    {
        selectedClusterId_ = clusterId;

        if (selectedWellId_ is Guid wellId)
        {
            Well? selectedWell = FindWellById(wellId);
            if (selectedWell == null || (!selectedWell.IsSingleWell && selectedWell.ClusterID != selectedClusterId_))
            {
                selectedWellId_ = null;
            }
        }

        return Task.CompletedTask;
    }

    private Task OnWellChanged(Guid? wellId)
    {
        selectedWellId_ = wellId;

        if (selectedWellId_ is Guid selectedId)
        {
            Well? selectedWell = FindWellById(selectedId);
            if (selectedWell != null)
            {
                selectedClusterId_ = selectedWell.IsSingleWell ? null : selectedWell.ClusterID;
                selectedFieldId_ ??= FindFieldIdForWell(selectedWell);
            }
        }

        return Task.CompletedTask;
    }

