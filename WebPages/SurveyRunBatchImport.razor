    private async Task ImportAssociationTableAsync(InputFileChangeEventArgs args)
    {
        try
        {
            IBrowserFile? file = args.File;
            if (file == null)
            {
                return;
            }

            using System.IO.Stream stream = file.OpenReadStream(20 * 1024 * 1024);
            using StreamReader reader = new(stream);
            string json = await reader.ReadToEndAsync();
            TrajectoryAssociationPackage? package = JsonSerializer.Deserialize<TrajectoryAssociationPackage>(json, BatchImportJsonOptions);

            if (package == null)
            {
                Snackbar.Add("Association import failed: invalid file content.", Severity.Warning);
                return;
            }

            selectedFieldId_ = package.SelectedFieldId;
            selectedClusterId_ = package.SelectedClusterId;
            selectedWellId_ = package.SelectedWellId;
            commonDepthReference_ = string.IsNullOrWhiteSpace(package.CommonDepthReference) ? commonDepthReference_ : package.CommonDepthReference;
            replaceExistingTrajectories_ = package.ReplaceExistingTrajectories;
            replaceTrajectoriesWithSameName_ = package.ReplaceTrajectoriesWithSameName;

            if (package.Settings != null)
            {
                selectedSurveyImportFormat_ = package.Settings.SelectedSurveyImportFormat ?? selectedSurveyImportFormat_;
                selectedSurveyImportSeparator_ = package.Settings.SelectedSurveyImportSeparator ?? selectedSurveyImportSeparator_;
                selectedSurveyImportDecimalMarker_ = package.Settings.SelectedSurveyImportDecimalMarker ?? selectedSurveyImportDecimalMarker_;
                selectedSurveyImportMDUnit_ = package.Settings.SelectedSurveyImportMDUnit ?? selectedSurveyImportMDUnit_;
                selectedSurveyImportInclinationUnit_ = package.Settings.SelectedSurveyImportInclinationUnit ?? selectedSurveyImportInclinationUnit_;
                selectedSurveyImportAzimuthUnit_ = package.Settings.SelectedSurveyImportAzimuthUnit ?? selectedSurveyImportAzimuthUnit_;
                surveyImportMDColumn_ = package.Settings.SurveyImportMDColumn;
                surveyImportInclinationColumn_ = package.Settings.SurveyImportInclinationColumn;
                surveyImportAzimuthColumn_ = package.Settings.SurveyImportAzimuthColumn;
                surveyImportMDStart_ = package.Settings.SurveyImportMDStart;
                surveyImportMDWidth_ = package.Settings.SurveyImportMDWidth;
                surveyImportInclinationStart_ = package.Settings.SurveyImportInclinationStart;
                surveyImportInclinationWidth_ = package.Settings.SurveyImportInclinationWidth;
                surveyImportAzimuthStart_ = package.Settings.SurveyImportAzimuthStart;
                surveyImportAzimuthWidth_ = package.Settings.SurveyImportAzimuthWidth;
            }

            NormalizeSelectionChain();
            rows_.Clear();

            foreach (TrajectoryAssociationRow row in package.Rows ?? [])
            {
                rows_.Add(new TrajectoryImportRowState
                {
                    WellBoreId = row.WellBoreId,
                    SurveyInstrumentId = row.SurveyInstrumentId,
                    ParentSurveyRunId = row.ParentSurveyRunId,
                    DepthReferenceName = string.IsNullOrWhiteSpace(row.DepthReferenceName) ? commonDepthReference_ : row.DepthReferenceName,
                    FileName = row.FileName,
                    FileContent = string.IsNullOrWhiteSpace(row.FileContentBase64) ? null : Convert.FromBase64String(row.FileContentBase64),
                    Status = "Imported"
                });
            }

            EnsureAtLeastOneRow();
            EnsureSurveyImportUnitsSelected();
            Snackbar.Add("Association table imported.", Severity.Success);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while importing the batch description");
            Snackbar.Add("Error importing batch description: " + ex.Message, Severity.Warning);
        }
    }

    private List<SurveyStation> ParseSurveyStations(string content, TrajectoryImportRowState row, Cluster? cluster, WellBore? wellBore, out int skippedLines)
    {
        string[] lines = content.Split(["\r\n", "\n", "\r"], StringSplitOptions.None);
        List<SurveyStation> importedStations = [];
        skippedLines = 0;
        double? previousMD = null;
        DepthReferenceContext depthReferenceContext = BuildDepthReferenceContext(row.DepthReferenceName, cluster, wellBore);

        foreach (string line in lines)
        {
            if (!TryParseSurveyStationLine(line, depthReferenceContext, out SurveyStation? station))
            {
                skippedLines++;
                continue;
            }

            if (station?.MD is not { } md)
            {
                skippedLines++;
                continue;
            }

            if (previousMD is { } lastMD && md <= lastMD)
            {
                skippedLines++;
                continue;
            }

            importedStations.Add(station);
            previousMD = md;
        }

        return importedStations;
    }

    private bool TryParseSurveyStationLine(string line, DepthReferenceContext depthReferenceContext, out SurveyStation? station)
    {
        station = null;
        if (string.IsNullOrWhiteSpace(line))
        {
            return false;
        }

        string? mdToken;
        string? inclinationToken;
        string? azimuthToken;

        if (IsFixedWidthImportFormat)
        {
            mdToken = ReadFixedWidthToken(line, surveyImportMDStart_, surveyImportMDWidth_);
            inclinationToken = ReadFixedWidthToken(line, surveyImportInclinationStart_, surveyImportInclinationWidth_);
            azimuthToken = ReadFixedWidthToken(line, surveyImportAzimuthStart_, surveyImportAzimuthWidth_);
        }
        else
        {
            List<string> columns = SplitDelimitedColumns(line);
            mdToken = ReadColumnToken(columns, surveyImportMDColumn_);
            inclinationToken = ReadColumnToken(columns, surveyImportInclinationColumn_);
            azimuthToken = ReadColumnToken(columns, surveyImportAzimuthColumn_);
        }

        if (!TryParseImportedNumber(mdToken, out double md) ||
            !TryParseImportedNumber(inclinationToken, out double inclination) ||
            !TryParseImportedNumber(azimuthToken, out double azimuth))
        {
            return false;
        }

        station = new SurveyStation
        {
            MD = ConvertDepthToSI(md, selectedSurveyImportMDUnit_, depthReferenceContext),
            Inclination = ConvertAngleToSI(inclination, selectedSurveyImportInclinationUnit_),
            Azimuth = ConvertAngleToSI(azimuth, selectedSurveyImportAzimuthUnit_)
        };
        return true;
    }

    private List<string> SplitDelimitedColumns(string line)
    {
        return selectedSurveyImportSeparator_ switch
        {
            "Semicolon (;)" => line.Split(';').Select(value => value.Trim()).ToList(),
            "Tab" => line.Split('\t').Select(value => value.Trim()).ToList(),
            "Space" => Regex.Split(line.Trim(), @"\s+").Where(value => !string.IsNullOrWhiteSpace(value)).ToList(),
            _ => line.Split(';').Select(value => value.Trim()).ToList()
        };
    }

    private static string? ReadColumnToken(List<string> columns, int columnIndex)
    {
        if (columnIndex < 1 || columnIndex > columns.Count)
        {
            return null;
        }

        return columns[columnIndex - 1];
    }

    private static string? ReadFixedWidthToken(string line, int start, int width)
    {
        if (start < 1 || width < 1)
        {
            return null;
        }

        int index = start - 1;
        if (line.Length <= index)
        {
            return null;
        }

        int safeWidth = Math.Min(width, line.Length - index);
        return line.Substring(index, safeWidth).Trim();
    }

    private bool TryParseImportedNumber(string? token, out double value)
    {
        value = 0;
        if (string.IsNullOrWhiteSpace(token))
        {
            return false;
        }

        string normalized = token.Trim();

        if (selectedSurveyImportDecimalMarker_ == "Dot (.)")
        {
            normalized = normalized.Replace(",", string.Empty);
        }
        else if (selectedSurveyImportDecimalMarker_ == "Comma (,)")
        {
            normalized = normalized.Replace(".", string.Empty).Replace(',', '.');
        }
        else
        {
            normalized = NormalizeAutoDecimalNumber(normalized);
        }

        return double.TryParse(normalized, NumberStyles.Float | NumberStyles.AllowLeadingSign, CultureInfo.InvariantCulture, out value);
    }

    private static string NormalizeAutoDecimalNumber(string token)
    {
        int lastComma = token.LastIndexOf(',');
        int lastDot = token.LastIndexOf('.');

        if (lastComma >= 0 && lastDot >= 0)
        {
            if (lastComma > lastDot)
            {
                return token.Replace(".", string.Empty).Replace(',', '.');
            }

            return token.Replace(",", string.Empty);
        }

        if (lastComma >= 0)
        {
            return token.Replace(',', '.');
        }

        return token;
    }

    private void EnsureSurveyImportUnitsSelected()
    {
        string defaultDepthUnit = DepthDrillingQuantity.Instance.GetUnitChoice(DepthDrillingQuantity.UnitChoicesEnum.Metre).UnitName;
        string defaultAngleUnit = PlaneAngleDrillingQuantity.Instance.GetUnitChoice(PlaneAngleDrillingQuantity.UnitChoicesEnum.Degree).UnitName;

        if (string.IsNullOrWhiteSpace(selectedSurveyImportMDUnit_) || !AvailableSurveyImportDepthUnits.Contains(selectedSurveyImportMDUnit_))
        {
            selectedSurveyImportMDUnit_ = AvailableSurveyImportDepthUnits.Contains(defaultDepthUnit)
                ? defaultDepthUnit
                : AvailableSurveyImportDepthUnits.FirstOrDefault() ?? selectedSurveyImportMDUnit_;
        }

        if (string.IsNullOrWhiteSpace(selectedSurveyImportInclinationUnit_) || !AvailableSurveyImportAngleUnits.Contains(selectedSurveyImportInclinationUnit_))
        {
            selectedSurveyImportInclinationUnit_ = AvailableSurveyImportAngleUnits.Contains(defaultAngleUnit)
                ? defaultAngleUnit
                : AvailableSurveyImportAngleUnits.FirstOrDefault() ?? selectedSurveyImportInclinationUnit_;
        }

        if (string.IsNullOrWhiteSpace(selectedSurveyImportAzimuthUnit_) || !AvailableSurveyImportAngleUnits.Contains(selectedSurveyImportAzimuthUnit_))
        {
            selectedSurveyImportAzimuthUnit_ = AvailableSurveyImportAngleUnits.Contains(defaultAngleUnit)
                ? defaultAngleUnit
                : AvailableSurveyImportAngleUnits.FirstOrDefault() ?? selectedSurveyImportAzimuthUnit_;
        }
    }

    private List<string> GetAvailableSurveyImportUnits(List<OSDC.UnitConversion.Conversion.UnitChoice> unitChoices)
    {
        HashSet<string> unitLabels = new(StringComparer.OrdinalIgnoreCase);
        foreach (var choice in unitChoices)
        {
            if (choice != null && !string.IsNullOrEmpty(choice.UnitName))
            {
                unitLabels.Add(choice.UnitName);
            }
        }

        return unitLabels
            .Where(label => !string.IsNullOrWhiteSpace(label))
            .OrderBy(label => label, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private double ConvertDepthToSI(double value, string unit, DepthReferenceContext depthReferenceContext)
    {
        OSDC.UnitConversion.Conversion.UnitChoice? unitChoice = DepthDrillingQuantity.UnitChoiceDescriptions
            .FirstOrDefault(choice => choice != null && choice.UnitName == unit);

        if (unitChoice != null)
        {
            value = DepthDrillingQuantity.Instance.ToSI(value, unitChoice.ID);
        }

        return value - depthReferenceContext.OffsetToWgs84;
    }

    private static void ApplyDepthReferenceContext(DepthReferenceContext context)
    {
        DataUtils.UpdateDepthReferenceName(context.DepthReferenceName);
        DataUtils.GroundMudLineDepthReferenceSource.GroundMudLineDepthReference = context.GroundMudLineDepthReference;
        DataUtils.SeaWaterLevelDepthReferenceSource.SeaWaterLevelDepthReference = context.SeaWaterLevelDepthReference;
        DataUtils.RotaryTableDepthReferenceSource.RotaryTableDepthReference = context.RotaryTableDepthReference;
    }

    private DepthReferenceContext BuildDepthReferenceContext(string? depthReferenceName, Cluster? cluster, WellBore? wellBore)
    {
        string normalizedDepthReference = string.IsNullOrWhiteSpace(depthReferenceName) ? commonDepthReference_ : depthReferenceName;
        double groundMudLineOffset = cluster?.GroundMudLineDepth?.GaussianValue?.Mean is double gml ? -gml : 0.0;
        double seaWaterLevelOffset = cluster?.TopWaterDepth?.GaussianValue?.Mean is double swl ? -swl : 0.0;
        double rotaryTableOffset = ResolveRotaryTableOffset(wellBore, cluster);

        double offsetToWgs84 = normalizedDepthReference switch
        {
            "Ground/Mud line" => groundMudLineOffset,
            "Sea water level" => seaWaterLevelOffset,
            _ => rotaryTableOffset
        };

        return new DepthReferenceContext
        {
            DepthReferenceName = normalizedDepthReference,
            OffsetToWgs84 = offsetToWgs84,
            GroundMudLineDepthReference = groundMudLineOffset,
            SeaWaterLevelDepthReference = seaWaterLevelOffset,
            RotaryTableDepthReference = rotaryTableOffset
        };
    }

    private double ResolveRotaryTableOffset(WellBore? wellBore, Cluster? cluster)
    {
        Guid? rigId = wellBore?.RigID;
        if (rigId == null && cluster?.RigID != null)
        {
            rigId = cluster.RigID;
        }

        if (rigId is not Guid resolvedRigId)
        {
            return 0.0;
        }

        Rig? rig = rigList_?.FirstOrDefault(item => item?.MetaInfo?.ID == resolvedRigId);
        return rig?.DrillFloorElevation is double rotaryTableDepthWgs84
            ? -rotaryTableDepthWgs84
            : 0.0;
    }

    private async Task<System.Collections.Generic.ICollection<TrajectoryLight>> GetExistingTrajectoriesAsync(Guid wellBoreId)
