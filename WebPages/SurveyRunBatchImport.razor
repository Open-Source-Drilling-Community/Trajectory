    private async Task DeleteExistingTrajectoriesAsync(IEnumerable<TrajectoryLight> existingTrajectories)
    {
        foreach (TrajectoryLight trajectory in existingTrajectories)
        {
            if (trajectory?.MetaInfo?.ID is Guid trajectoryId && trajectoryId != Guid.Empty)
            {
                await Api.ClientTrajectory.DeleteTrajectoryByIdAsync(trajectoryId);
            }
        }
    }

    private static string GenerateTrajectoryName(string baseName, IEnumerable<TrajectoryLight> existingTrajectories)
    {
        HashSet<string> existingNames = existingTrajectories
            .Where(trajectory => !string.IsNullOrWhiteSpace(trajectory?.Name))
            .Select(trajectory => trajectory!.Name!)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!existingNames.Contains(baseName))
        {
            return baseName;
        }

        for (int index = 2; index < int.MaxValue; index++)
        {
            string candidate = $"{baseName} ({index})";
            if (!existingNames.Contains(candidate))
            {
                return candidate;
            }
        }

        return $"{baseName} ({Guid.NewGuid():N})";
    }

    private static double ConvertAngleToSI(double value, string unit)
    {
        OSDC.UnitConversion.Conversion.UnitChoice? unitChoice = PlaneAngleDrillingQuantity.UnitChoiceDescriptions
            .FirstOrDefault(choice => choice != null && choice.UnitName == unit);

        if (unitChoice != null)
        {
            value = PlaneAngleDrillingQuantity.Instance.ToSI(value, unitChoice.ID);
        }

        return value;
    }

    private List<WellBore> GetRowWellBoreOptions(TrajectoryImportRowState row)
    {
        IEnumerable<WellBore> options = AvailableWellBores;

        if (row.WellBoreId is Guid wellBoreId)
        {
            WellBore? current = FindWellBoreById(wellBoreId);
            if (current != null && !options.Any(option => option.MetaInfo.ID == wellBoreId))
            {
                options = options.Concat([current]);
            }
        }

        return options
            .Where(option => option?.MetaInfo != null)
            .OrderBy(option => option.Name)
            .ToList();
    }

    private List<SurveyRun> GetRowParentSurveyRunOptions(TrajectoryImportRowState row) =>
        allSurveyRunHeavyList_?
            .Where(surveyRun =>
                surveyRun?.MetaInfo?.ID is Guid &&
                IsParentSurveyRunCandidate(row, surveyRun))
            .OrderBy(surveyRun => surveyRun.Name)
            .ToList() ?? [];

    private bool IsRowParentSurveyRunRequired(TrajectoryImportRowState row)
    {
        if (row.FileContent == null || row.WellBoreId is not Guid)
        {
            return false;
        }

        string content = Encoding.UTF8.GetString(row.FileContent);
        WellBore? wellBore = row.WellBoreId is Guid wellBoreId ? FindWellBoreById(wellBoreId) : null;
        Well? well = wellBore?.WellID is Guid wellId ? FindWellById(wellId) : null;
        Cluster? cluster = well?.ClusterID is Guid clusterId ? FindClusterById(clusterId) : null;
        List<SurveyStation> stations = ParseSurveyStations(content, row, cluster, wellBore, out _);
        return IsSurveyRunParentRequired(row, stations);
    }

    private bool IsSurveyRunParentRequired(TrajectoryImportRowState row, List<SurveyStation> stations) =>
        GetFirstSurveyStationMd(stations) is { } firstMd &&
        GetRowWellheadMd(row) is { } wellheadMd &&
        firstMd > wellheadMd;

    private bool IsParentSurveyRunCandidate(TrajectoryImportRowState row, SurveyRun candidate)
    {
        if (row.FileContent == null)
        {
            return false;
        }

        string content = Encoding.UTF8.GetString(row.FileContent);
        WellBore? wellBore = row.WellBoreId is Guid wellBoreId ? FindWellBoreById(wellBoreId) : null;
        Well? well = wellBore?.WellID is Guid wellId ? FindWellById(wellId) : null;
        Cluster? cluster = well?.ClusterID is Guid clusterId ? FindClusterById(clusterId) : null;
        List<SurveyStation> stations = ParseSurveyStations(content, row, cluster, wellBore, out _);

        if (GetFirstSurveyStationMd(stations) is not { } firstMd ||
            candidate.SurveyStationList is not { Count: > 0 } candidateStations)
        {
            return false;
        }

        List<double> candidateMds = candidateStations
            .Select(station => station.MD ?? station.Abscissa)
            .Where(md => md.HasValue)
            .Select(md => md!.Value)
            .OrderBy(md => md)
            .ToList();

        if (candidateMds.Count == 0)
        {
            return false;
        }

        const double maxTieInGap = 10.0;
        double firstParentMd = candidateMds.First();
        double lastParentMd = candidateMds.Last();
        return (firstParentMd <= firstMd && firstMd <= lastParentMd) ||
               (lastParentMd <= firstMd && firstMd - lastParentMd <= maxTieInGap);
    }

    private static double? GetFirstSurveyStationMd(List<SurveyStation> stations) =>
        stations
            .Select(station => station.MD ?? station.Abscissa)
            .Where(md => md.HasValue)
            .Select(md => md!.Value)
            .OrderBy(md => md)
            .Cast<double?>()
            .FirstOrDefault();

    private double? GetRowWellheadMd(TrajectoryImportRowState row)
    {
        WellBore? wellBore = row.WellBoreId is Guid wellBoreId ? FindWellBoreById(wellBoreId) : null;
        Well? well = wellBore?.WellID is Guid wellId ? FindWellById(wellId) : null;
        Cluster? cluster = well?.ClusterID is Guid clusterId ? FindClusterById(clusterId) : null;
        return cluster?.ReferenceDepth?.GaussianValue?.Mean;
    }

    private void ClearInvalidParentSurveyRunSelection(TrajectoryImportRowState row)
    {
        if (!IsRowParentSurveyRunRequired(row))
        {
            row.ParentSurveyRunId = null;
            return;
        }

        if (row.ParentSurveyRunId is Guid parentSurveyRunId &&
            !GetRowParentSurveyRunOptions(row).Any(surveyRun => surveyRun.MetaInfo?.ID == parentSurveyRunId))
        {
            row.ParentSurveyRunId = null;
        }
    }

    private bool MatchesSelectedField(Well well)
    {
        if (selectedFieldId_ == null)
        {
            return true;
        }

        Guid? fieldId = FindFieldIdForWell(well);
        return fieldId == selectedFieldId_;
    }

    private Guid? FindFieldIdForWell(Well? well)
    {
        if (well?.ClusterID is Guid clusterId)
        {
            return FindClusterById(clusterId)?.FieldID;
        }

        return null;
    }

    private Well? FindWellById(Guid wellId) =>
        wellList_?.FirstOrDefault(well => well?.MetaInfo?.ID == wellId);

    private Cluster? FindClusterById(Guid clusterId) =>
        clusterList_?.FirstOrDefault(cluster => cluster?.MetaInfo?.ID == clusterId);

    private WellBore? FindWellBoreById(Guid wellBoreId) =>
        wellBoreList_?.FirstOrDefault(wellBore => wellBore?.MetaInfo?.ID == wellBoreId);

    private Color GetStatusColor(string status)
    {
        if (status.Contains("Uploaded", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Success;
        }

        if (status.Contains("failed", StringComparison.OrdinalIgnoreCase) ||
            status.Contains("invalid", StringComparison.OrdinalIgnoreCase) ||
            status.Contains("select", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Error;
        }

        if (status.Contains("Parsing", StringComparison.OrdinalIgnoreCase) ||
            status.Contains("Uploading", StringComparison.OrdinalIgnoreCase) ||
            status.Contains("Replacing", StringComparison.OrdinalIgnoreCase) ||
            status.Contains("Deleting", StringComparison.OrdinalIgnoreCase))
        {
            return Color.Info;
        }

        return Color.Default;
    }

