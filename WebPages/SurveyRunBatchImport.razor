        selectedSurveyImportFormat_ = string.IsNullOrWhiteSpace(settings.SelectedSurveyImportFormat) ? selectedSurveyImportFormat_ : settings.SelectedSurveyImportFormat;
        selectedSurveyImportSeparator_ = string.IsNullOrWhiteSpace(settings.SelectedSurveyImportSeparator) ? selectedSurveyImportSeparator_ : settings.SelectedSurveyImportSeparator;
        selectedSurveyImportDecimalMarker_ = string.IsNullOrWhiteSpace(settings.SelectedSurveyImportDecimalMarker) ? selectedSurveyImportDecimalMarker_ : settings.SelectedSurveyImportDecimalMarker;
        selectedSurveyImportMDUnit_ = string.IsNullOrWhiteSpace(settings.SelectedSurveyImportMDUnit) ? selectedSurveyImportMDUnit_ : settings.SelectedSurveyImportMDUnit;
        selectedSurveyImportInclinationUnit_ = string.IsNullOrWhiteSpace(settings.SelectedSurveyImportInclinationUnit) ? selectedSurveyImportInclinationUnit_ : settings.SelectedSurveyImportInclinationUnit;
        selectedSurveyImportAzimuthUnit_ = string.IsNullOrWhiteSpace(settings.SelectedSurveyImportAzimuthUnit) ? selectedSurveyImportAzimuthUnit_ : settings.SelectedSurveyImportAzimuthUnit;
        surveyImportMDColumn_ = settings.SurveyImportMDColumn > 0 ? settings.SurveyImportMDColumn : surveyImportMDColumn_;
        surveyImportInclinationColumn_ = settings.SurveyImportInclinationColumn > 0 ? settings.SurveyImportInclinationColumn : surveyImportInclinationColumn_;
        surveyImportAzimuthColumn_ = settings.SurveyImportAzimuthColumn > 0 ? settings.SurveyImportAzimuthColumn : surveyImportAzimuthColumn_;
        surveyImportMDStart_ = settings.SurveyImportMDStart > 0 ? settings.SurveyImportMDStart : surveyImportMDStart_;
        surveyImportMDWidth_ = settings.SurveyImportMDWidth > 0 ? settings.SurveyImportMDWidth : surveyImportMDWidth_;
        surveyImportInclinationStart_ = settings.SurveyImportInclinationStart > 0 ? settings.SurveyImportInclinationStart : surveyImportInclinationStart_;
        surveyImportInclinationWidth_ = settings.SurveyImportInclinationWidth > 0 ? settings.SurveyImportInclinationWidth : surveyImportInclinationWidth_;
        surveyImportAzimuthStart_ = settings.SurveyImportAzimuthStart > 0 ? settings.SurveyImportAzimuthStart : surveyImportAzimuthStart_;
        surveyImportAzimuthWidth_ = settings.SurveyImportAzimuthWidth > 0 ? settings.SurveyImportAzimuthWidth : surveyImportAzimuthWidth_;

        rows_.Clear();
        foreach (SharedSurveyRunBatchImportRow row in batchImport.Rows ?? [])
        {
            rows_.Add(new TrajectoryImportRowState
            {
                RowId = row.RowId,
                WellBoreId = row.WellBoreId,
