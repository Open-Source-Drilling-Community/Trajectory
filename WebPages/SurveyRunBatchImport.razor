    private async Task UploadTrajectoriesAsync()
    {
        List<TrajectoryImportRowState> candidateRows = rows_
            .Where(row => row.WellBoreId != null || row.FileContent != null)
            .ToList();

        if (candidateRows.Count == 0)
        {
            Snackbar.Add("Add at least one row with a wellbore and a file before uploading.", Severity.Warning);
            return;
        }

        isUploading_ = true;
        int uploadedCount = 0;
        int failedCount = 0;

        try
        {
            foreach (TrajectoryImportRowState row in candidateRows)
            {
                try
                {
                    if (row.WellBoreId is not Guid wellBoreId)
                    {
                        row.Status = "Select a wellbore";
                        failedCount++;
                        continue;
                    }

                    if (row.FileContent == null || row.FileContent.Length == 0)
                    {
                        row.Status = "Select a file";
                        failedCount++;
                        continue;
                    }

                    if (row.SurveyInstrumentId is not Guid surveyInstrumentId)
                    {
                        row.Status = "Select a survey instrument";
                        failedCount++;
                        continue;
                    }

                    WellBore? wellBore = FindWellBoreById(wellBoreId);
                    Well? well = wellBore?.WellID is Guid wellId ? FindWellById(wellId) : null;
                    Cluster? cluster = well?.ClusterID is Guid clusterId ? FindClusterById(clusterId) : null;
                    Guid? fieldId = cluster?.FieldID ?? FindFieldIdForWell(well);
                    List<TrajectoryLight> existingTrajectories = (await GetExistingTrajectoriesAsync(wellBoreId)).ToList();

                    row.Status = "Parsing file";
                    string content = Encoding.UTF8.GetString(row.FileContent);
                    List<SurveyStation> importedStations = ParseSurveyStations(content, row, cluster, wellBore, out int skippedLines);

                    if (importedStations.Count < 3)
                    {
                        row.Status = "Invalid trajectory file";
                        failedCount++;
                        continue;
                    }

                    if (IsSurveyRunParentRequired(row, importedStations))
                    {
                        if (row.ParentSurveyRunId is not Guid parentSurveyRunId || !GetRowParentSurveyRunOptions(row).Any(surveyRun => surveyRun.MetaInfo?.ID == parentSurveyRunId))
                        {
                            row.Status = "Select a parent survey run";
                            failedCount++;
                            continue;
                        }
                    }
                    else
                    {
                        row.ParentSurveyRunId = null;
                    }

                    if (replaceExistingTrajectories_)
                    {
                        row.Status = "Deleting previous trajectories";
                        await DeleteExistingTrajectoriesAsync(existingTrajectories);
                        existingTrajectories.Clear();
                    }

                    string baseTrajectoryName = Path.GetFileNameWithoutExtension(row.FileName ?? "survey-run");
                    TrajectoryLight? sameNameTrajectory = existingTrajectories.FirstOrDefault(trajectory => string.Equals(trajectory?.Name, baseTrajectoryName, StringComparison.OrdinalIgnoreCase));
                    SurveyRun surveyRun = CreateSurveyRun(row, importedStations, fieldId, cluster, well, baseTrajectoryName, surveyInstrumentId);

                    row.Status = "Uploading survey run";
                    await Api.ClientTrajectory.PostSurveyRunAsync(surveyRun);
                    await UploadSurveyMeasurementChunksAsync(surveyRun.MetaInfo.ID, importedStations.Select(SurveyMeasurement.FromSurveyStation).ToList());
                    await Api.ClientTrajectory.CommitSurveyRunSurveyMeasurementChunksAsync(surveyRun.MetaInfo.ID);

                    if (!replaceExistingTrajectories_ && replaceTrajectoriesWithSameName_ && sameNameTrajectory?.MetaInfo?.ID is Guid existingTrajectoryId && existingTrajectoryId != Guid.Empty)
                    {
                        Trajectory? trajectory = await Api.ClientTrajectory.GetTrajectoryByIdAsync(existingTrajectoryId);
                        if (trajectory == null)
                        {
                            row.Status = "Matching trajectory not found";
                            failedCount++;
                            continue;
                        }

                        ApplySurveyRunToTrajectory(trajectory, row, surveyRun, importedStations, fieldId, cluster, well, baseTrajectoryName);
                        trajectory.LastModificationDate = DateTimeOffset.UtcNow;

                        row.Status = "Replacing matching trajectory";
                        await Api.ClientTrajectory.PutTrajectoryByIdAsync(existingTrajectoryId, trajectory);
                    }
                    else
                    {
                        string trajectoryName = GenerateTrajectoryName(baseTrajectoryName, existingTrajectories);
                        Trajectory trajectory = CreateTrajectory(row, surveyRun, importedStations, fieldId, cluster, well, trajectoryName);
                        row.Status = "Uploading default trajectory";
                        await Api.ClientTrajectory.PostTrajectoryAsync(trajectory);
                    }

                    uploadedCount++;
                    row.Status = $"Uploaded ({importedStations.Count} stations, {skippedLines} skipped)";
                }
                catch (Exception ex)
                {
                    failedCount++;
                    row.Status = "Upload failed";
                    logger.LogError(ex, "Problem while uploading trajectory for row {RowId}", row.RowId);
                }
            }
        }
        finally
        {
            isUploading_ = false;
        }

        if (uploadedCount > 0)
        {
            Snackbar.Add($"Uploaded {uploadedCount} survey runs.", Severity.Success);
        }

        if (failedCount > 0)
        {
            Snackbar.Add($"{failedCount} rows could not be uploaded. Check the row status column.", Severity.Warning);
        }
    }

    private SurveyRun CreateSurveyRun(TrajectoryImportRowState row, List<SurveyStation> surveyStations, Guid? fieldId, Cluster? cluster, Well? well, string surveyRunName, Guid surveyInstrumentId)
    {
        DateTimeOffset now = DateTimeOffset.UtcNow;
        return new SurveyRun
        {
            MetaInfo = new MetaInfo { ID = Guid.NewGuid() },
            Name = surveyRunName,
            Description = $"Imported from {(row.FileName ?? "survey run file")}",
            CreationDate = now,
            LastModificationDate = now,
            FieldID = fieldId,
            ClusterID = well is { IsSingleWell: true } ? null : cluster?.MetaInfo.ID,
            WellID = well?.MetaInfo.ID,
            WellBoreID = row.WellBoreId ?? Guid.Empty,
            SurveyInstrumentID = surveyInstrumentId,
            SurveyRunType = SurveyRunType.Actual,
            CalculationType = TrajectoryCalculationType.MinimumCurvatureMethod,
            ParentSurveyRunID = row.ParentSurveyRunId,
            SurveyMeasurementList = null,
            SurveyStationList = null
        };
    }

    private async Task UploadSurveyMeasurementChunksAsync(Guid surveyRunId, List<SurveyMeasurement> measurements)
    {
        await Api.ClientTrajectory.DeleteSurveyRunSurveyMeasurementChunksAsync(surveyRunId);
        int chunkIndex = 0;
        foreach (List<SurveyMeasurement> measurementChunk in measurements.Chunk(SurveyMeasurementChunkSize).Select(chunk => chunk.ToList()))
        {
            SurveyMeasurementChunk chunk = new()
            {
                SurveyRunID = surveyRunId,
                ChunkIndex = chunkIndex,
                MeasurementCount = measurementChunk.Count,
                StartMD = measurementChunk.FirstOrDefault()?.MD,
                EndMD = measurementChunk.LastOrDefault()?.MD,
                SurveyMeasurementList = measurementChunk
            };
            await Api.ClientTrajectory.PutSurveyRunSurveyMeasurementChunkAsync(surveyRunId, chunkIndex, chunk);
            chunkIndex++;
        }
    }

    private Trajectory CreateTrajectory(TrajectoryImportRowState row, SurveyRun surveyRun, List<SurveyStation> surveyStations, Guid? fieldId, Cluster? cluster, Well? well, string trajectoryName)
    {
        Trajectory trajectory = PseudoConstructors.ConstructTrajectory();
        DateTimeOffset now = DateTimeOffset.UtcNow;

        trajectory.MetaInfo.ID = Guid.NewGuid();
        trajectory.CreationDate = now;
        trajectory.LastModificationDate = now;
        ApplySurveyRunToTrajectory(trajectory, row, surveyRun, surveyStations, fieldId, cluster, well, trajectoryName);

        return trajectory;
    }

    private static void ApplySurveyRunToTrajectory(Trajectory trajectory, TrajectoryImportRowState row, SurveyRun surveyRun, List<SurveyStation> surveyStations, Guid? fieldId, Cluster? cluster, Well? well, string trajectoryName)
    {
        trajectory.Name = trajectoryName;
        trajectory.Description = $"Imported from {(row.FileName ?? "survey run file")}";
        trajectory.FieldID = fieldId;
        trajectory.ClusterID = well is { IsSingleWell: true } ? null : cluster?.MetaInfo.ID;
        trajectory.WellID = well?.MetaInfo.ID;
        trajectory.WellBoreID = row.WellBoreId ?? Guid.Empty;
        trajectory.TrajectoryType = TrajectoryType.Actual;
        trajectory.IsDefinitive = false;
        trajectory.CalculationType = TrajectoryCalculationType.MinimumCurvatureMethod;
        trajectory.MDStep = EstimateMdStep(surveyStations);
        trajectory.SurveyStationList = null;
        trajectory.SurveyRunSectionList =
        [
            new TrajectorySurveyRunSection
            {
                SurveyRunID = surveyRun.MetaInfo?.ID ?? Guid.Empty,
                StartAbscissa = surveyStations.FirstOrDefault()?.MD ?? surveyStations.FirstOrDefault()?.Abscissa ?? 0.0
            }
        ];
    }

    private static double EstimateMdStep(List<SurveyStation> surveyStations)
    {
        if (surveyStations.Count < 2)
        {
            return 10.0;
        }

        for (int i = 1; i < surveyStations.Count; i++)
        {
            if (surveyStations[i].MD is { } currentMd && surveyStations[i - 1].MD is { } previousMd)
            {
                double delta = currentMd - previousMd;
                if (delta > 0)
                {
                    return delta;
                }
            }
        }

        return 10.0;
    }

