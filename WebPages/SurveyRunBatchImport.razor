    private async Task DeleteBatchImport(Guid id)
    {
        try
        {
            if (await ConfirmDeletion())
            {
                if (!await DeleteStoredBatchImportAsync(id))
                {
                    Snackbar.Add("Failed to delete batch import.", Severity.Error);
                }
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete batch import");
            Snackbar.Add("Failed to delete batch import.", Severity.Error);
        }
    }

    private async Task DeleteSelectedBatchImports()
    {
        List<SharedSurveyRunBatchImportLight> toDelete = selectedBatchImportList_.ToList();
        if (toDelete.Count == 0)
        {
            return;
        }

        try
        {
            if (await ConfirmDeletion())
            {
                foreach (SharedSurveyRunBatchImportLight batchImport in toDelete)
                {
                    if (batchImport.MetaInfo?.ID is Guid id && id != Guid.Empty)
                    {
                        await DeleteStoredBatchImportAsync(id);
                    }
                }
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete selected batch imports");
            Snackbar.Add("Failed to delete one or more batch imports.", Severity.Error);
        }
    }

    private async Task<bool> ConfirmDeletion()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };
        var dialog = await DialogService.ShowAsync<DialogDeleteTemplate>("DELETE", options);
        var result = await dialog.Result;
        return result != null && !result.Canceled;
    }

