@page "/SurveyRunBatchImport"
@inject ILogger<SurveyRunBatchImport> logger
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject ITrajectoryAPIUtils Api
@using System.Globalization
@using System.Text
@using System.Text.Json
@using System.Text.RegularExpressions
@using OSDC.UnitConversion.Conversion.DrillingEngineering
@using SharedSurveyImportSettings = NORCE.Drilling.Trajectory.ModelShared.SurveyImportSettings
@using SharedMetaInfo = NORCE.Drilling.Trajectory.ModelShared.MetaInfo
@using SharedSurveyRunBatchImport = NORCE.Drilling.Trajectory.ModelShared.SurveyRunBatchImport
@using SharedSurveyRunBatchImportLight = NORCE.Drilling.Trajectory.ModelShared.SurveyRunBatchImportLight
@using SharedSurveyRunBatchImportRow = NORCE.Drilling.Trajectory.ModelShared.SurveyRunBatchImportRow

<MudText Class="mt-4 mb-4" Typo="Typo.h5"><strong>Batch Import Survey Runs</strong></MudText>

@if (isLoading_)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div hidden="@isHiddenMainPanel_">
            <MudDataGrid T="SharedSurveyRunBatchImportLight" @key="_gridKey"
                     MultiSelection="true" Items="@batchImportList_"
                     SelectedItemsChanged="@SelectedItemsChanged"
                     Hover="true" RowClick="@RowClicked"
                     SortMode="SortMode.Multiple" QuickFilter="@_batchImportFilter"
                     Filterable="false" ReadOnly="true" ColumnResizeMode="ResizeMode.Column" Elevation="0">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Saved Survey Run Batch Imports</MudText>
                <MudButton OnClick="@AddBatchImport" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
                <MudButton OnClick="@DeleteSelectedBatchImports" Color="@Color.Error" Class="add-item-btn"
                           Disabled="@(selectedBatchImportList_.Count == 0)">Delete</MudButton>
                <MudSpacer />
                <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <Columns>
                    <SelectColumn T="SharedSurveyRunBatchImportLight" />
                <PropertyColumn Property="x => x.Name" Title="Batch Import" Sortable="true" />
                <PropertyColumn Property="x => x.Description" Title="Description" Sortable="true" />
                <PropertyColumn Property="x => x.LastModificationDate" Title="Last Updated" Sortable="true" />
                <TemplateColumn CellClass="d-flex justify-end">
                    <CellTemplate>
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete"
                                       OnClick="(() => DeleteBatchImport(context.Item.MetaInfo!.ID))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                    <MudDataGridPager T="SharedSurveyRunBatchImportLight" />
            </PagerContent>
        </MudDataGrid>
    </div>

    <div hidden="@isHiddenEditPanel_">
        <MudText Class="mt-4 mb-4" Typo="Typo.h6">Edit Batch Import</MudText>
        <MudContainer Class="d-flex flex-row mt-4 mb-4">
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Secondary" OnClick="UploadTrajectoriesAsync" Disabled="@isUploading_">Upload survey runs</MudButton>
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveBatchImportAsync">Save</MudButton>
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="HandleEditPanelClosed">Cancel</MudButton>
        </MudContainer>

        <MudGrid Class="mb-4">
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="currentBatchImport_.Name" Label="Name" Required="true" ShrinkLabel />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="currentBatchImport_.Description" Label="Description" ShrinkLabel />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField Value="@FormatDate(currentBatchImport_.CreationDate)" Label="Created" ReadOnly="true" ShrinkLabel />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudTextField Value="@FormatDate(currentBatchImport_.LastModificationDate)" Label="Last Updated" ReadOnly="true" ShrinkLabel />
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudText Typo="Typo.h6">Selection filters</MudText>
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId_" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                        @foreach (Field field in AvailableFields)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect Label="Cluster" T="Guid?" Value="@selectedClusterId_" ValueChanged="OnClusterChanged" ShrinkLabel Clearable="true">
                        @foreach (Cluster cluster in AvailableClusters)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">@cluster.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect Label="Well" T="Guid?" Value="@selectedWellId_" ValueChanged="OnWellChanged" ShrinkLabel Clearable="true">
                        @foreach (Well well in AvailableWells)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">@well.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudText Typo="Typo.h6">Survey run file format</MudText>
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="File format" @bind-Value="selectedSurveyImportFormat_" ShrinkLabel>
                        @foreach (string format in SurveyImportFormats)
                        {
                            <MudSelectItem T="string" Value="@format">@format</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                @if (IsDelimitedImportFormat)
                {
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" Label="Column separator" @bind-Value="selectedSurveyImportSeparator_" ShrinkLabel>
                            @foreach (string separator in SurveyImportSeparators)
                            {
                                <MudSelectItem T="string" Value="@separator">@separator</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="Decimal marker" @bind-Value="selectedSurveyImportDecimalMarker_" ShrinkLabel>
                        @foreach (string marker in SurveyImportDecimalMarkers)
                        {
                            <MudSelectItem T="string" Value="@marker">@marker</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudNumericField T="int" Label="MD column" @bind-Value="surveyImportMDColumn_" Min="1" Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudSelect T="string" Label="MD unit" @bind-Value="selectedSurveyImportMDUnit_" ShrinkLabel>
                        @foreach (string unit in AvailableSurveyImportDepthUnits)
                        {
                            <MudSelectItem T="string" Value="@unit">@unit</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudNumericField T="int" Label="Incl column" @bind-Value="surveyImportInclinationColumn_" Min="1" Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudSelect T="string" Label="Incl unit" @bind-Value="selectedSurveyImportInclinationUnit_" ShrinkLabel>
                        @foreach (string unit in AvailableSurveyImportAngleUnits)
                        {
                            <MudSelectItem T="string" Value="@unit">@unit</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudNumericField T="int" Label="Az column" @bind-Value="surveyImportAzimuthColumn_" Min="1" Immediate="true" />
                </MudItem>
                <MudItem xs="12" md="2">
                    <MudSelect T="string" Label="Az unit" @bind-Value="selectedSurveyImportAzimuthUnit_" ShrinkLabel>
                        @foreach (string unit in AvailableSurveyImportAngleUnits)
                        {
                            <MudSelectItem T="string" Value="@unit">@unit</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                @if (IsFixedWidthImportFormat)
                {
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int" Label="MD start" @bind-Value="surveyImportMDStart_" Min="1" Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int" Label="MD width" @bind-Value="surveyImportMDWidth_" Min="1" Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int" Label="Incl start" @bind-Value="surveyImportInclinationStart_" Min="1" Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int" Label="Incl width" @bind-Value="surveyImportInclinationWidth_" Min="1" Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int" Label="Az start" @bind-Value="surveyImportAzimuthStart_" Min="1" Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int" Label="Az width" @bind-Value="surveyImportAzimuthWidth_" Min="1" Immediate="true" />
                    </MudItem>
                }
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudText Typo="Typo.h6">Batch options</MudText>
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="Common depth reference" @bind-Value="commonDepthReference_" ShrinkLabel>
                        @foreach (string depthReference in DepthReferenceChoices)
                        {
                            <MudSelectItem T="string" Value="@depthReference">@depthReference</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4" Class="d-flex align-center">
                    <MudButton OnClick="ApplyCommonDepthReferenceToAllRows" Color="Color.Primary" Variant="Variant.Outlined">Apply depth reference to all rows</MudButton>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSwitch @bind-Value="replaceExistingTrajectories_" Color="Color.Secondary">
                        Replace existing trajectories in each selected wellbore
                    </MudSwitch>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSwitch @bind-Value="replaceTrajectoriesWithSameName_" Color="Color.Secondary" Disabled="@replaceExistingTrajectories_">
                        Replace existing trajectory with the same name in the selected wellbore
                    </MudSwitch>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudToolBar Class="px-0">
            <MudText Typo="Typo.h6">Association table</MudText>
            <MudSpacer />
            <MudButton OnClick="AddRow" Color="Color.Success" Variant="Variant.Filled">Add row</MudButton>
            <MudButton OnClick="ExportAssociationTableAsync" Color="Color.Primary" Variant="Variant.Outlined" Class="ms-2">Export batch description</MudButton>
        </MudToolBar>

        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudText Typo="Typo.caption">Import a batch description file to restore the table, filters, per-row depth references, upload mode, format settings, and selected trajectory files.</MudText>
            <div class="mt-2">
                <InputFile OnChange="ImportAssociationTableAsync" accept=".json,application/json" />
            </div>
        </MudPaper>

        <MudTable Items="@rows_" T="TrajectoryImportRowState" Hover="true" Dense="true" Bordered="true" Elevation="1">
            <HeaderContent>
                <MudTh>Wellbore</MudTh>
                <MudTh>Survey instrument</MudTh>
                <MudTh>Parent survey run</MudTh>
                <MudTh>Depth reference</MudTh>
                <MudTh>File name</MudTh>
                <MudTh>File</MudTh>
                <MudTh>Status</MudTh>
                <MudTh />
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Wellbore">
                    <MudSelect T="Guid?" Value="@context.WellBoreId" ValueChanged="@(value => OnRowWellBoreChanged(context, value))" ShrinkLabel Dense="true">
                        @foreach (WellBore option in GetRowWellBoreOptions(context))
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)option.MetaInfo.ID)">@option.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Survey instrument">
                    <MudSelect T="Guid?" Value="@context.SurveyInstrumentId" ValueChanged="@(value => OnRowSurveyInstrumentChanged(context, value))" ShrinkLabel Dense="true">
                        @foreach (SurveyInstrumentLight option in AvailableSurveyInstruments)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)option.MetaInfo.ID)">@option.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Parent survey run">
                    <MudSelect T="Guid?" Value="@context.ParentSurveyRunId" ValueChanged="@(value => OnRowParentSurveyRunChanged(context, value))" ShrinkLabel Dense="true" Clearable="true" Disabled="@(!IsRowParentSurveyRunRequired(context))">
                        @foreach (SurveyRun option in GetRowParentSurveyRunOptions(context))
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)option.MetaInfo.ID)">@option.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Depth reference">
                    <MudSelect T="string" Value="@context.DepthReferenceName" ValueChanged="@(value => OnRowDepthReferenceChanged(context, value))" ShrinkLabel Dense="true">
                        @foreach (string depthReference in DepthReferenceChoices)
                        {
                            <MudSelectItem T="string" Value="@depthReference">@depthReference</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="File name">
                    <MudText>@(string.IsNullOrWhiteSpace(context.FileName) ? "No file selected" : context.FileName)</MudText>
                </MudTd>
                <MudTd DataLabel="File">
                    <div @key="context.RowId">
                        <InputFile OnChange="@(args => OnTrajectoryFileChangedAsync(context, args))" />
                    </div>
                </MudTd>
                <MudTd DataLabel="Status">
                    <MudText Color="@GetStatusColor(context.Status)">@context.Status</MudText>
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudButton OnClick="@(() => ClearRowFile(context))" Color="Color.Warning" Variant="Variant.Text">Clear file</MudButton>
                    <MudButton OnClick="@(() => RemoveRow(context))" Color="Color.Error" Variant="Variant.Text">Remove</MudButton>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No rows available</MudText>
            </NoRecordsContent>
        </MudTable>
    </div>
}

@code {
    [CascadingParameter]
    private MudUnitAndReferenceChoiceTag? Parent { get; set; }

    private readonly List<TrajectoryImportRowState> rows_ = [];
    private List<Field>? fieldList_;
    private List<Cluster>? clusterList_;
    private List<Well>? wellList_;
    private List<WellBore>? wellBoreList_;
    private List<Rig>? rigList_;
    private List<SurveyInstrumentLight>? surveyInstrumentList_;
    private List<SurveyRun>? allSurveyRunHeavyList_;

    private List<SharedSurveyRunBatchImportLight> allBatchImportList_ = [];
    private List<SharedSurveyRunBatchImportLight> batchImportList_ = [];
    private List<SharedSurveyRunBatchImportLight> selectedBatchImportList_ = [];
    private SharedSurveyRunBatchImport currentBatchImport_ = CreateEmptyBatchImport();

    private bool isLoading_ = true;
    private bool isUploading_;
    private bool isHiddenMainPanel_;
    private bool isHiddenEditPanel_ = true;
    private string? _searchString;
    private int _gridKey = 0;

    private Guid? selectedFieldId_;
    private Guid? selectedClusterId_;
    private Guid? selectedWellId_;
    private string commonDepthReference_ = "Rotary table";
    private bool replaceExistingTrajectories_;
    private bool replaceTrajectoriesWithSameName_;
    private const int SurveyMeasurementChunkSize = 5000;

    private string selectedSurveyImportFormat_ = "Separated";
    private static readonly string[] SurveyImportFormats = ["Separated", "Fixed width"];
    private string selectedSurveyImportSeparator_ = "Semicolon (;)";
    private static readonly string[] SurveyImportSeparators = ["Semicolon (;)", "Tab", "Space"];
    private string selectedSurveyImportDecimalMarker_ = "Auto";
    private static readonly string[] SurveyImportDecimalMarkers = ["Auto", "Dot (.)", "Comma (,)"];
    private string selectedSurveyImportMDUnit_ = DepthDrillingQuantity.Instance.GetUnitChoice(DepthDrillingQuantity.UnitChoicesEnum.Metre).UnitName;
    private string selectedSurveyImportInclinationUnit_ = PlaneAngleDrillingQuantity.Instance.GetUnitChoice(PlaneAngleDrillingQuantity.UnitChoicesEnum.Degree).UnitName;
    private string selectedSurveyImportAzimuthUnit_ = PlaneAngleDrillingQuantity.Instance.GetUnitChoice(PlaneAngleDrillingQuantity.UnitChoicesEnum.Degree).UnitName;
    private int surveyImportMDColumn_ = 1;
    private int surveyImportInclinationColumn_ = 2;
    private int surveyImportAzimuthColumn_ = 3;
    private int surveyImportMDStart_ = 1;
    private int surveyImportMDWidth_ = 12;
    private int surveyImportInclinationStart_ = 13;
    private int surveyImportInclinationWidth_ = 12;
    private int surveyImportAzimuthStart_ = 25;
    private int surveyImportAzimuthWidth_ = 12;

    private bool IsDelimitedImportFormat => selectedSurveyImportFormat_ == "Separated";
    private bool IsFixedWidthImportFormat => selectedSurveyImportFormat_ == "Fixed width";
    private static readonly string[] DepthReferenceChoices = ["Rotary table", "Ground/Mud line", "Sea water level"];
    private static readonly JsonSerializerOptions BatchImportJsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        WriteIndented = true
    };

    private Func<SharedSurveyRunBatchImportLight, bool> _batchImportFilter => item =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
        {
            return true;
        }

        return $"{item.Name} {item.Description}".Contains(_searchString, StringComparison.OrdinalIgnoreCase);
    };

    private List<Field> AvailableFields =>
        fieldList_?
            .Where(field => field?.MetaInfo != null)
            .OrderBy(field => field.Name)
            .ToList() ?? [];

    private List<Cluster> AvailableClusters =>
        clusterList_?
            .Where(cluster =>
                cluster?.MetaInfo != null &&
                !cluster.IsSingleWell &&
                (selectedFieldId_ == null || cluster.FieldID == selectedFieldId_))
            .OrderBy(cluster => cluster.Name)
            .ToList() ?? [];

    private List<Well> AvailableWells =>
        wellList_?
            .Where(well =>
                well?.MetaInfo != null &&
                (selectedFieldId_ == null || MatchesSelectedField(well)) &&
                (selectedClusterId_ == null || well.IsSingleWell || well.ClusterID == selectedClusterId_))
            .OrderBy(well => well.Name)
            .ToList() ?? [];

    private List<WellBore> AvailableWellBores =>
        wellBoreList_?
            .Where(wellBore =>
                wellBore?.MetaInfo != null &&
                (selectedWellId_ == null || wellBore.WellID == selectedWellId_))
            .OrderBy(wellBore => wellBore.Name)
            .ToList() ?? [];

    private List<SurveyInstrumentLight> AvailableSurveyInstruments =>
        surveyInstrumentList_?
            .Where(instrument => instrument?.MetaInfo != null)
            .OrderBy(instrument => instrument.Name)
            .ToList() ?? [];

    private List<string> AvailableSurveyImportDepthUnits =>
        GetAvailableSurveyImportUnits(DepthDrillingQuantity.UnitChoiceDescriptions);

    private List<string> AvailableSurveyImportAngleUnits =>
        GetAvailableSurveyImportUnits(PlaneAngleDrillingQuantity.UnitChoiceDescriptions);

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            isLoading_ = true;
            isHiddenMainPanel_ = false;
            isHiddenEditPanel_ = true;
            selectedBatchImportList_ = [];
            currentBatchImport_ = CreateEmptyBatchImport();

            Task<System.Collections.Generic.ICollection<Field>> fieldTask = Api.ClientField.GetAllFieldAsync();
            Task<System.Collections.Generic.ICollection<Cluster>> clusterTask = Api.ClientCluster.GetAllClusterAsync();
            Task<System.Collections.Generic.ICollection<Well>> wellTask = Api.ClientWell.GetAllWellAsync();
            Task<System.Collections.Generic.ICollection<WellBore>> wellBoreTask = Api.ClientWellBore.GetAllWellBoreAsync();
            Task<System.Collections.Generic.ICollection<Rig>> rigTask = Api.ClientRig.GetAllRigAsync();
            Task<System.Collections.Generic.ICollection<SurveyInstrumentLight>> surveyInstrumentTask = Api.ClientSurveyInstrument.GetAllSurveyInstrumentLightAsync();
            Task<System.Collections.Generic.ICollection<SurveyRun>> surveyRunHeavyTask = Api.ClientTrajectory.GetAllSurveyRunAsync();
            Task<List<SharedSurveyRunBatchImportLight>?> batchImportTask = GetStoredBatchImportsLightAsync();

            await Task.WhenAll(fieldTask, clusterTask, wellTask, wellBoreTask, rigTask, surveyInstrumentTask, surveyRunHeavyTask, batchImportTask);

            fieldList_ = fieldTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            clusterList_ = clusterTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            wellList_ = wellTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            wellBoreList_ = wellBoreTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            rigList_ = rigTask.Result.Where(item => item != null).ToList();
            surveyInstrumentList_ = surveyInstrumentTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            allSurveyRunHeavyList_ = surveyRunHeavyTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();

            allBatchImportList_ = batchImportTask.Result?.OrderBy(item => item.Name).ToList() ?? [];
            batchImportList_ = allBatchImportList_.ToList();
            EnsureSurveyImportUnitsSelected();
            EnsureAtLeastOneRow();
            _gridKey++;
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem batch trajectory import initialization");
            Snackbar.Add("Problem on survey run batch import initialization.", Severity.Error);
        }
        finally
        {
            isLoading_ = false;
        }
    }

    private static SharedSurveyRunBatchImport CreateEmptyBatchImport()
    {
        DateTimeOffset now = DateTimeOffset.UtcNow;
        return new SharedSurveyRunBatchImport
        {
            MetaInfo = new SharedMetaInfo(),
            Name = string.Empty,
            Description = string.Empty,
            CreationDate = now,
            LastModificationDate = now,
            CommonDepthReference = "Rotary table",
            Settings = new SharedSurveyImportSettings(),
            Rows = []
        };
    }

    private async Task<List<SharedSurveyRunBatchImportLight>?> GetStoredBatchImportsLightAsync()
    {
        return (await Api.ClientTrajectory.GetAllSurveyRunBatchImportLightAsync()).ToList();
    }

    private async Task<SharedSurveyRunBatchImport?> GetStoredBatchImportByIdAsync(Guid id)
    {
        return await Api.ClientTrajectory.GetSurveyRunBatchImportByIdAsync(id);
    }

    private async Task<bool> PostStoredBatchImportAsync(SharedSurveyRunBatchImport batchImport)
    {
        await Api.ClientTrajectory.PostSurveyRunBatchImportAsync(batchImport);
        return true;
    }

    private async Task<bool> PutStoredBatchImportAsync(Guid id, SharedSurveyRunBatchImport batchImport)
    {
        await Api.ClientTrajectory.PutSurveyRunBatchImportByIdAsync(id, batchImport);
        return true;
    }

    private async Task<bool> DeleteStoredBatchImportAsync(Guid id)
    {
        await Api.ClientTrajectory.DeleteSurveyRunBatchImportByIdAsync(id);
        return true;
    }

    private async Task AddBatchImport()
    {
        ResetEditorState();
        isHiddenMainPanel_ = true;
        isHiddenEditPanel_ = false;
        await Task.Delay(1);
    }

    private async Task EditBatchImport(Guid id)
    {
        try
        {
            SharedSurveyRunBatchImport? batchImport = await GetStoredBatchImportByIdAsync(id);
            if (batchImport == null)
            {
                Snackbar.Add("Batch import not found.", Severity.Warning);
                return;
            }

            ApplyStoredBatchImport(batchImport);
            isHiddenMainPanel_ = true;
            isHiddenEditPanel_ = false;
            await Task.Delay(1);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to load saved batch import");
            Snackbar.Add("Failed to load saved batch import.", Severity.Error);
        }
    }

    private async Task HandleEditPanelClosed()
    {
        isHiddenMainPanel_ = false;
        isHiddenEditPanel_ = true;
        await LoadDataAsync();
    }

    private async Task SaveBatchImportAsync()
    {
        if (string.IsNullOrWhiteSpace(currentBatchImport_.Name))
        {
            Snackbar.Add("A batch import name is required.", Severity.Warning);
            return;
        }

        try
        {
            SharedSurveyRunBatchImport snapshot = BuildStoredBatchImportSnapshot();
            bool success;

            if (snapshot.MetaInfo?.ID is Guid id && id != Guid.Empty && allBatchImportList_.Any(item => item.MetaInfo?.ID == id))
            {
                success = await PutStoredBatchImportAsync(id, snapshot);
            }
            else
            {
                if (snapshot.MetaInfo == null)
                {
                    snapshot.MetaInfo = new SharedMetaInfo();
                }
                snapshot.MetaInfo.ID = Guid.NewGuid();
                snapshot.CreationDate = DateTimeOffset.UtcNow;
                snapshot.LastModificationDate = snapshot.CreationDate;
                success = await PostStoredBatchImportAsync(snapshot);
            }

            if (success)
            {
                Snackbar.Add("Batch import saved successfully", Severity.Success);
                await HandleEditPanelClosed();
            }
            else
            {
                Snackbar.Add("Failed to save batch import.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while saving survey run batch import");
            Snackbar.Add("Error saving batch import: " + ex.Message, Severity.Warning);
        }
    }

