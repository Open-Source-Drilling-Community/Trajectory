    private static bool IsValidReferenceInterval(MinimumDistanceReferenceInterval interval) =>
        interval.StartMD is double start &&
        interval.EndMD is double end &&
        !double.IsNaN(start) &&
        !double.IsNaN(end) &&
        !double.IsInfinity(start) &&
        !double.IsInfinity(end) &&
        end > start;

    private SurveyRunMinimumDistanceIntervalResult? GetIntervalResult(Guid intervalId, Guid surveyRunId) =>
        currentCalculation_?.IntervalResultList?
            .FirstOrDefault(result => result.IntervalID == intervalId && result.ComparisonSurveyRunID == surveyRunId);

    private string GetIntervalLabel(MinimumDistanceReferenceInterval interval)
    {
        string name = string.IsNullOrWhiteSpace(interval.Name) ? "Interval" : interval.Name!;
        return $"{name} [{FormatDepth(interval.StartMD)} - {FormatDepth(interval.EndMD)}]";
    }

    private string FormatIntervalResult(SurveyRunMinimumDistanceIntervalResult? result)
    {
        if (result == null || result.SampleCount == 0)
        {
            return "-";
        }

        double? average = selectedDistanceMode_ == CenterDistanceMode
            ? result.AverageCenterToCenterDistance
            : result.AverageClearanceDistance;
        double? standardDeviation = selectedDistanceMode_ == CenterDistanceMode
            ? result.StandardDeviationCenterToCenterDistance
            : result.StandardDeviationClearanceDistance;
        return $"{FormatPosition(average)} +/- {FormatPosition(standardDeviation)} ({result.SampleCount})";
    }

    private string FormatDepth(double? value)
    {
        if (value == null)
        {
            return "-";
        }

        double converted = Parent?.FromSI(value.Value, "DepthDrilling") ?? value.Value;
        return converted.ToString("0.###");
    }

    private string FormatPosition(double? value)
    {
        if (value == null)
        {
            return "-";
        }

        double converted = Parent?.FromSI(value.Value, "PositionDrilling") ?? value.Value;
        return converted.ToString("0.###");
    }

    private async Task<bool> ConfirmDeletion()
    {
        var dialog = await DialogService.ShowAsync<DialogDeleteTemplate>("DELETE", new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        return result != null && !result.Canceled;
    }

    private async Task DeleteCalculation(Guid id)
    {
        try
        {
            if (await ConfirmDeletion())
            {
                await Api.ClientTrajectory.DeleteSurveyRunMinimumDistanceCalculationByIdAsync(id);
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete survey run minimum distance calculation");
            Snackbar.Add("Failed to delete minimum distance calculation.", Severity.Error);
        }
    }

    private async Task DeleteSelectedCalculations()
    {
        List<SurveyRunMinimumDistanceCalculationLight> toDelete = selectedCalculationLightList_.ToList();
        if (toDelete.Count == 0)
        {
            return;
        }

        try
        {
            if (await ConfirmDeletion())
            {
                foreach (SurveyRunMinimumDistanceCalculationLight item in toDelete)
                {
                    await Api.ClientTrajectory.DeleteSurveyRunMinimumDistanceCalculationByIdAsync(item.MetaInfo.ID);
                }

                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete survey run minimum distance calculations");
            Snackbar.Add("Failed to delete one or more minimum distance calculations.", Severity.Error);
        }
    }

    private void ApplySurveyRunReferenceValues()
    {
        DataUtils.ApplySurveyRunReferenceValues(selectedReferenceSurveyRunId_, SurveyRunLightList_, wellBoreList_, wellList_, clusterList_, rigList_);
    }

    private bool MatchesSelectedField(Well well)
    {
        if (selectedFieldId_ == null)
        {
            return true;
        }

        if (well.IsSingleWell)
        {
            return well.ClusterID == selectedFieldId_;
        }

        return well.ClusterID is Guid clusterId && FindClusterById(clusterId)?.FieldID == selectedFieldId_;
    }

    private bool MatchesSelectedField(SurveyRunLight surveyRun)
    {
        if (selectedFieldId_ == null)
        {
            return true;
        }

        return surveyRun.FieldID == selectedFieldId_ ||
            (surveyRun.WellID is Guid wellId && FindWellById(wellId) is Well well && MatchesSelectedField(well));
    }

    private bool MatchesSelectedCluster(SurveyRunLight surveyRun)
    {
        if (selectedClusterId_ == null)
        {
            return true;
        }

        return surveyRun.ClusterID == selectedClusterId_ ||
            (surveyRun.WellID is Guid wellId && FindWellById(wellId)?.ClusterID == selectedClusterId_);
    }

    private bool MatchesComparisonHierarchy(SurveyRunLight surveyRun)
    {
        return (comparisonFieldId_ == null || MatchesComparisonField(surveyRun)) &&
            (comparisonClusterId_ == null || MatchesComparisonCluster(surveyRun)) &&
            (comparisonWellId_ == null || surveyRun.WellID == comparisonWellId_) &&
            (comparisonWellBoreId_ == null || surveyRun.WellBoreID == comparisonWellBoreId_);
    }

    private bool MatchesComparisonField(Well well)
    {
        if (comparisonFieldId_ == null)
        {
            return true;
        }

        if (well.IsSingleWell)
        {
            return well.ClusterID == comparisonFieldId_;
        }

        return well.ClusterID is Guid clusterId && FindClusterById(clusterId)?.FieldID == comparisonFieldId_;
    }

    private bool MatchesComparisonField(SurveyRunLight surveyRun)
    {
        if (comparisonFieldId_ == null)
        {
            return true;
        }

        return surveyRun.FieldID == comparisonFieldId_ ||
            (surveyRun.WellID is Guid wellId && FindWellById(wellId) is Well well && MatchesComparisonField(well));
    }

    private bool MatchesComparisonCluster(SurveyRunLight surveyRun)
    {
        if (comparisonClusterId_ == null)
        {
            return true;
        }

        return surveyRun.ClusterID == comparisonClusterId_ ||
            (surveyRun.WellID is Guid wellId && FindWellById(wellId)?.ClusterID == comparisonClusterId_);
    }

    private Guid? FindFieldIdForWell(Well? well)
    {
        if (well == null)
        {
            return null;
        }

        if (well.IsSingleWell)
        {
            return well.ClusterID;
        }

        return well.ClusterID is Guid clusterId ? FindClusterById(clusterId)?.FieldID : null;
    }

    private Well? FindWellById(Guid id) => wellList_?.FirstOrDefault(well => well?.MetaInfo?.ID == id);

    private WellBore? FindWellBoreById(Guid id) => wellBoreList_?.FirstOrDefault(wellBore => wellBore?.MetaInfo?.ID == id);

    private Cluster? FindClusterById(Guid id) => clusterList_?.FirstOrDefault(cluster => cluster?.MetaInfo?.ID == id);
