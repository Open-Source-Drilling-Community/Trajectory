    private List<Well> AvailableComparisonWells =>
        wellList_?
            .Where(well =>
                well?.MetaInfo != null &&
                (comparisonFieldId_ == null || MatchesComparisonField(well)) &&
                (comparisonClusterId_ == null || well.IsSingleWell || well.ClusterID == comparisonClusterId_))
            .OrderBy(well => well.Name)
            .ToList() ?? [];
    private List<WellBore> AvailableComparisonWellBores =>
        wellBoreList_?
            .Where(wellBore =>
                wellBore?.MetaInfo != null &&
