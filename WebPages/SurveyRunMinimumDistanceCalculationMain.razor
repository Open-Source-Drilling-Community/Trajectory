    }

    private void StartResultLoading()
    {
        if (currentCalculation_?.MetaInfo?.ID is not Guid id || id == Guid.Empty || resultLoadComplete_ || isLoadingResults_ || IsCalculationActive(currentCalculation_))
        {
            return;
        }

        _ = LoadResultsAsync(id);
    }

    private async Task LoadResultsAsync(Guid id)
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        isLoadingResults_ = true;
        resultLoadComplete_ = false;
        resultChunkCount_ = 0;
        resultChunksLoaded_ = 0;
        resultsLoaded_ = 0;
        currentCalculation_.ResultList = [];
        await InvokeAsync(StateHasChanged);

        try
        {
            int chunkCount = await Api.ClientTrajectory.GetSurveyRunMinimumDistanceCalculationResultChunkCountAsync(id);
            resultChunkCount_ = chunkCount;
            await InvokeAsync(StateHasChanged);
            List<SurveyRunMinimumDistanceResult> results = [];
            for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
            {
                SurveyRunMinimumDistanceResultChunk chunk = await Api.ClientTrajectory.GetSurveyRunMinimumDistanceCalculationResultChunkAsync(id, chunkIndex);
                if (chunk.ResultList is { Count: > 0 })
                {
                    results.AddRange(chunk.ResultList);
                }

                resultChunksLoaded_ = chunkIndex + 1;
                resultsLoaded_ = results.Count;
                if (chunkIndex == 0 || resultChunksLoaded_ == chunkCount || resultChunksLoaded_ % 5 == 0)
                {
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(1);
                }
            }

            currentCalculation_.ResultList = results;
            SelectAllResultSurveyRuns();
            resultLoadComplete_ = true;
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem loading survey run minimum distance result chunks");
            Snackbar.Add("Failed to load result chunks.", Severity.Error);
        }
        finally
        {
            isLoadingResults_ = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ResetResultLoadingState()
    {
        isLoadingResults_ = false;
        resultLoadComplete_ = false;
        resultChunkCount_ = 0;
        resultChunksLoaded_ = 0;
        resultsLoaded_ = 0;
        displayedResultSurveyRunIds_.Clear();
    }

    private bool IsResultSurveyRunDisplayed(Guid surveyRunId) => displayedResultSurveyRunIds_.Contains(surveyRunId);

    private void SetResultSurveyRunDisplayed(Guid surveyRunId, bool selected)
    {
        if (selected)
        {
            displayedResultSurveyRunIds_.Add(surveyRunId);
        }
        else
        {
            displayedResultSurveyRunIds_.Remove(surveyRunId);
        }
    }

    private void SelectAllResultSurveyRuns()
    {
        displayedResultSurveyRunIds_.Clear();
        foreach (Guid surveyRunId in ResultComparisonSurveyRunIDs)
        {
            displayedResultSurveyRunIds_.Add(surveyRunId);
        }
    }

    private void ClearResultSurveyRunFilter() => displayedResultSurveyRunIds_.Clear();

    private bool IsComparisonSelected(Guid id) => currentCalculation_?.ComparisonSurveyRunIDList?.Contains(id) == true;

    private bool IsComparisonCandidateStaged(Guid id) => stagedComparisonSurveyRunIDs_.Contains(id);

    private void SetComparisonCandidateStaged(Guid id, bool selected)
    {
        if (selected)
        {
            stagedComparisonSurveyRunIDs_.Add(id);
        }
        else
        {
            stagedComparisonSurveyRunIDs_.Remove(id);
        }
    }

    private void SetAllAvailableComparisonCandidatesStaged(bool selected)
    {
        foreach (SurveyRunLight surveyRun in AvailableComparisonCandidates)
        {
            if (surveyRun.MetaInfo?.ID is not Guid id || id == Guid.Empty)
            {
                continue;
            }

            if (selected)
            {
                stagedComparisonSurveyRunIDs_.Add(id);
            }
            else
            {
                stagedComparisonSurveyRunIDs_.Remove(id);
            }
        }
    }

    private void AddStagedComparisonSurveyRuns()
    {
        AddComparisonSurveyRuns(stagedComparisonSurveyRunIDs_);
        stagedComparisonSurveyRunIDs_.Clear();
    }

    private void AddComparisonSurveyRuns(IEnumerable<Guid> ids)
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        List<Guid> values = currentCalculation_.ComparisonSurveyRunIDList?.ToList() ?? [];
        foreach (Guid id in ids.Where(id => id != Guid.Empty && id != selectedReferenceSurveyRunId_))
        {
            if (!values.Contains(id))
            {
                values.Add(id);
            }
        }

        currentCalculation_.ComparisonSurveyRunIDList = values;
    }

    private void AddReferenceInterval()
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        currentCalculation_.ReferenceIntervalList ??= [];
        double? start = currentCalculation_.ReferenceIntervalList
            .Where(interval => interval.EndMD.HasValue)
            .Select(interval => interval.EndMD)
            .Max();
        currentCalculation_.ReferenceIntervalList.Add(new MinimumDistanceReferenceInterval
        {
            ID = Guid.NewGuid(),
            Name = $"Interval {currentCalculation_.ReferenceIntervalList.Count + 1}",
            StartMD = start,
            EndMD = start.HasValue ? start.Value + 100.0 : null
        });
    }

    private void RemoveReferenceInterval(MinimumDistanceReferenceInterval interval)
    {
        currentCalculation_?.ReferenceIntervalList?.Remove(interval);
    }

    private void RemoveComparisonSurveyRun(Guid id)
    {
        if (currentCalculation_?.ComparisonSurveyRunIDList == null)
        {
            return;
        }

        currentCalculation_.ComparisonSurveyRunIDList = currentCalculation_.ComparisonSurveyRunIDList.Where(value => value != id).ToList();
        stagedComparisonSurveyRunIDs_.Remove(id);
    }

    private void ClearComparisonSurveyRuns()
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        currentCalculation_.ComparisonSurveyRunIDList = [];
        stagedComparisonSurveyRunIDs_.Clear();
    }

    private bool MatchesComparisonSearch(SurveyRunLight surveyRun)
    {
        if (string.IsNullOrWhiteSpace(comparisonSearchString_))
        {
            return true;
        }

        return $"{surveyRun.Name} {surveyRun.Description}".Contains(comparisonSearchString_, StringComparison.OrdinalIgnoreCase);
    }

    private Func<SurveyRunMinimumDistanceCalculationLight, bool> Filter => x =>
        string.IsNullOrWhiteSpace(searchString_) ||
        $"{x.Name} {x.Description} {GetSurveyRunName(x.ReferenceSurveyRunID)}".Contains(searchString_, StringComparison.OrdinalIgnoreCase);

