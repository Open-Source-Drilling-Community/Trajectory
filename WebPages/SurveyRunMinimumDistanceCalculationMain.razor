@page "/SurveyRunMinimumDistanceCalculation"
@inject ILogger<SurveyRunMinimumDistanceCalculationMain> logger
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ITrajectoryAPIUtils Api
@using System.Text.Json

<MudUnitAndReferenceChoiceTag @ref="unitReferenceTag_"
                              HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="@DataUtils.UpdateDepthReferenceName"
                              GroundMudLineDepthReferenceSource="@DataUtils.GroundMudLineDepthReferenceSource"
                              SeaWaterLevelDepthReferenceSource="@DataUtils.SeaWaterLevelDepthReferenceSource"
                              RotaryTableDepthReferenceSource="@DataUtils.RotaryTableDepthReferenceSource"
                              PositionReferenceName="@DataUtils.UnitAndReferenceParameters.PositionReferenceName"
                              PositionReferenceNameChanged="@DataUtils.UpdatePositionReferenceName"
                              WellHeadPositionReferenceSource="@DataUtils.WellHeadPositionReferenceSource"
                              CartographicGridPositionReferenceSource="@DataUtils.CartographicGridPositionReferenceSource"
                              LeaseLinePositionReferenceSource="@DataUtils.LeaseLinePositionReferenceSource"
                              ClusterPositionReferenceSource="@DataUtils.ClusterPositionReferenceSource">
    @if (!isEditing_)
    {
        <MudDataGrid T="SurveyRunMinimumDistanceCalculationLight" @key="gridKey_"
                     MultiSelection="true" Items="@calculationLightList_" SelectedItemsChanged="@SelectedItemsChanged"
                     Hover="true" RowClick="@RowClicked"
                     SortMode="SortMode.Multiple" QuickFilter="@Filter" Filterable="false"
                     ReadOnly="true" ColumnResizeMode="ResizeMode.Column" Elevation="0">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Survey Run Minimum Distance</MudText>
                <MudButton OnClick="@AddCalculation" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
                <MudButton OnClick="@DeleteSelectedCalculations" Color="@Color.Error" Class="add-item-btn"
                           Disabled="@(selectedCalculationLightList_.Count == 0)">Delete</MudButton>
                <MudSpacer />
                <MudTextField @bind-Value="searchString_" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            </ToolBarContent>
            <Columns>
                <SelectColumn T="SurveyRunMinimumDistanceCalculationLight" />
                <PropertyColumn Property="x => x.Name" Title="Case" CellStyle="width: 25%;" Sortable="true" />
                <PropertyColumn Property="x => x.Description" Title="Description" CellStyle="width: 25%;" Sortable="true" />
                <PropertyColumn Property="x => GetSurveyRunName(x.ReferenceSurveyRunID)" Title="Reference Survey Run" Sortable="true" />
                <PropertyColumn Property="x => x.ResultCount" Title="Results" Sortable="true" />
                <TemplateColumn Title="Calculation" Sortable="true">
                    <CellTemplate>
                        @CalculationStatusContent(context.Item)
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn CellClass="d-flex justify-end">
                    <CellTemplate>
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete"
                                       OnClick="(() => DeleteCalculation(context.Item.MetaInfo.ID))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="SurveyRunMinimumDistanceCalculationLight" />
            </PagerContent>
        </MudDataGrid>
    }
    else if (currentCalculation_ != null)
    {
        <MudText Class="mt-4 mb-4" Typo="Typo.h6">Edit Minimum Distance Calculation</MudText>
        <MudContainer Class="d-flex flex-row mt-4 mb-4">
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveCalculation">Save</MudButton>
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="CloseEditor">Close</MudButton>
        </MudContainer>

        <MudGrid>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="currentCalculation_.Name" Label="Name" Required="true" ShrinkLabel /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="currentCalculation_.Description" Label="Description" ShrinkLabel /></MudItem>
            <MudItem xs="12" />
            <MudItem xs="12" md="3">
                <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId_" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                    @foreach (Field field in AvailableFields)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Cluster" T="Guid?" Value="@selectedClusterId_" ValueChanged="OnClusterChanged" ShrinkLabel Clearable="true">
                    @foreach (Cluster cluster in AvailableClusters)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">@cluster.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Well" T="Guid?" Value="@selectedWellId_" ValueChanged="OnWellChanged" ShrinkLabel Clearable="true">
                    @foreach (Well well in AvailableWells)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">@well.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="WellBore" T="Guid?" Value="@selectedWellBoreId_" ValueChanged="OnWellBoreChanged" ShrinkLabel Clearable="true">
                    @foreach (WellBore wellBore in AvailableWellBores)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)wellBore.MetaInfo.ID)">@wellBore.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Reference Survey Run" T="Guid?" Value="@selectedReferenceSurveyRunId_" ValueChanged="OnReferenceSurveyRunChanged" ShrinkLabel Clearable="true">
                    @foreach (SurveyRunLight surveyRun in AvailableReferenceSurveyRuns)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)surveyRun.MetaInfo.ID)">@surveyRun.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" />
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="currentCalculation_.AccountForBoreholeRadius" Label="Use borehole radius" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Displayed Distance" T="string" @bind-Value="selectedDistanceMode_" ShrinkLabel>
                    <MudSelectItem T="string" Value="@CenterDistanceMode">Center to center</MudSelectItem>
                    <MudSelectItem T="string" Value="@ClearanceDistanceMode">Clearance</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudSwitch T="bool" @bind-Value="advancedMode_" Color="Color.Primary" Label="Advanced" />
            </MudItem>
            @if (advancedMode_)
            {
                <MudItem xs="12" md="3">
                    <MudInputWithUnit QuantityLabel="Chord Distance" QuantityName="DepthDrilling"
                                      SIValueNullable="@currentCalculation_.MaximumChordArcDistance"
                                      SIValueNullableChanged="@OnMaximumChordDistanceChanged" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField T="int" @bind-Value="currentCalculation_.OctreeMaximumDepth" Label="Octree Depth" Min="1" Max="12" ShrinkLabel />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudNumericField T="int" @bind-Value="currentCalculation_.OctreeMaximumSegmentCountPerLeaf" Label="Segments per Leaf" Min="4" Max="256" ShrinkLabel />
                </MudItem>
                <MudItem xs="12" md="3" Class="d-flex align-center">
                    <MudCheckBox T="bool" Value="@AdaptiveRefinement.Enabled" ValueChanged="@OnAdaptiveRefinementEnabledChanged" Label="Adaptive polar refinement" />
                </MudItem>
                @if (AdaptiveRefinement.Enabled)
                {
                    <MudItem xs="12" md="3">
                        <MudInputWithUnit QuantityLabel="Polar Deviation" QuantityName="PositionDrilling"
                                          SIValueNullable="@AdaptiveRefinement.PolarDeviationTolerance"
                                          SIValueNullableChanged="@OnAdaptivePolarDeviationToleranceChanged" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudInputWithUnit QuantityLabel="Angular Deviation" QuantityName="PlaneAngleDrilling"
                                          SIValueNullable="@AdaptiveRefinement.PolarAngularTolerance"
                                          SIValueNullableChanged="@OnAdaptivePolarAngularToleranceChanged" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudInputWithUnit QuantityLabel="Minimum MD Step" QuantityName="DepthDrilling"
                                          SIValueNullable="@AdaptiveRefinement.MinimumMDStep"
                                          SIValueNullableChanged="@OnAdaptiveMinimumMDStepChanged" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int" Value="@AdaptiveRefinement.MaximumDepth" ValueChanged="@OnAdaptiveMaximumDepthChanged" Label="Maximum Refinement Depth" Min="1" Max="12" ShrinkLabel />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int" Value="@AdaptiveRefinement.MaximumExtraSamplesPerComparison" ValueChanged="@OnAdaptiveMaximumExtraSamplesChanged" Label="Max Extra Samples" Min="0" Max="100000" ShrinkLabel />
                    </MudItem>
                }
            }
        </MudGrid>

        <MudPaper Class="pa-4 mt-4" Outlined="true">
            <MudText Typo="Typo.subtitle1">Comparison Survey Runs</MudText>
            <MudGrid Class="mt-1">
                <MudItem xs="12" md="5">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Field" T="Guid?" Value="@comparisonFieldId_" ValueChanged="OnComparisonFieldChanged" ShrinkLabel Clearable="true">
                                @foreach (Field field in AvailableFields)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Cluster" T="Guid?" Value="@comparisonClusterId_" ValueChanged="OnComparisonClusterChanged" ShrinkLabel Clearable="true">
                                @foreach (Cluster cluster in AvailableComparisonClusters)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">@cluster.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="Well" T="Guid?" Value="@comparisonWellId_" ValueChanged="OnComparisonWellChanged" ShrinkLabel Clearable="true">
                                @foreach (Well well in AvailableComparisonWells)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">@well.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect Label="WellBore" T="Guid?" Value="@comparisonWellBoreId_" ValueChanged="OnComparisonWellBoreChanged" ShrinkLabel Clearable="true">
                                @foreach (WellBore wellBore in AvailableComparisonWellBores)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)wellBore.MetaInfo.ID)">@wellBore.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                    <MudTextField @bind-Value="comparisonSearchString_" Label="Filter available survey runs" ShrinkLabel Immediate="true"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                    <MudToolBar Dense="true" Class="px-0">
                        <MudText Typo="Typo.caption">@AvailableComparisonCandidates.Count survey run candidates</MudText>
                        <MudSpacer />
                        <MudButton OnClick="AddStagedComparisonSurveyRuns" Color="Color.Primary" Variant="Variant.Outlined"
                                   Disabled="@(!stagedComparisonSurveyRunIDs_.Any())">Add Selected</MudButton>
                    </MudToolBar>
                    <MudTable Items="@AvailableComparisonCandidates" T="SurveyRunLight" Dense="true" Hover="true"
                              Height="320px" FixedHeader="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>
                                <MudCheckBox T="bool" Value="@AreAllAvailableComparisonCandidatesStaged"
                                             ValueChanged="SetAllAvailableComparisonCandidatesStaged"
                                             Disabled="@(!AvailableComparisonCandidates.Any())" />
                            </MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Select">
                                <MudCheckBox T="bool" Value="@IsComparisonCandidateStaged(context.MetaInfo.ID)"
                                             ValueChanged="@((bool selected) => SetComparisonCandidateStaged(context.MetaInfo.ID, selected))" />
                            </MudTd>
                            <MudTd DataLabel="Name">@context.Name</MudTd>
                            <MudTd DataLabel="Description">@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudToolBar Dense="true" Class="px-0">
                        <MudText Typo="Typo.caption">@SelectedComparisonSurveyRuns.Count selected comparison survey runs</MudText>
                        <MudSpacer />
                        <MudButton OnClick="ClearComparisonSurveyRuns" Color="Color.Error" Variant="Variant.Text"
                                   Disabled="@(!SelectedComparisonSurveyRuns.Any())">Clear</MudButton>
                    </MudToolBar>
                    <MudTable Items="@SelectedComparisonSurveyRuns" T="SurveyRunLight" Dense="true" Hover="true"
                              Height="370px" FixedHeader="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Name">@context.Name</MudTd>
                            <MudTd DataLabel="Description">@context.Description</MudTd>
                            <MudTd DataLabel="Remove">
                                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete"
                                               OnClick="@(() => RemoveComparisonSurveyRun(context.MetaInfo.ID))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4 mt-4" Outlined="true">
            <MudToolBar Dense="true" Class="px-0">
                <MudText Typo="Typo.subtitle1">Reference MD Intervals</MudText>
                <MudSpacer />
                <MudButton OnClick="AddReferenceInterval" Color="Color.Success" Variant="Variant.Outlined">Add interval</MudButton>
            </MudToolBar>
            <MudTable Items="@ReferenceIntervals" T="MinimumDistanceReferenceInterval" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Start MD [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                    <MudTh>End MD [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudTextField @bind-Value="context.Name" ShrinkLabel />
                    </MudTd>
                    <MudTd DataLabel="Start MD">
                        <MudInputWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                          SIValueNullable="@context.StartMD"
                                          SIValueNullableChanged="@((double? value) => context.StartMD = value)" />
                    </MudTd>
                    <MudTd DataLabel="End MD">
                        <MudInputWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                          SIValueNullable="@context.EndMD"
                                          SIValueNullableChanged="@((double? value) => context.EndMD = value)" />
                    </MudTd>
                    <MudTd DataLabel="Remove">
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete"
                                       OnClick="@(() => RemoveReferenceInterval(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudExpansionPanels Class="mt-4" Style="overflow-y: auto; max-height: none;">
            <MudExpansionPanel Text="Results" ExpandedChanged="@OnResultsPanelExpandedChanged">
                @if (IsCalculationActive(currentCalculation_))
                {
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.body2">@currentCalculation_.CalculationMessage</MudText>
                        <MudProgressLinear Value="@(100.0 * currentCalculation_.CalculationProgress)" Color="Color.Info" Class="mt-2" />
                    </MudPaper>
                }
                else if (isLoadingResults_)
                {
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.body2">@ResultLoadingText</MudText>
                        <MudProgressLinear Value="@ResultLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                    </MudPaper>
                }
                else if (currentCalculation_.ResultList is { Count: > 0 } results)
                {
                    <MudText Typo="Typo.body2" Class="mb-2 d-flex align-center flex-nowrap" Style="gap: 16px; overflow: hidden;">
                        <span class="d-inline-flex align-center flex-shrink-0" style="gap: 4px;">
                            <span>Global minimum clearance:</span>
                            <span style="display: inline-flex; width: max-content;">
                                <MudSpanWithUnit QuantityName="LengthStandard" SIValue="@currentCalculation_.GlobalMinimumClearanceDistance" />
                            </span>
                        </span>
                        <span class="d-inline-flex align-center flex-shrink-0" style="gap: 4px;">
                            <span>at MD</span>
                            <span style="display: inline-flex; width: max-content;">
                                <MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@currentCalculation_.GlobalMinimumReferenceMD" />
                            </span>
                        </span>
                        <span class="text-truncate">
                            for @GetSurveyRunName(currentCalculation_.GlobalMinimumComparisonSurveyRunID ?? Guid.Empty)
                        </span>
                    </MudText>
                    @if (currentCalculation_.IntervalResultList is { Count: > 0 } && ValidReferenceIntervals.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Interval Summary (@SelectedDistanceLabel)</MudText>
                        <MudTable Items="@ValidReferenceIntervals" T="MinimumDistanceReferenceInterval" Dense="true" Hover="true" Elevation="1" Bordered="true" Class="mb-3">
                            <HeaderContent>
                                <MudTh>Interval</MudTh>
                                @foreach (Guid surveyRunId in ResultComparisonSurveyRunIDs)
                                {
                                    <MudTh>@GetSurveyRunName(surveyRunId)</MudTh>
                                }
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Interval">@GetIntervalLabel(context)</MudTd>
                                @foreach (Guid surveyRunId in ResultComparisonSurveyRunIDs)
                                {
                                    <MudTd>@FormatIntervalResult(GetIntervalResult(context.ID, surveyRunId))</MudTd>
                                }
                            </RowTemplate>
                        </MudTable>
                    }
                    <MudPaper Class="pa-3 mb-3" Outlined="true">
                        <MudToolBar Dense="true" Class="px-0">
                            <MudText Typo="Typo.caption">@FilteredResultList.Count/@results.Count result rows displayed</MudText>
                            <MudSpacer />
                            <MudSelect T="string" Label="Table mode" @bind-Value="resultTableMode_" Dense="true" ShrinkLabel Style="width: 230px;">
                                <MudSelectItem T="string" Value="@ResultTableBySurveyRunMode">By survey run</MudSelectItem>
                                <MudSelectItem T="string" Value="@ResultTableByReferenceMdMode">By reference MD</MudSelectItem>
                            </MudSelect>
                            <MudButton OnClick="SelectAllResultSurveyRuns" Color="Color.Primary" Variant="Variant.Text">All</MudButton>
                            <MudButton OnClick="ClearResultSurveyRunFilter" Color="Color.Primary" Variant="Variant.Text">None</MudButton>
                        </MudToolBar>
                        <MudGrid>
                            @foreach (Guid surveyRunId in ResultComparisonSurveyRunIDs)
                            {
                                <MudItem xs="12" sm="6" md="4" lg="3">
                                    <MudCheckBox T="bool" Value="@IsResultSurveyRunDisplayed(surveyRunId)"
                                                 ValueChanged="@((bool selected) => SetResultSurveyRunDisplayed(surveyRunId, selected))"
                                                 Label="@GetSurveyRunName(surveyRunId)" />
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>
                    <MudTable Items="@DisplayedResultList" T="SurveyRunMinimumDistanceResult" Height="360px" FixedHeader="true"
                              Virtualize="true" OverscanCount="3" ItemSize="38"
                              Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true" ReadOnly="true">
                        <HeaderContent>
                            <MudTHeadRow>
                                <MudTh>Reference MD [@ReferencedDepthUnitLabel]</MudTh>
                                <MudTh>Comparison</MudTh>
                                <MudTh>Comparison MD [@ReferencedDepthUnitLabel]</MudTh>
                                <MudTh>Center Distance [@PositionUnitLabel]</MudTh>
                                <MudTh>Clearance [@StandardLengthUnitLabel]</MudTh>
                                <MudTh>Toolface [@PlaneAngleUnitLabel]</MudTh>
                            </MudTHeadRow>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.ReferenceMD" /></MudTd>
                            <MudTd>@GetSurveyRunName(context.ComparisonSurveyRunID ?? Guid.Empty)</MudTd>
                            <MudTd><MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.ComparisonMD" /></MudTd>
                            <MudTd><MudSpanWithUnit QuantityName="PositionDrilling" SIValue="@context.CenterToCenterDistance" /></MudTd>
                            <MudTd><MudSpanWithUnit QuantityName="LengthStandard" SIValue="@context.ClearanceDistance" /></MudTd>
                            <MudTd><MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Toolface" /></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText>No results loaded</MudText>
                }
            </MudExpansionPanel>
            <MudExpansionPanel Text="Plots" ExpandedChanged="@OnResultsPanelExpandedChanged">
                @if (isLoadingResults_)
                {
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.body2">@ResultLoadingText</MudText>
                        <MudProgressLinear Value="@ResultLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                    </MudPaper>
                }
                else if (currentCalculation_.ResultList is { Count: > 0 })
                {
                    <MudGrid Justify="Justify.Center">
                        <MudItem xs="12" md="6">
                            <ScatterPlot NameList="@DistanceNameList" ModeFlagList="@DistanceModeFlagList" ColorList="@DistanceColorList"
                                         XValuesList="@DistanceValuesList" YValuesList="@ReferenceMdValuesList"
                                         PlotTitle="" XAxisTitle="@SelectedDistanceLabel" YAxisTitle="Reference MD"
                                         XUnit="PositionDrilling" YUnit="DepthDrilling"
                                         YAxisReversed="@true"
                                         YAxisUsesDepthReference="@true">
                            </ScatterPlot>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <ToolfacePolarPlot NameList="@DistanceNameList"
                                               ColorList="@DistanceColorList"
                                               RadiusValuesList="@DistanceValuesList"
                                               ToolfaceValuesList="@ToolfaceValuesList"
                                               RadiusUnit="PositionDrilling" />
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <MudText>No results loaded</MudText>
                }
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
</MudUnitAndReferenceChoiceTag>

@code {
    [CascadingParameter] private MudUnitAndReferenceChoiceTag? Parent { get; set; }

    private const string CenterDistanceMode = "Center";
    private const string ClearanceDistanceMode = "Clearance";
    private const string ResultTableBySurveyRunMode = "BySurveyRun";
    private const string ResultTableByReferenceMdMode = "ByReferenceMD";
    private static readonly string[] PlotColorPalette = ["#1769aa", "#c23b22", "#4f7d20", "#7b3f98", "#bf7f00", "#00838f", "#8d5a3b", "#455a64"];
    private List<SurveyRunMinimumDistanceCalculationLight> calculationLightList_ = [];
    private List<SurveyRunMinimumDistanceCalculationLight> selectedCalculationLightList_ = [];
    private List<SurveyRunLight> SurveyRunLightList_ = [];
    private MudUnitAndReferenceChoiceTag? unitReferenceTag_;
    private List<Field>? fieldList_;
    private List<WellBore>? wellBoreList_;
    private List<Well>? wellList_;
    private List<Cluster>? clusterList_;
    private List<Rig>? rigList_;
    private SurveyRunMinimumDistanceCalculation? currentCalculation_;
    private Guid? currentCalculationId_;
    private Guid? selectedFieldId_;
    private Guid? selectedClusterId_;
    private Guid? selectedWellId_;
    private Guid? selectedWellBoreId_;
    private Guid? selectedReferenceSurveyRunId_;
    private Guid? comparisonFieldId_;
    private Guid? comparisonClusterId_;
    private Guid? comparisonWellId_;
    private Guid? comparisonWellBoreId_;
    private string selectedDistanceMode_ = ClearanceDistanceMode;
    private string resultTableMode_ = ResultTableBySurveyRunMode;
    private string? searchString_;
    private string? comparisonSearchString_;
    private readonly HashSet<Guid> stagedComparisonSurveyRunIDs_ = [];
    private readonly HashSet<Guid> displayedResultSurveyRunIds_ = [];
    private string? cleanCalculationSnapshot_;
    private bool advancedMode_;
    private bool isEditing_;
    private bool isLoadingResults_;
    private bool resultLoadComplete_;
    private bool hasRenderedUnitReference_;
    private int resultChunkCount_;
    private int resultChunksLoaded_;
    private int resultsLoaded_;
    private int gridKey_;
    private CancellationTokenSource? pollingCancellation_;
    private static readonly JsonSerializerOptions DirtySnapshotJsonOptions = new() { WriteIndented = false };

    private List<Field> AvailableFields =>
        fieldList_?
            .Where(field => field?.MetaInfo != null)
            .OrderBy(field => field.Name)
            .ToList() ?? [];

    private List<Cluster> AvailableClusters =>
        clusterList_?
            .Where(cluster =>
                cluster?.MetaInfo != null &&
                !cluster.IsSingleWell &&
                (selectedFieldId_ == null || cluster.FieldID == selectedFieldId_))
            .OrderBy(cluster => cluster.Name)
            .ToList() ?? [];

    private List<Well> AvailableWells =>
        wellList_?
            .Where(well =>
                well?.MetaInfo != null &&
                (selectedFieldId_ == null || MatchesSelectedField(well)) &&
                (selectedClusterId_ == null || well.IsSingleWell || well.ClusterID == selectedClusterId_))
            .OrderBy(well => well.Name)
            .ToList() ?? [];

    private List<WellBore> AvailableWellBores =>
        wellBoreList_?
            .Where(wellBore =>
                wellBore?.MetaInfo != null &&
                (selectedWellId_ == null || wellBore.WellID == selectedWellId_))
            .OrderBy(wellBore => wellBore.Name)
            .ToList() ?? [];

    private List<SurveyRunLight> AvailableReferenceSurveyRuns =>
        SurveyRunLightList_
            .Where(surveyRun =>
                surveyRun?.MetaInfo != null &&
                (selectedFieldId_ == null || MatchesSelectedField(surveyRun)) &&
                (selectedClusterId_ == null || MatchesSelectedCluster(surveyRun)) &&
                (selectedWellId_ == null || surveyRun.WellID == selectedWellId_) &&
                (selectedWellBoreId_ == null || surveyRun.WellBoreID == selectedWellBoreId_))
            .OrderBy(surveyRun => surveyRun.Name)
            .ToList();

    private List<SurveyRunLight> AvailableComparisonCandidates =>
