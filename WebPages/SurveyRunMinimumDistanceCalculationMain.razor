            .ToList() ?? [];
    private List<SurveyRunMinimumDistanceResult> FilteredResultList =>
        currentCalculation_?.ResultList?
            .Where(result => result.ComparisonSurveyRunID is Guid id && displayedResultSurveyRunIds_.Contains(id))
            .ToList() ?? [];
    private List<SurveyRunMinimumDistanceResult> DisplayedResultList =>
        resultTableMode_ == ResultTableByReferenceMdMode
            ? FilteredResultList
                .OrderBy(result => result.ReferenceMD ?? double.MaxValue)
                .ThenBy(result => GetSurveyRunName(result.ComparisonSurveyRunID ?? Guid.Empty))
                .ThenBy(result => result.ComparisonMD ?? double.MaxValue)
                .ToList()
            : FilteredResultList
                .OrderBy(result => GetSurveyRunName(result.ComparisonSurveyRunID ?? Guid.Empty))
                .ThenBy(result => result.ReferenceMD ?? double.MaxValue)
                .ThenBy(result => result.ComparisonMD ?? double.MaxValue)
                .ToList();
