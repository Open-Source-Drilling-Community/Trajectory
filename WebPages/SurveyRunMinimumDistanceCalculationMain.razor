    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!hasRenderedUnitReference_ && unitReferenceTag_ != null)
        {
            hasRenderedUnitReference_ = true;
            return InvokeAsync(StateHasChanged);
        }

        return Task.CompletedTask;
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var calculationTask = Api.ClientTrajectory.GetAllSurveyRunMinimumDistanceCalculationLightAsync();
            var surveyRunTask = Api.ClientTrajectory.GetAllSurveyRunLightAsync();
            var fieldTask = Api.ClientField.GetAllFieldAsync();
            var wellBoreTask = Api.ClientWellBore.GetAllWellBoreAsync();
            var wellTask = Api.ClientWell.GetAllWellAsync();
            var clusterTask = Api.ClientCluster.GetAllClusterAsync();
            var rigTask = Api.ClientRig.GetAllRigAsync();

            await Task.WhenAll(calculationTask, surveyRunTask, fieldTask, wellBoreTask, wellTask, clusterTask, rigTask);

            calculationLightList_ = ((ICollection<SurveyRunMinimumDistanceCalculationLight>)await calculationTask).OrderBy(x => x.Name).ToList();
            SurveyRunLightList_ = ((ICollection<SurveyRunLight>)await surveyRunTask).OrderBy(x => x.Name).ToList();
            fieldList_ = ((ICollection<Field>)await fieldTask).OrderBy(x => x.Name).ToList();
            wellBoreList_ = ((ICollection<WellBore>)await wellBoreTask).OrderBy(x => x.Name).ToList();
            wellList_ = ((ICollection<Well>)await wellTask).OrderBy(x => x.Name).ToList();
            clusterList_ = ((ICollection<Cluster>)await clusterTask).OrderBy(x => x.Name).ToList();
            rigList_ = ((ICollection<Rig>)await rigTask).OrderBy(x => x.Name).ToList();
            StartCalculationPollingIfNeeded();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem loading survey run minimum distance calculations");
            Snackbar.Add("Failed to load minimum distance calculations.", Severity.Error);
        }

        gridKey_++;
        await InvokeAsync(StateHasChanged);
    }

    private RenderFragment CalculationStatusContent(SurveyRunMinimumDistanceCalculationLight calculation) => @<div style="min-width: 150px;">
        @if (IsCalculationActive(calculation))
        {
            <MudText Typo="Typo.caption">@calculation.CalculationState</MudText>
            <MudProgressLinear Value="@(100.0 * calculation.CalculationProgress)" Color="Color.Info" Size="Size.Small" />
        }
        else if (calculation.CalculationState == CalculationState.Failed)
        {
            <MudText Typo="Typo.caption" Color="Color.Error">@calculation.CalculationState</MudText>
        }
        else
        {
            <MudText Typo="Typo.caption">@calculation.CalculationState</MudText>
        }
    </div>;

    private void StartCalculationPollingIfNeeded()
    {
        if (calculationLightList_.Any(IsCalculationActive) || currentCalculation_ != null && IsCalculationActive(currentCalculation_))
        {
            if (pollingCancellation_ == null)
            {
                pollingCancellation_ = new CancellationTokenSource();
                _ = PollCalculationProgressAsync(pollingCancellation_.Token);
            }
        }
    }

    private async Task PollCalculationProgressAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
                calculationLightList_ = ((ICollection<SurveyRunMinimumDistanceCalculationLight>)await Api.ClientTrajectory.GetAllSurveyRunMinimumDistanceCalculationLightAsync()).OrderBy(x => x.Name).ToList();
                if (currentCalculation_?.MetaInfo?.ID is Guid id)
                {
                    currentCalculation_ = await Api.ClientTrajectory.GetSurveyRunMinimumDistanceCalculationByIdAsync(id);
                    currentCalculation_.ResultList ??= [];
                    if (currentCalculation_.CalculationState == CalculationState.Completed)
                    {
                        ResetResultLoadingState();
                    }
                }

                gridKey_++;
                await InvokeAsync(StateHasChanged);
                if (!calculationLightList_.Any(IsCalculationActive) && (currentCalculation_ == null || !IsCalculationActive(currentCalculation_)))
                {
                    break;
                }
            }
        }
        catch (TaskCanceledException)
        {
        }
        finally
        {
            pollingCancellation_?.Dispose();
            pollingCancellation_ = null;
        }
    }

    private async Task AddCalculation()
    {
        currentCalculationId_ = null;
        currentCalculation_ = CreateCalculation();
        currentCalculation_.ReferenceIntervalList ??= [];
        selectedFieldId_ = null;
        selectedClusterId_ = null;
        selectedWellId_ = null;
        selectedWellBoreId_ = null;
        selectedReferenceSurveyRunId_ = null;
        advancedMode_ = false;
        ResetResultLoadingState();
        MarkCalculationClean();
        isEditing_ = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task EditCalculation(Guid id)
    {
        currentCalculationId_ = id;
        currentCalculation_ = await Api.ClientTrajectory.GetSurveyRunMinimumDistanceCalculationByIdAsync(id);
        currentCalculation_.ResultList ??= [];
        currentCalculation_.ReferenceIntervalList ??= [];
        selectedReferenceSurveyRunId_ = currentCalculation_.ReferenceSurveyRunID == Guid.Empty ? null : currentCalculation_.ReferenceSurveyRunID;
        SyncSelectorsFromSurveyRun(selectedReferenceSurveyRunId_);
        advancedMode_ = false;
        ResetResultLoadingState();
        ApplySurveyRunReferenceValues();
        MarkCalculationClean();
        isEditing_ = true;
        StartCalculationPollingIfNeeded();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveCalculation()
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        if (selectedReferenceSurveyRunId_ is not Guid referenceId || referenceId == Guid.Empty)
        {
            Snackbar.Add("Choose a reference survey run.", Severity.Warning);
            return;
        }

        if (currentCalculation_.ComparisonSurveyRunIDList is not { Count: > 0 })
        {
            Snackbar.Add("Choose at least one comparison survey run.", Severity.Warning);
            return;
        }

        try
        {
            currentCalculation_.MetaInfo ??= PseudoConstructors.ConstructMetaInfo();
            currentCalculation_.ReferenceSurveyRunID = referenceId;
            currentCalculation_.LastModificationDate = DateTimeOffset.UtcNow;
            currentCalculation_.ResultList = null;
            currentCalculation_.IntervalResultList = null;
            if (currentCalculationId_ is Guid id)
            {
                await Api.ClientTrajectory.PutSurveyRunMinimumDistanceCalculationByIdAsync(id, currentCalculation_);
                currentCalculation_ = await Api.ClientTrajectory.GetSurveyRunMinimumDistanceCalculationByIdAsync(id);
                Snackbar.Add("Minimum distance calculation updated", Severity.Success);
            }
            else
            {
                currentCalculation_.MetaInfo.ID = currentCalculation_.MetaInfo.ID == Guid.Empty ? Guid.NewGuid() : currentCalculation_.MetaInfo.ID;
                currentCalculation_.CreationDate ??= DateTimeOffset.UtcNow;
                await Api.ClientTrajectory.PostSurveyRunMinimumDistanceCalculationAsync(currentCalculation_);
                currentCalculationId_ = currentCalculation_.MetaInfo.ID;
                currentCalculation_ = await Api.ClientTrajectory.GetSurveyRunMinimumDistanceCalculationByIdAsync(currentCalculationId_.Value);
                Snackbar.Add("Minimum distance calculation created", Severity.Success);
            }

            currentCalculation_.ResultList ??= [];
            selectedReferenceSurveyRunId_ = currentCalculation_.ReferenceSurveyRunID == Guid.Empty ? null : currentCalculation_.ReferenceSurveyRunID;
            ResetResultLoadingState();
            MarkCalculationClean();
            StartCalculationPollingIfNeeded();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error saving survey run minimum distance calculation");
            Snackbar.Add("Error saving minimum distance calculation: " + ex.Message, Severity.Warning);
        }
    }

    private async Task CloseEditor()
    {
        if (HasUnsavedCalculationChanges() && !await ConfirmCloseWithoutSavingAsync())
        {
            return;
        }

        isEditing_ = false;
        currentCalculation_ = null;
        currentCalculationId_ = null;
        cleanCalculationSnapshot_ = null;
        await LoadDataAsync();
    }

    private void MarkCalculationClean() => cleanCalculationSnapshot_ = BuildCalculationDirtySnapshot();

    private bool HasUnsavedCalculationChanges() =>
        cleanCalculationSnapshot_ != null &&
        !string.Equals(cleanCalculationSnapshot_, BuildCalculationDirtySnapshot(), StringComparison.Ordinal);

    private string BuildCalculationDirtySnapshot()
    {
        return JsonSerializer.Serialize(new
        {
            Id = currentCalculationId_,
            CalculationId = currentCalculation_?.MetaInfo?.ID,
            currentCalculation_?.Name,
            currentCalculation_?.Description,
            currentCalculation_?.CreationDate,
            SelectedReferenceSurveyRunId = selectedReferenceSurveyRunId_,
            ComparisonSurveyRunIds = currentCalculation_?.ComparisonSurveyRunIDList?.OrderBy(id => id).ToList(),
            ReferenceIntervals = currentCalculation_?.ReferenceIntervalList?
                .OrderBy(interval => interval.StartMD)
                .Select(interval => new { interval.StartMD, interval.EndMD })
                .ToList(),
            AdaptiveRefinement = currentCalculation_?.AdaptiveRefinementSettings == null ? null : new
            {
                currentCalculation_.AdaptiveRefinementSettings.Enabled,
                currentCalculation_.AdaptiveRefinementSettings.PolarDeviationTolerance,
                currentCalculation_.AdaptiveRefinementSettings.PolarAngularTolerance,
                currentCalculation_.AdaptiveRefinementSettings.MinimumMDStep,
                currentCalculation_.AdaptiveRefinementSettings.MaximumDepth,
                currentCalculation_.AdaptiveRefinementSettings.MaximumExtraSamplesPerComparison
            }
        }, DirtySnapshotJsonOptions);
    }

    private async Task<bool> ConfirmCloseWithoutSavingAsync()
    {
        bool? result = await DialogService.ShowMessageBox(
            "Unsaved changes",
            "Some changes have not been saved. Close without saving?",
            yesText: "Close without saving",
            cancelText: "Stay");

        return result == true;
    }

    private Task OnReferenceSurveyRunChanged(Guid? id)
    {
        selectedReferenceSurveyRunId_ = id;
        if (currentCalculation_ != null)
        {
            currentCalculation_.ReferenceSurveyRunID = id ?? Guid.Empty;
            currentCalculation_.ComparisonSurveyRunIDList = currentCalculation_.ComparisonSurveyRunIDList?.Where(x => x != id).ToList();
            stagedComparisonSurveyRunIDs_.Remove(id ?? Guid.Empty);
        }

        ApplySurveyRunReferenceValues();
        return Task.CompletedTask;
    }

    private Task OnFieldChanged(Guid? fieldId)
    {
        selectedFieldId_ = fieldId;
        NormalizeReferenceSelectionChain();
        return Task.CompletedTask;
    }

    private Task OnClusterChanged(Guid? clusterId)
    {
        selectedClusterId_ = clusterId;
        NormalizeReferenceSelectionChain();
        return Task.CompletedTask;
    }

    private Task OnWellChanged(Guid? wellId)
    {
        selectedWellId_ = wellId;
        if (wellId is Guid selectedId && FindWellById(selectedId) is Well well)
        {
            selectedClusterId_ = well.IsSingleWell ? null : well.ClusterID;
            selectedFieldId_ ??= FindFieldIdForWell(well);
        }
        NormalizeReferenceSelectionChain();
        return Task.CompletedTask;
    }

    private Task OnWellBoreChanged(Guid? wellBoreId)
    {
        selectedWellBoreId_ = wellBoreId;
        if (wellBoreId is Guid selectedId && FindWellBoreById(selectedId) is WellBore wellBore)
        {
            selectedWellId_ = wellBore.WellID;
            if (wellBore.WellID is Guid resolvedWellId && FindWellById(resolvedWellId) is Well well)
            {
                selectedClusterId_ = well.IsSingleWell ? null : well.ClusterID;
                selectedFieldId_ ??= FindFieldIdForWell(well);
            }
        }
        NormalizeReferenceSelectionChain();
        return Task.CompletedTask;
    }

    private void NormalizeReferenceSelectionChain()
    {
        if (selectedClusterId_ != null && !AvailableClusters.Any(cluster => cluster.MetaInfo.ID == selectedClusterId_))
        {
            selectedClusterId_ = null;
        }

        if (selectedWellId_ != null && !AvailableWells.Any(well => well.MetaInfo.ID == selectedWellId_))
        {
            selectedWellId_ = null;
        }

        if (selectedWellBoreId_ != null && !AvailableWellBores.Any(wellBore => wellBore.MetaInfo.ID == selectedWellBoreId_))
        {
            selectedWellBoreId_ = null;
        }

        if (selectedReferenceSurveyRunId_ != null && !AvailableReferenceSurveyRuns.Any(surveyRun => surveyRun.MetaInfo.ID == selectedReferenceSurveyRunId_))
        {
            selectedReferenceSurveyRunId_ = null;
            if (currentCalculation_ != null)
            {
                currentCalculation_.ReferenceSurveyRunID = Guid.Empty;
            }
            ApplySurveyRunReferenceValues();
        }
    }

    private Task OnComparisonFieldChanged(Guid? fieldId)
    {
        comparisonFieldId_ = fieldId;
        NormalizeComparisonSelectionChain();
        return Task.CompletedTask;
    }

    private Task OnComparisonClusterChanged(Guid? clusterId)
    {
        comparisonClusterId_ = clusterId;
        NormalizeComparisonSelectionChain();
        return Task.CompletedTask;
    }

    private Task OnComparisonWellChanged(Guid? wellId)
    {
        comparisonWellId_ = wellId;
        if (wellId is Guid selectedId && FindWellById(selectedId) is Well well)
        {
            comparisonClusterId_ = well.IsSingleWell ? null : well.ClusterID;
            comparisonFieldId_ ??= FindFieldIdForWell(well);
        }
        NormalizeComparisonSelectionChain();
        return Task.CompletedTask;
    }

    private Task OnComparisonWellBoreChanged(Guid? wellBoreId)
    {
        comparisonWellBoreId_ = wellBoreId;
        if (wellBoreId is Guid selectedId && FindWellBoreById(selectedId) is WellBore wellBore)
        {
            comparisonWellId_ = wellBore.WellID;
            if (wellBore.WellID is Guid resolvedWellId && FindWellById(resolvedWellId) is Well well)
            {
                comparisonClusterId_ = well.IsSingleWell ? null : well.ClusterID;
                comparisonFieldId_ ??= FindFieldIdForWell(well);
            }
        }
        NormalizeComparisonSelectionChain();
        return Task.CompletedTask;
    }

    private void NormalizeComparisonSelectionChain()
    {
        if (comparisonClusterId_ != null && !AvailableComparisonClusters.Any(cluster => cluster.MetaInfo.ID == comparisonClusterId_))
        {
            comparisonClusterId_ = null;
        }

        if (comparisonWellId_ != null && !AvailableComparisonWells.Any(well => well.MetaInfo.ID == comparisonWellId_))
        {
            comparisonWellId_ = null;
        }

        if (comparisonWellBoreId_ != null && !AvailableComparisonWellBores.Any(wellBore => wellBore.MetaInfo.ID == comparisonWellBoreId_))
        {
            comparisonWellBoreId_ = null;
        }

        stagedComparisonSurveyRunIDs_.RemoveWhere(id => !AvailableComparisonCandidates.Any(surveyRun => surveyRun.MetaInfo?.ID == id));
    }

    private void SyncSelectorsFromSurveyRun(Guid? surveyRunId)
    {
        selectedFieldId_ = null;
        selectedClusterId_ = null;
        selectedWellId_ = null;
        selectedWellBoreId_ = null;

        if (surveyRunId is not Guid id || SurveyRunLightList_.FirstOrDefault(surveyRun => surveyRun.MetaInfo?.ID == id) is not SurveyRunLight surveyRun)
        {
            return;
        }

        selectedReferenceSurveyRunId_ = id;
        selectedWellBoreId_ = surveyRun.WellBoreID == Guid.Empty ? null : surveyRun.WellBoreID;
        selectedWellId_ = surveyRun.WellID;
        selectedClusterId_ = surveyRun.ClusterID;
        selectedFieldId_ = surveyRun.FieldID;

        if (selectedWellId_ is Guid wellId && FindWellById(wellId) is Well well)
        {
            selectedClusterId_ = well.IsSingleWell ? null : well.ClusterID;
            selectedFieldId_ ??= FindFieldIdForWell(well);
        }
    }

