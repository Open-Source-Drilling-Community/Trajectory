    private bool AreAllAvailableComparisonCandidatesStaged =>
        AvailableComparisonCandidates.Count > 0 &&
        AvailableComparisonCandidates.All(surveyRun => surveyRun.MetaInfo?.ID is Guid id && stagedComparisonSurveyRunIDs_.Contains(id));
    private List<SurveyRunLight> SelectedComparisonSurveyRuns =>
        currentCalculation_?.ComparisonSurveyRunIDList?
            .Select(id => SurveyRunLightList_.FirstOrDefault(surveyRun => surveyRun.MetaInfo?.ID == id))
            .Where(surveyRun => surveyRun != null)
            .Cast<SurveyRunLight>()
            .OrderBy(surveyRun => surveyRun.Name)
            .ToList() ?? [];

