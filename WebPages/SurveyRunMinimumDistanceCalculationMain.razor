        .ToList();
    private List<List<object>> DistanceValuesList => ResultGroups
        .Select(group => group.OrderBy(result => result.ReferenceMD).Select(result => (object)(SelectedDistance(result) ?? double.NaN)).ToList())
        .ToList();
    private List<List<object>> ToolfaceValuesList => ResultGroups
        .Select(group => group.OrderBy(result => result.ReferenceMD).Select(result => (object)(result.Toolface ?? double.NaN)).ToList())
        .ToList();
    private List<Guid> ResultComparisonSurveyRunIDs =>
        currentCalculation_?.ResultList?
            .Where(result => result.ComparisonSurveyRunID.HasValue)
            .Select(result => result.ComparisonSurveyRunID!.Value)
            .Distinct()
