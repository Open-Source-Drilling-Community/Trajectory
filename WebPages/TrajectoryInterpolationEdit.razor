    private void AddSupplementaryInterpolationDepth()
    {
        if (supplementaryInterpolationDepthInput is not { } depth || double.IsNaN(depth) || double.IsInfinity(depth))
        {
            Snackbar.Add("Supplementary interpolation depth must be a defined value", Severity.Warning);
            return;
        }

        List<AnnotatedAbscissa> depths = AdditionalAbscissas;
        AnnotatedAbscissa? existing = depths.FirstOrDefault(x => Math.Abs(x.Abscissa - depth) < 1e-6);
        string? annotation = string.IsNullOrWhiteSpace(supplementaryInterpolationAnnotationInput) ? null : supplementaryInterpolationAnnotationInput.Trim();

        if (existing == null)
        {
            depths.Add(new AnnotatedAbscissa { Abscissa = depth, Annotation = annotation });
        }
        else if (!string.IsNullOrWhiteSpace(annotation))
        {
            existing.Annotation = annotation;
        }

        currentInterpolatedTrajectory.AdditionalAbscissaList = depths.OrderBy(x => x.Abscissa).ToList();
