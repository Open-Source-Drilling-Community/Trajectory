        {
            return null;
        }

        HashSet<Guid> candidateWellBoreIds = [];

        if (selectedWellBoreId is Guid selectedWellBore && selectedWellBore != Guid.Empty)
        {
            candidateWellBoreIds.Add(selectedWellBore);
        }

        if (selectedTrajectory?.WellBoreID is Guid trajectoryWellBore && trajectoryWellBore != Guid.Empty)
        {
            candidateWellBoreIds.Add(trajectoryWellBore);
        }

        if (selectedTrajectoryId is Guid trajectoryId)
