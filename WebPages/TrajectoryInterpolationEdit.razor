    private static double? ResolveFirstSurveyOutputMd(Trajectory? trajectory, WellBoreArchitecture? architecture)
    {
        if (trajectory?.SurveyStationList is not { Count: > 0 } surveyStationCollection)
        {
            return null;
        }

        List<SurveyStation> surveyStations = surveyStationCollection
            .Where(station => station?.MD is { } && station.TVD is { })
            .OrderBy(station => station.MD)
            .ToList();

        if (surveyStations.Count == 0)
        {
            return trajectory.SurveyStationList.FirstOrDefault()?.MD;
        }

        SurveyStation firstSurvey = surveyStations[0];
        if (firstSurvey.MD is not { } firstSurveyMd)
        {
            return null;
        }

        List<OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint> surveyPoints = surveyStations
            .Select(station => new OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint
            {
                MD = station.MD,
                Inclination = station.Inclination,
                Azimuth = station.Azimuth,
                TVD = station.TVD,
                RiemannianNorth = station.RiemannianNorth,
                RiemannianEast = station.RiemannianEast,
                Curvature = station.Curvature,
                BUR = station.BUR,
                TUR = station.TUR,
                Toolface = station.Toolface,
                VerticalSection = station.VerticalSection
            })
            .ToList();

        double? wellHeadDepth = GetGaussianMean(architecture?.WellHead?.Depth);
        if (wellHeadDepth is not { } targetDepth || firstSurvey.TVD is not { } firstSurveyTvd || firstSurveyTvd >= targetDepth)
        {
            return firstSurveyMd;
        }

        for (int i = 1; i < surveyStations.Count; i++)
        {
            SurveyStation start = surveyStations[i - 1];
            SurveyStation end = surveyStations[i];
            if (start.MD is not { } startMd ||
                end.MD is not { } endMd ||
                start.TVD is not { } startTvd ||
                end.TVD is not { } endTvd)
            {
                continue;
            }

            if (IsDepthWithinSegment(targetDepth, startTvd, endTvd))
            {
                return InterpolateMdAtDepth(surveyPoints, startMd, endMd, targetDepth, ToSurveyingCalculationType(trajectory.CalculationType)) ?? firstSurveyMd;
            }
        }

        return firstSurveyMd;
    }
    private static bool IsDepthWithinSegment(double targetDepth, double startDepth, double endDepth)
    {
        double minDepth = Math.Min(startDepth, endDepth);
        double maxDepth = Math.Max(startDepth, endDepth);
        return targetDepth >= minDepth && targetDepth <= maxDepth;
    }
    private static OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType ToSurveyingCalculationType(TrajectoryCalculationType calculationType)
    {
        return calculationType switch
        {
            TrajectoryCalculationType.ConstantBuildAndTurnMethod => OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType.ConstantBuildAndTurnMethod,
            TrajectoryCalculationType.ConstantCurvatureAndToolfaceMethod => OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType.ConstantCurvatureAndToolfaceMethod,
            _ => OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType.MinimumCurvatureMethod,
        };
    }
    private static double? InterpolateMdAtDepth(List<OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint> surveyStations, double startMd, double endMd, double targetDepth, OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType calculationType)
    {
        const double depthTolerance = 1e-6;
        double lowMd = Math.Min(startMd, endMd);
        double highMd = Math.Max(startMd, endMd);
        OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint lowPoint = new();
        OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint highPoint = new();
        if (!OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint.InterpolateAtAbscissa(surveyStations, lowMd, lowPoint, calculationType) ||
            !OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint.InterpolateAtAbscissa(surveyStations, highMd, highPoint, calculationType) ||
            lowPoint.TVD is not { } resolvedLowDepth ||
            highPoint.TVD is not { } resolvedHighDepth)
        {
            return null;
        }

        double lowDepth = resolvedLowDepth;
        double highDepth = resolvedHighDepth;

        if (!IsDepthWithinSegment(targetDepth, lowDepth, highDepth))
        {
            return null;
        }

        for (int i = 0; i < 64; i++)
        {
            double midMd = 0.5 * (lowMd + highMd);
            OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint midPoint = new();
            if (!OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint.InterpolateAtAbscissa(surveyStations, midMd, midPoint, calculationType) ||
                midPoint.TVD is not { } resolvedMidDepth)
            {
                return null;
            }

            double midDepth = resolvedMidDepth;

            if (Math.Abs(midDepth - targetDepth) <= depthTolerance)
            {
                return midMd;
            }

            if (IsDepthWithinSegment(targetDepth, lowDepth, midDepth))
            {
                highMd = midMd;
                highDepth = midDepth;
            }
            else
            {
                lowMd = midMd;
                lowDepth = midDepth;
            }
        }

        return 0.5 * (lowMd + highMd);
    }
