    private static double? ResolveFirstSurveyOutputMd(Trajectory? trajectory, WellBoreArchitecture? architecture)
    {
        if (trajectory?.SurveyStationList is not { Count: > 0 } surveyStationCollection)
        {
            return null;
        }

        List<SurveyStation> surveyStations = surveyStationCollection
            .Where(station => station?.MD is { } && station.TVD is { })
            .OrderBy(station => station.MD)
            .ToList();

        if (surveyStations.Count == 0)
        {
            return trajectory.SurveyStationList.FirstOrDefault()?.MD;
        }

        SurveyStation firstSurvey = surveyStations[0];
        if (firstSurvey.MD is not { } firstSurveyMd)
        {
            return null;
        }

        List<OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint> surveyPoints = surveyStations
            .Select(station => new OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint
            {
                MD = station.MD,
                Inclination = station.Inclination,
                Azimuth = station.Azimuth,
                TVD = station.TVD,
                RiemannianNorth = station.RiemannianNorth,
                RiemannianEast = station.RiemannianEast,
                Curvature = station.Curvature,
                BUR = station.BUR,
                TUR = station.TUR,
                Toolface = station.Toolface,
                VerticalSection = station.VerticalSection
            })
            .ToList();

        double? wellHeadDepth = GetGaussianMean(architecture?.WellHead?.Depth);
        if (wellHeadDepth is not { } targetDepth || firstSurvey.TVD is not { } firstSurveyTvd || firstSurveyTvd >= targetDepth)
        {
            return firstSurveyMd;
        }

        for (int i = 1; i < surveyStations.Count; i++)
        {
            SurveyStation start = surveyStations[i - 1];
            SurveyStation end = surveyStations[i];
            if (start.MD is not { } startMd ||
                end.MD is not { } endMd ||
                start.TVD is not { } startTvd ||
                end.TVD is not { } endTvd)
            {
                continue;
            }

            if (IsDepthWithinSegment(targetDepth, startTvd, endTvd))
            {
                return InterpolateMdAtDepth(surveyPoints, startMd, endMd, targetDepth, ToSurveyingCalculationType(trajectory.CalculationType)) ?? firstSurveyMd;
            }
        }

        return firstSurveyMd;
    }
    private static bool IsDepthWithinSegment(double targetDepth, double startDepth, double endDepth)
    {
        double minDepth = Math.Min(startDepth, endDepth);
        double maxDepth = Math.Max(startDepth, endDepth);
        return targetDepth >= minDepth && targetDepth <= maxDepth;
    }
    private static OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType ToSurveyingCalculationType(TrajectoryCalculationType calculationType)
    {
        return calculationType switch
        {
            TrajectoryCalculationType.ConstantBuildAndTurnMethod => OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType.ConstantBuildAndTurnMethod,
            TrajectoryCalculationType.ConstantCurvatureAndToolfaceMethod => OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType.ConstantCurvatureAndToolfaceMethod,
            _ => OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType.MinimumCurvatureMethod,
        };
    }
    private static double? InterpolateMdAtDepth(List<OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint> surveyStations, double startMd, double endMd, double targetDepth, OSDC.DotnetLibraries.Drilling.Surveying.TrajectoryCalculationType calculationType)
    {
        const double depthTolerance = 1e-6;
        double lowMd = Math.Min(startMd, endMd);
        double highMd = Math.Max(startMd, endMd);
        OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint lowPoint = new();
        OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint highPoint = new();
        if (!OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint.InterpolateAtAbscissa(surveyStations, lowMd, lowPoint, calculationType) ||
            !OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint.InterpolateAtAbscissa(surveyStations, highMd, highPoint, calculationType) ||
            lowPoint.TVD is not { } resolvedLowDepth ||
            highPoint.TVD is not { } resolvedHighDepth)
        {
            return null;
        }

        double lowDepth = resolvedLowDepth;
        double highDepth = resolvedHighDepth;

        if (!IsDepthWithinSegment(targetDepth, lowDepth, highDepth))
        {
            return null;
        }

        for (int i = 0; i < 64; i++)
        {
            double midMd = 0.5 * (lowMd + highMd);
            OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint midPoint = new();
            if (!OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint.InterpolateAtAbscissa(surveyStations, midMd, midPoint, calculationType) ||
                midPoint.TVD is not { } resolvedMidDepth)
            {
                return null;
            }

            double midDepth = resolvedMidDepth;

            if (Math.Abs(midDepth - targetDepth) <= depthTolerance)
            {
                return midMd;
            }

            if (IsDepthWithinSegment(targetDepth, lowDepth, midDepth))
            {
                highMd = midMd;
                highDepth = midDepth;
            }
            else
            {
                lowMd = midMd;
                lowDepth = midDepth;
            }
        }

        return 0.5 * (lowMd + highMd);
    }
    private async Task EnsureWellBoreArchitectureDataLoadedAsync()
    {
        if (wellBoreArchitectureHeavyList != null || isLoadingWellBoreArchitectureData)
        {
            return;
        }

        try
        {
            isLoadingWellBoreArchitectureData = true;
            wellBoreArchitectureHeavyList = (List<WellBoreArchitecture>)await Api.ClientWellBoreArchitecture.GetAllWellBoreArchitectureAsync();
        }
        finally
        {
            isLoadingWellBoreArchitectureData = false;
        }
    }
    private WellBoreArchitecture? GetSelectedWellBoreArchitecture(Trajectory? selectedTrajectory = null)
    {
        if (wellBoreArchitectureHeavyList is not { Count: > 0 })
        {
            return null;
        }

        HashSet<Guid> candidateWellBoreIds = [];

        if (selectedWellBoreId is Guid selectedWellBore && selectedWellBore != Guid.Empty)
        {
            candidateWellBoreIds.Add(selectedWellBore);
        }

        if (selectedTrajectory?.WellBoreID is Guid trajectoryWellBore && trajectoryWellBore != Guid.Empty)
        {
            candidateWellBoreIds.Add(trajectoryWellBore);
        }

        if (selectedTrajectoryId is Guid trajectoryId)
        {
            Guid? lightWellBoreId = GetTrajectoryWellBoreId(trajectoryId);
            if (lightWellBoreId is Guid resolvedLightWellBoreId && resolvedLightWellBoreId != Guid.Empty)
            {
                candidateWellBoreIds.Add(resolvedLightWellBoreId);
            }
        }

        foreach (Guid wellBoreId in candidateWellBoreIds.ToList())
        {
            foreach (Guid hierarchyWellBoreId in EnumerateWellBoreHierarchyIds(wellBoreId))
            {
                WellBoreArchitecture? architecture = wellBoreArchitectureHeavyList.FirstOrDefault(item => item?.WellBoreID == hierarchyWellBoreId);
                if (architecture != null)
                {
                    return architecture;
                }
            }
        }

        return null;
    }
    private IEnumerable<Guid> EnumerateWellBoreHierarchyIds(Guid startWellBoreId)
    {
        HashSet<Guid> visited = [];
        Guid? currentWellBoreId = startWellBoreId;

        while (currentWellBoreId is Guid wellBoreId && wellBoreId != Guid.Empty && visited.Add(wellBoreId))
        {
            yield return wellBoreId;

            WellBore? currentWellBore = FindWellBoreById(wellBoreId);
            currentWellBoreId = currentWellBore?.ParentWellBoreID;
        }
    }
    private void AddOrUpdateAnnotatedAbscissa(List<AnnotatedAbscissa> values, double? abscissa, string? annotation)
    {
        if (abscissa is not { } depth || double.IsNaN(depth) || double.IsInfinity(depth))
        {
            return;
        }

        AnnotatedAbscissa? existing = values.FirstOrDefault(x => Math.Abs(x.Abscissa - depth) < 1e-6);
        if (existing == null)
        {
            values.Add(new AnnotatedAbscissa { Abscissa = depth, Annotation = annotation });
            return;
        }

        if (string.IsNullOrWhiteSpace(annotation))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(existing.Annotation))
        {
            existing.Annotation = annotation;
        }
    }
    private string BuildCasingAnnotation(string prefix, double? size)
    {
        string sizeText = FormatCasingSize(size);
        return string.IsNullOrWhiteSpace(sizeText) ? prefix : $"{prefix} {sizeText}";
    }
    private string BuildCasingChangeAnnotation(double? sizeAbove, double? sizeBelow)
    {
        string above = FormatCasingSize(sizeAbove);
        string below = FormatCasingSize(sizeBelow);
        if (string.IsNullOrWhiteSpace(above) || string.IsNullOrWhiteSpace(below))
        {
            return "Casing size change";
        }

        return $"Casing size {above} x {below}";
    }
    private string FormatCasingSize(double? size) =>
        Parent == null || size is not { } definedSize
            ? string.Empty
            : Parent.FromSI(definedSize, "DiameterPipeDrilling", true);
    private void AddCasingChangeAnnotations(List<AnnotatedAbscissa> values, CasingSection? casingSection)
    {
        if (casingSection?.CasingSectionElements is not { Count: > 1 } elements)
        {
            return;
        }

        double currentDepth = GetGaussianMean(casingSection.TopDepth) ?? 0.0;
        double? previousBodyOd = null;

        foreach (CasingSectionElement element in elements)
        {
            double? currentBodyOd = GetGaussianMean(element?.BodyOD);
            if (previousBodyOd.HasValue &&
                currentBodyOd.HasValue &&
                Math.Abs(previousBodyOd.Value - currentBodyOd.Value) >= 1e-9)
            {
                AddOrUpdateAnnotatedAbscissa(values, currentDepth, BuildCasingChangeAnnotation(previousBodyOd.Value, currentBodyOd.Value));
            }

            previousBodyOd = currentBodyOd ?? previousBodyOd;
            currentDepth += GetGaussianMean(element?.SectionLength) ?? 0.0;
        }
    }
    private static CasingSection? FindCasingSectionForDepth(ICollection<CasingSection>? casingSections, double? depth)
    {
        if (casingSections is not { Count: > 0 })
        {
            return null;
        }

        if (depth is not { } requestedDepth)
        {
            return casingSections.FirstOrDefault();
        }

        return casingSections
            .OrderBy(section => Math.Abs((GetGaussianMean(section?.TopDepth) ?? double.MaxValue) - requestedDepth))
            .FirstOrDefault();
    }
    private static double? GetCasingSize(CasingSection? casingSection)
    {
        if (casingSection?.CasingSectionElements is { Count: > 0 } elements)
        {
            foreach (CasingSectionElement element in elements)
            {
                double? value = GetGaussianMean(element?.BodyOD);
                if (value is { })
                {
                    return value;
                }
            }
        }

        return null;
    }
    private static double? GetGaussianMean(GaussianDrillingProperty? property) => property?.GaussianValue?.Mean;
    private static double? GetScalarValue(ScalarDrillingProperty? property) => property?.DiracDistributionValue?.Value;
    private static string NormalizeExportNumber(string? value) { if (string.IsNullOrWhiteSpace(value)) return string.Empty; string trimmed = value.Trim().Replace("\u00A0", string.Empty, StringComparison.Ordinal).Replace(" ", string.Empty, StringComparison.Ordinal); if (double.TryParse(trimmed, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.CurrentCulture, out double parsed) || double.TryParse(trimmed, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out parsed) || double.TryParse(trimmed, NumberStyles.Float | NumberStyles.AllowThousands, new CultureInfo("nb-NO"), out parsed)) return parsed.ToString("G17", CultureInfo.InvariantCulture); return trimmed.Replace(',', '.'); }
    private static string SanitizeExportField(string? value) { if (string.IsNullOrEmpty(value)) return string.Empty; string sanitized = value.Replace("\r", " ", StringComparison.Ordinal).Replace("\n", " ", StringComparison.Ordinal).Replace("\t", " ", StringComparison.Ordinal).Trim().Replace("°", "deg", StringComparison.Ordinal).Replace("µ", "u", StringComparison.Ordinal).Replace("μ", "u", StringComparison.Ordinal); StringBuilder ascii = new(sanitized.Length); foreach (char c in sanitized) ascii.Append(c <= sbyte.MaxValue ? c : '?'); return ascii.ToString(); }
    private static string SanitizeFileName(string fileName) { char[] invalidChars = Path.GetInvalidFileNameChars(); StringBuilder builder = new(fileName.Length); foreach (char c in fileName) builder.Append(invalidChars.Contains(c) ? '-' : c); return builder.ToString().Trim(); }
