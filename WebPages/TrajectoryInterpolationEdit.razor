@inject ILogger<TrajectoryInterpolationEdit> logger
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject ITrajectoryAPIUtils Api
@using System.Globalization
@using System.Text
@using System.Text.Json

<MudText Class="mt-4 mb-4" Typo="Typo.h6">Edit Interpolated Trajectory</MudText>
<MudContainer Class="d-flex flex-row mt-4 mb-4">
    <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveInterpolatedTrajectory">Save</MudButton>
    <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="CloseEditorAsync">Close</MudButton>
</MudContainer>

@if (currentInterpolatedTrajectory is { } traj)
{
    <MudGrid>
        <MudItem xs="3"><MudTextField @bind-Value="traj.Name" Label="Name" Required="true" ShrinkLabel /></MudItem>
        <MudItem xs="3"><MudTextField @bind-Value="traj.Description" Label="Description" ShrinkLabel /></MudItem>
        <MudItem xs="3"><MudTextField Value="@FormatDate(traj.CreationDate)" Label="Created" ReadOnly="true" ShrinkLabel /></MudItem>
        <MudItem xs="3"><MudTextField Value="@FormatDate(traj.LastModificationDate)" Label="Last Updated" ReadOnly="true" ShrinkLabel /></MudItem>
        <MudItem xs="2">
            <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                @foreach (Field field in AvailableFields)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="2">
            <MudSelect Label="Cluster" T="Guid?" Value="@selectedClusterId" ValueChanged="OnClusterChanged" ShrinkLabel Clearable="true">
                @foreach (Cluster cluster in AvailableClusters)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">@cluster.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="2">
            <MudSelect Label="Well" T="Guid?" Value="@selectedWellId" ValueChanged="OnWellChanged" ShrinkLabel Clearable="true">
                @foreach (Well well in AvailableWells)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">@well.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="3">
            <MudSelect Label="WellBore" T="Guid?" Value="@selectedWellBoreId" ValueChanged="OnWellBoreChanged" ShrinkLabel Clearable="true">
                @foreach (WellBore wb in AvailableWellBores)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)wb.MetaInfo.ID)">@wb.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="3">
            <MudSelect Label="Trajectory" T="Guid?" Value="@selectedTrajectoryId" ValueChanged="OnTrajectoryChanged" ShrinkLabel Clearable="true">
                @foreach (TrajectoryLight trajectory in AvailableTrajectories)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)trajectory.MetaInfo.ID)">@trajectory.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="3"><MudTextField Value="@AssociatedRigName" Label="Rig" ReadOnly="true" ShrinkLabel /></MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mt-4 mb-4" Outlined="true">
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudInputWithUnit QuantityLabel="Interpolation Interval" QuantityName="DepthDrilling"
                                  @key="AdditionalDepthReferenceRenderKey"
                                  SIValueNullable="@InterpolationStepValue"
                                  SIValueNullableChanged="OnInterpolationStepChanged" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudInputWithUnit QuantityLabel="Chord Distance" QuantityName="DepthDrilling"
                                  SIValueNullable="@MaximumChordDistanceValue"
                                  SIValueNullableChanged="OnMaximumChordDistanceChanged" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudInputWithUnit QuantityLabel="Interpolation Reference Depth" QuantityName="DepthDrilling"
                                  @key="AdditionalDepthReferenceRenderKey"
                                  DrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                  SIValueNullable="@InterpolationReferenceDepthValue"
                                  SIValueNullableChanged="OnInterpolationReferenceDepthChanged" />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="traj.IncludeFirstSurvey" Label="Include first survey" />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="traj.IncludeLastSurvey" Label="Include last survey" />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="traj.InterpolateAtCasingAndLinerShoeDepths" Label="At casing and liner shoe depths" />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="traj.InterpolateAtLinerHangerDepths" Label="At casing hanger depths" />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="traj.InterpolateAtCasingChangeOfDiameter" Label="At casing change of diameter" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudInputWithUnit QuantityLabel="Additional Interpolation Depth" QuantityName="DepthDrilling"
                                  @key="AdditionalDepthReferenceRenderKey"
                                  DrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                  SIValueNullable="@supplementaryInterpolationDepthInput"
                                  SIValueNullableChanged="@(val => supplementaryInterpolationDepthInput = val)" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="supplementaryInterpolationAnnotationInput" Label="Annotation" ShrinkLabel />
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudButton OnClick="AddSupplementaryInterpolationDepth" Color="Color.Primary" Variant="Variant.Outlined">Add Depth</MudButton>
            </MudItem>
            <MudItem xs="12" md="6">
                @if (AdditionalAbscissas.Count > 0)
                {
                    <MudTable Items="@AdditionalAbscissas" T="AnnotatedAbscissa" Dense="true" Elevation="0" Hover="true" @key="AdditionalDepthReferenceRenderKey">
                        <RowTemplate>
                            <MudTd DataLabel="Supplementary depth"><MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.Abscissa" /></MudTd>
                            <MudTd DataLabel="Annotation">@context.Annotation</MudTd>
                            <MudTd DataLabel="Delete"><MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="@(() => RemoveSupplementaryInterpolationDepth(context))" /></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudExpansionPanels Class="mt-4" Style="overflow-y: auto; max-height: none;">
        <MudExpansionPanel Text="Interpolated survey points" ExpandedChanged="@OnCalculatedStationsPanelExpandedChanged">
            <MudToolBar>
                <MudText Typo="Typo.h6">Interpolated survey points</MudText>
                <MudSpacer />
                <MudButton OnClick="ExportInterpolatedSurveyPointsAsync" Color="@Color.Primary" Variant="Variant.Outlined" Disabled="@isLoadingCalculatedStations_">Export</MudButton>
            </MudToolBar>

            @if (isLoadingCalculatedStations_)
            {
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.body2">@InterpolatedStationLoadingText</MudText>
                    <MudProgressLinear Value="@InterpolatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                </MudPaper>
            }
            else if (traj.SurveyStationList is { Count: > 0 } surveyStations)
            {
                <MudTable Items="@surveyStations" T="SurveyStation" Height="400px" FixedHeader="true"
                          Virtualize="true" OverscanCount="3" ItemSize="38"
                          Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true" ReadOnly="true">
            <HeaderContent>
                <MudTHeadRow>
                    <MudTh>Measured Depth [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                    <MudTh>Inclination [@Parent?.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                    <MudTh>Azimuth [@Parent?.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                    <MudTh>Vertical Depth [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                    <MudTh>@NorthCoordinateLabel [@Parent?.GetUnitLabel("PositionDrilling")]</MudTh>
                    <MudTh>@EastCoordinateLabel [@Parent?.GetUnitLabel("PositionDrilling")]</MudTh>
                    <MudTh>Vertical Section [@Parent?.GetUnitLabel("DepthDrilling")]</MudTh>
                    <MudTh>Curvature [@Parent?.GetUnitLabel("CurvatureDrilling")]</MudTh>
                    <MudTh>BUR [@Parent?.GetUnitLabel("CurvatureDrilling")]</MudTh>
                    <MudTh>TR [@Parent?.GetUnitLabel("CurvatureDrilling")]</MudTh>
                    <MudTh>Annotation</MudTh>
                </MudTHeadRow>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.MD" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Inclination" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Azimuth" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.TVD" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="PositionDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Position" PositionDirection="@PositionDirectionType.North" SIValue="@context.RiemannianNorth" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="PositionDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Position" PositionDirection="@PositionDirectionType.East" SIValue="@context.RiemannianEast" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="DepthDrilling" SIValue="@context.VerticalSection" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.Curvature" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.BUR" /></MudTd>
                <MudTd><MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.TUR" /></MudTd>
                <MudTd>@context.Annotation</MudTd>
            </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudText>No interpolated survey points</MudText>
            }
        </MudExpansionPanel>
        <MudExpansionPanel Text="Uncertainty ellipses" ExpandedChanged="@OnCalculatedStationsPanelExpandedChanged">
            @if (isLoadingCalculatedStations_)
            {
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.body2">@InterpolatedStationLoadingText</MudText>
                    <MudProgressLinear Value="@InterpolatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                </MudPaper>
            }
            else if (traj.SurveyStationList is { Count: > 0 } surveyStations)
            {
                <SurveyStationEllipseTable SurveyStationList="@surveyStations"
                                           CalculationName="@($"{traj.Name} uncertainty ellipses")"
                                           EllipseResultsChanged="OnEllipseResultsChanged"
                                           CalculationChanged="OnEllipseCalculationChanged" />
            }
            else
            {
                <MudText>No interpolated survey points</MudText>
            }
        </MudExpansionPanel>
        <MudExpansionPanel Text="Plot interpolated trajectory" Style="overflow: visible;" ExpandedChanged="@OnCalculatedStationsPanelExpandedChanged">
            @if (isLoadingCalculatedStations_)
            {
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.body2">@InterpolatedStationLoadingText</MudText>
                    <MudProgressLinear Value="@InterpolatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                </MudPaper>
            }
            else if (traj.SurveyStationList is { Count: > 0 })
            {
                <MudToolBar>
                    <MudText Typo="Typo.h6">Plot</MudText>
                    <MudSpacer />
                    <MudNumericField T="int" Value="@maxDisplayedUncertaintiesInPlots"
                                     ValueChanged="OnMaxDisplayedUncertaintiesInPlotsChanged"
                                     Label="Max number of ellipses"
                                     Min="1"
                                     Max="100000"
                                     Step="50"
                                     ShrinkLabel
                                     Style="width: 180px;" />
                </MudToolBar>
                <MudGrid Justify="Justify.Center">
                    <MudItem xs="12">
                        <Scatter3DPlot NameList="@ThreeDNameList" ModeFlagList="@ThreeDModeFlagList" ColorList="@ThreeDColorList"
                                       MarkerSizeList="@ThreeDMarkerSizeList"
                                       ShowLegendList="@ThreeDShowLegendList"
                                       XValuesList="@ThreeDNorthValuesList" YValuesList="@ThreeDEastValuesList" ZValuesList="@ThreeDTvdValuesList"
                                       YAxisReversed="@true" ZAxisReversed="@true"
                                       PlotTitle="" XAxisTitle="@NorthCoordinateLabel" YAxisTitle="@EastCoordinateLabel" ZAxisTitle="TVD"
                                       XUnit="PositionDrilling" YUnit="PositionDrilling" ZUnit="DepthDrilling"
                                       XAxisUsesPositionReference="@true"
                                       YAxisUsesPositionReference="@true"
                                       ZAxisUsesDepthReference="@true"
                                       XAxisPositionDirection="@PositionDirectionType.North"
                                       YAxisPositionDirection="@PositionDirectionType.East">
                        </Scatter3DPlot>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <ScatterPlot NameList="@HorizontalNameList" ModeFlagList="@HorizontalModeFlagList" ColorList="@HorizontalColorList"
                                     MarkerSizeList="@HorizontalMarkerSizeList"
                                     ShowLegendList="@HorizontalShowLegendList"
                                     XValuesList="@HorizontalEastValuesList" YValuesList="@HorizontalNorthValuesList"
                                     PlotTitle="" XAxisTitle="@EastCoordinateLabel" YAxisTitle="@NorthCoordinateLabel"
                                     XUnit="PositionDrilling" YUnit="PositionDrilling"
                                     XAxisUsesPositionReference="@true"
                                     YAxisUsesPositionReference="@true"
                                     XAxisPositionDirection="@PositionDirectionType.East"
                                     YAxisPositionDirection="@PositionDirectionType.North"
                                     AspectRatio="1">
                        </ScatterPlot>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <ScatterPlot NameList="@VerticalNameList" ModeFlagList="@VerticalModeFlagList" ColorList="@VerticalColorList"
                                     MarkerSizeList="@VerticalMarkerSizeList"
                                     ShowLegendList="@VerticalShowLegendList"
                                     XValuesList="@VerticalSectionValuesList" YValuesList="@VerticalTvdValuesList"
                                     PlotTitle="" XAxisTitle="Vertical Section" YAxisTitle="TVD"
                                     XUnit="DepthDrilling" YUnit="DepthDrilling"
                                     YAxisReversed="@true"
                                     YAxisUsesDepthReference="@true"
                                     XAxisStartsAtZero="@true">
                        </ScatterPlot>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText>No interpolated survey points</MudText>
            }
        </MudExpansionPanel>
    </MudExpansionPanels>
}

@code {
    [CascadingParameter] private MudUnitAndReferenceChoiceTag? Parent { get; set; }
    [Parameter] public Guid? InterpolatedTrajectoryId { get; set; }
    [Parameter] public List<Rig>? RigList { get; set; }
    [Parameter] public List<WellBore>? WellBoreList { get; set; }
    [Parameter] public List<Well>? WellList { get; set; }
    [Parameter] public List<Cluster>? ClusterList { get; set; }
    [Parameter] public List<Field>? FieldList { get; set; }
    [Parameter] public List<TrajectoryLight>? TrajectoryList { get; set; }
    [Parameter] public EventCallback ValueChanged { get; set; }

    private InterpolatedTrajectory currentInterpolatedTrajectory = CreateInterpolatedTrajectory();
    private Guid? selectedFieldId;
    private Guid? selectedClusterId;
    private Guid? selectedWellId;
    private Guid? selectedWellBoreId;
    private Guid? selectedTrajectoryId;
    private Guid? interpolatedTrajectoryIdBeingEdited;
    private string? cleanInterpolatedTrajectorySnapshot;
    private double? supplementaryInterpolationDepthInput;
    private string? supplementaryInterpolationAnnotationInput;
    private List<WellBoreArchitecture>? wellBoreArchitectureHeavyList;
    private bool isLoadingWellBoreArchitectureData;
    private readonly List<string> nameList = [];
    private readonly List<int> modeFlagList = [];
    private readonly List<string> colorList = [];
    private readonly List<List<object>> northValuesList = [];
    private readonly List<List<object>> eastValuesList = [];
    private readonly List<List<object>> tvdValuesList = [];
    private readonly List<List<object>> verticalSectionValuesList = [];
    private readonly EllipsePlotData ellipsePlotData = new();
    private List<SurveyStationEllipseResult> ellipseResults = [];
    private SurveyStationEllipseCalculation? ellipseCalculation;
    private int maxDisplayedUncertaintiesInPlots = 200;
    private bool isLoadingCalculatedStations_;
    private bool calculatedStationLoadComplete_;
    private bool calculatedStationsPanelExpanded_;
    private int calculatedStationChunkCount_;
    private int calculatedStationChunksLoaded_;
    private int calculatedStationsLoaded_;
    private static readonly JsonSerializerOptions DirtySnapshotJsonOptions = new() { WriteIndented = false };

    private List<string> HorizontalNameList => Combine(nameList, ellipsePlotData.HorizontalNameList);
    private List<int> HorizontalModeFlagList => Combine(modeFlagList, ellipsePlotData.HorizontalModeFlagList);
    private List<string> HorizontalColorList => Combine(colorList, ellipsePlotData.HorizontalColorList);
    private List<int?> HorizontalMarkerSizeList => Combine(Enumerable.Repeat<int?>(null, nameList.Count), ellipsePlotData.HorizontalMarkerSizeList);
    private List<bool> HorizontalShowLegendList => CombineLegendFlags(nameList.Count, ellipsePlotData.HorizontalShowLegendList);
    private List<List<object>> HorizontalEastValuesList => Combine(eastValuesList, ellipsePlotData.HorizontalEastValuesList);
    private List<List<object>> HorizontalNorthValuesList => Combine(northValuesList, ellipsePlotData.HorizontalNorthValuesList);

    private List<string> VerticalNameList => Combine(nameList, ellipsePlotData.VerticalNameList);
    private List<int> VerticalModeFlagList => Combine(modeFlagList, ellipsePlotData.VerticalModeFlagList);
    private List<string> VerticalColorList => Combine(colorList, ellipsePlotData.VerticalColorList);
    private List<int?> VerticalMarkerSizeList => Combine(Enumerable.Repeat<int?>(null, nameList.Count), ellipsePlotData.VerticalMarkerSizeList);
    private List<bool> VerticalShowLegendList => CombineLegendFlags(nameList.Count, ellipsePlotData.VerticalShowLegendList);
    private List<List<object>> VerticalSectionValuesList => Combine(verticalSectionValuesList, ellipsePlotData.VerticalSectionValuesList);
    private List<List<object>> VerticalTvdValuesList => Combine(tvdValuesList, ellipsePlotData.VerticalTvdValuesList);

    private List<string> ThreeDNameList => Combine(nameList, ellipsePlotData.PerpendicularNameList);
    private List<int> ThreeDModeFlagList => Combine(modeFlagList, ellipsePlotData.PerpendicularModeFlagList);
    private List<string> ThreeDColorList => Combine(colorList, ellipsePlotData.PerpendicularColorList);
    private List<int?> ThreeDMarkerSizeList => Combine(Enumerable.Repeat<int?>(null, nameList.Count), ellipsePlotData.PerpendicularMarkerSizeList);
    private List<bool> ThreeDShowLegendList => CombineLegendFlags(nameList.Count, ellipsePlotData.PerpendicularShowLegendList);
    private List<List<object>> ThreeDNorthValuesList => Combine(northValuesList, ellipsePlotData.PerpendicularNorthValuesList);
    private List<List<object>> ThreeDEastValuesList => Combine(eastValuesList, ellipsePlotData.PerpendicularEastValuesList);
    private List<List<object>> ThreeDTvdValuesList => Combine(tvdValuesList, ellipsePlotData.PerpendicularTvdValuesList);

    private static List<T> Combine<T>(IEnumerable<T> first, IEnumerable<T> second) => first.Concat(second).ToList();
    private static List<bool> CombineLegendFlags(int baseTraceCount, IEnumerable<bool> ellipseFlags) =>
        Enumerable.Repeat(true, baseTraceCount).Concat(ellipseFlags).ToList();
    private double InterpolatedStationLoadingProgressPercent =>
        calculatedStationChunkCount_ <= 0 ? 0.0 : 100.0 * calculatedStationChunksLoaded_ / calculatedStationChunkCount_;
    private string InterpolatedStationLoadingText =>
        calculatedStationChunkCount_ <= 0
            ? "Loading interpolated survey point chunks..."
            : $"Loading interpolated survey point chunks {calculatedStationChunksLoaded_}/{calculatedStationChunkCount_} ({calculatedStationsLoaded_:N0} stations)";

    protected override async Task OnParametersSetAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        interpolatedTrajectoryIdBeingEdited = InterpolatedTrajectoryId;
        currentInterpolatedTrajectory = InterpolatedTrajectoryId is Guid id ? await Api.ClientTrajectory.GetInterpolatedTrajectoryByIdAsync(id) : CreateInterpolatedTrajectory();
        currentInterpolatedTrajectory.SurveyStationList ??= [];
        ResetCalculatedStationLoadingState();
        selectedTrajectoryId = currentInterpolatedTrajectory.TrajectoryID == Guid.Empty ? null : currentInterpolatedTrajectory.TrajectoryID;
        SyncSelectorsFromTrajectory(selectedTrajectoryId);
        await UpdateReferenceSourcesAsync();
        UpdatePlots();
        MarkInterpolatedTrajectoryClean();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveInterpolatedTrajectory()
    {
        try
        {
            currentInterpolatedTrajectory.MetaInfo ??= PseudoConstructors.ConstructMetaInfo();
            currentInterpolatedTrajectory.TrajectoryID = selectedTrajectoryId ?? Guid.Empty;
            currentInterpolatedTrajectory.AdditionalAbscissaList = BuildUserAdditionalAbscissasForSave();
            currentInterpolatedTrajectory.InternalAdditionalAbscissaList = await BuildInternalAdditionalAbscissasForSaveAsync();
            currentInterpolatedTrajectory.LastModificationDate = DateTimeOffset.UtcNow;
            if (interpolatedTrajectoryIdBeingEdited is Guid id)
            {
                await Api.ClientTrajectory.PutInterpolatedTrajectoryByIdAsync(id, currentInterpolatedTrajectory);
                currentInterpolatedTrajectory = await Api.ClientTrajectory.GetInterpolatedTrajectoryByIdAsync(id);
                currentInterpolatedTrajectory.SurveyStationList ??= [];
                ResetCalculatedStationLoadingState();
                Snackbar.Add("Interpolated trajectory updated successfully", Severity.Success);
            }
            else
            {
                currentInterpolatedTrajectory.MetaInfo.ID = currentInterpolatedTrajectory.MetaInfo.ID == Guid.Empty ? Guid.NewGuid() : currentInterpolatedTrajectory.MetaInfo.ID;
                currentInterpolatedTrajectory.CreationDate ??= DateTimeOffset.UtcNow;
                await Api.ClientTrajectory.PostInterpolatedTrajectoryAsync(currentInterpolatedTrajectory);
                currentInterpolatedTrajectory = await Api.ClientTrajectory.GetInterpolatedTrajectoryByIdAsync(currentInterpolatedTrajectory.MetaInfo.ID);
                interpolatedTrajectoryIdBeingEdited = currentInterpolatedTrajectory.MetaInfo.ID;
                currentInterpolatedTrajectory.SurveyStationList ??= [];
                ResetCalculatedStationLoadingState();
                Snackbar.Add("Interpolated trajectory created successfully", Severity.Success);
            }
            selectedTrajectoryId = currentInterpolatedTrajectory.TrajectoryID == Guid.Empty ? null : currentInterpolatedTrajectory.TrajectoryID;
            SyncSelectorsFromTrajectory(selectedTrajectoryId);
            await UpdateReferenceSourcesAsync();
            UpdatePlots();
            MarkInterpolatedTrajectoryClean();
            if (calculatedStationsPanelExpanded_)
            {
                await LoadInterpolatedTrajectoryCalculatedStationsAsync(currentInterpolatedTrajectory);
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error saving interpolated trajectory");
            Snackbar.Add("Error saving interpolated trajectory: " + ex.Message, Severity.Warning);
        }
    }

    private async Task CloseEditorAsync()
    {
        if (HasUnsavedInterpolatedTrajectoryChanges() && !await ConfirmCloseWithoutSavingAsync())
        {
            return;
        }

        await ValueChanged.InvokeAsync();
    }

    private void MarkInterpolatedTrajectoryClean() => cleanInterpolatedTrajectorySnapshot = BuildInterpolatedTrajectoryDirtySnapshot();

    private bool HasUnsavedInterpolatedTrajectoryChanges() =>
        cleanInterpolatedTrajectorySnapshot != null &&
        !string.Equals(cleanInterpolatedTrajectorySnapshot, BuildInterpolatedTrajectoryDirtySnapshot(), StringComparison.Ordinal);

    private string BuildInterpolatedTrajectoryDirtySnapshot()
    {
        return JsonSerializer.Serialize(new
        {
            Id = interpolatedTrajectoryIdBeingEdited,
            InterpolatedTrajectoryId = currentInterpolatedTrajectory.MetaInfo?.ID,
            currentInterpolatedTrajectory.Name,
            currentInterpolatedTrajectory.Description,
            currentInterpolatedTrajectory.CreationDate,
            SelectedFieldId = selectedFieldId,
            SelectedClusterId = selectedClusterId,
            SelectedWellId = selectedWellId,
            SelectedWellBoreId = selectedWellBoreId,
            SelectedTrajectoryId = selectedTrajectoryId,
            currentInterpolatedTrajectory.InterpolationStep,
            currentInterpolatedTrajectory.MaximumChordArcDistance,
            currentInterpolatedTrajectory.InterpolationReferenceDepth,
            currentInterpolatedTrajectory.IncludeFirstSurvey,
            currentInterpolatedTrajectory.IncludeLastSurvey,
            currentInterpolatedTrajectory.InterpolateAtCasingAndLinerShoeDepths,
            currentInterpolatedTrajectory.InterpolateAtLinerHangerDepths,
            currentInterpolatedTrajectory.InterpolateAtCasingChangeOfDiameter,
            AdditionalAbscissas = AdditionalAbscissas
                .Select(abscissa => new { abscissa.Abscissa, abscissa.Annotation })
                .ToList()
        }, DirtySnapshotJsonOptions);
    }

    private async Task<bool> ConfirmCloseWithoutSavingAsync()
    {
        bool? result = await DialogService.ShowMessageBox(
            "Unsaved changes",
            "Some changes have not been saved. Close without saving?",
            yesText: "Close without saving",
            cancelText: "Stay");

        return result == true;
    }

    private Task OnCalculatedStationsPanelExpandedChanged(bool expanded)
    {
        calculatedStationsPanelExpanded_ = expanded;
        if (expanded)
        {
            StartCalculatedStationLoading();
        }

        return Task.CompletedTask;
    }

    private void StartCalculatedStationLoading()
    {
        if (calculatedStationLoadComplete_ || isLoadingCalculatedStations_)
        {
            return;
        }

        _ = LoadInterpolatedTrajectoryCalculatedStationsAsync(currentInterpolatedTrajectory);
    }

    private void ResetCalculatedStationLoadingState()
    {
        calculatedStationLoadComplete_ = false;
        isLoadingCalculatedStations_ = false;
        calculatedStationChunkCount_ = 0;
        calculatedStationChunksLoaded_ = 0;
        calculatedStationsLoaded_ = 0;
    }

    private async Task LoadInterpolatedTrajectoryCalculatedStationsAsync(InterpolatedTrajectory? interpolatedTrajectory)
    {
        if (interpolatedTrajectory?.MetaInfo?.ID is not Guid interpolatedTrajectoryId || interpolatedTrajectoryId == Guid.Empty)
        {
            return;
        }

        isLoadingCalculatedStations_ = true;
        calculatedStationLoadComplete_ = false;
        calculatedStationChunkCount_ = 0;
        calculatedStationChunksLoaded_ = 0;
        calculatedStationsLoaded_ = 0;
        interpolatedTrajectory.SurveyStationList = [];
        await InvokeAsync(StateHasChanged);

        try
        {
            int chunkCount = await Api.ClientTrajectory.GetInterpolatedTrajectorySurveyStationChunkCountAsync(interpolatedTrajectoryId);
            for (int attempt = 0; attempt < 120 && chunkCount <= 0 && (IsCalculationActive(interpolatedTrajectory) || attempt < 3); attempt++)
            {
                currentInterpolatedTrajectory = await Api.ClientTrajectory.GetInterpolatedTrajectoryByIdAsync(interpolatedTrajectoryId);
                currentInterpolatedTrajectory.SurveyStationList = [];
                interpolatedTrajectory = currentInterpolatedTrajectory;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(TimeSpan.FromSeconds(1));
                chunkCount = await Api.ClientTrajectory.GetInterpolatedTrajectorySurveyStationChunkCountAsync(interpolatedTrajectoryId);
            }

            calculatedStationChunkCount_ = chunkCount;
            await InvokeAsync(StateHasChanged);
            if (chunkCount <= 0)
            {
                interpolatedTrajectory.SurveyStationList ??= [];
                calculatedStationLoadComplete_ = true;
                return;
            }

            List<SurveyStation> stations = [];
            for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
            {
                SurveyStationChunk chunk = await Api.ClientTrajectory.GetInterpolatedTrajectorySurveyStationChunkAsync(interpolatedTrajectoryId, chunkIndex);
                if (chunk.SurveyStationList is { Count: > 0 } chunkStations)
                {
                    stations.AddRange(chunkStations);
                }

                calculatedStationChunksLoaded_ = chunkIndex + 1;
                calculatedStationsLoaded_ = stations.Count;
                if (chunkIndex == 0 || calculatedStationChunksLoaded_ == chunkCount || calculatedStationChunksLoaded_ % 5 == 0)
                {
                    await InvokeAsync(StateHasChanged);
                }
            }

            interpolatedTrajectory.SurveyStationList = stations;
            calculatedStationLoadComplete_ = true;
            UpdatePlots();
        }
        finally
        {
            isLoadingCalculatedStations_ = false;
            await InvokeAsync(StateHasChanged);
        }
    }

