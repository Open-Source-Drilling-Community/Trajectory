    private async Task<List<AnnotatedAbscissa>> BuildInternalAdditionalAbscissasForSaveAsync()
    {
        List<AnnotatedAbscissa> values = [];
        Trajectory? selectedTrajectory = await GetSelectedTrajectoryAsync();
        WellBoreArchitecture? architecture = null;

        if (currentInterpolatedTrajectory.IncludeFirstSurvey ||
            currentInterpolatedTrajectory.InterpolateAtCasingAndLinerShoeDepths ||
            currentInterpolatedTrajectory.InterpolateAtLinerHangerDepths ||
            currentInterpolatedTrajectory.InterpolateAtCasingChangeOfDiameter)
        {
            await EnsureWellBoreArchitectureDataLoadedAsync();
            architecture = GetSelectedWellBoreArchitecture(selectedTrajectory);
        }

        if (currentInterpolatedTrajectory.IncludeFirstSurvey)
        {
            AddOrUpdateAnnotatedAbscissa(values, ResolveFirstSurveyOutputMd(selectedTrajectory, architecture), null);
        }

        if (currentInterpolatedTrajectory.IncludeLastSurvey && selectedTrajectory?.SurveyStationList is { Count: > 0 } lastSurveyList)
        {
            AddOrUpdateAnnotatedAbscissa(values, lastSurveyList.LastOrDefault()?.MD, null);
        }

        if (currentInterpolatedTrajectory.InterpolateAtCasingAndLinerShoeDepths ||
            currentInterpolatedTrajectory.InterpolateAtLinerHangerDepths ||
            currentInterpolatedTrajectory.InterpolateAtCasingChangeOfDiameter)
        {
            if (architecture != null)
            {
                if (currentInterpolatedTrajectory.InterpolateAtCasingAndLinerShoeDepths && architecture.CasingSections is { Count: > 0 } casingSections)
                {
                    foreach (CasingSection casingSection in casingSections)
                    {
                        double? topDepth = GetGaussianMean(casingSection?.TopDepth);
                        double? length = GetGaussianMean(casingSection?.Length);
                        double? shoeDepth = topDepth is { } top && length is { } len ? top + len : null;
                        AddOrUpdateAnnotatedAbscissa(values, shoeDepth, BuildCasingAnnotation("Casing shoe", GetCasingSize(casingSection)));
                    }
                }

                if (currentInterpolatedTrajectory.InterpolateAtLinerHangerDepths)
                {
                    double? hangerDepth = GetScalarValue(architecture.WellHead?.CasingHangerDepth);
                    CasingSection? casingSection = FindCasingSectionForDepth(architecture.CasingSections, hangerDepth);
                    AddOrUpdateAnnotatedAbscissa(values, hangerDepth, BuildCasingAnnotation("Casing hanger", GetCasingSize(casingSection)));
                }

                if (currentInterpolatedTrajectory.InterpolateAtCasingChangeOfDiameter && architecture.CasingSections is { Count: > 0 } casingSectionsForChanges)
                {
                    foreach (CasingSection casingSection in casingSectionsForChanges)
                    {
                        AddCasingChangeAnnotations(values, casingSection);
                    }
                }
            }
        }

        return values.OrderBy(x => x.Abscissa).ToList();
    }
