    private string GetCoordinateLabel(PositionDirectionType direction)
    {
        string? positionReferenceName = Parent?.PositionReferenceName ?? DataUtils.UnitAndReferenceParameters.PositionReferenceName;
        if (string.Equals(positionReferenceName, "WGS84", StringComparison.OrdinalIgnoreCase))
        {
            return direction == PositionDirectionType.North ? "Riemann North" : "Riemann East";
        }

        if (string.Equals(positionReferenceName, "Cartographic", StringComparison.OrdinalIgnoreCase))
        {
            return direction == PositionDirectionType.North ? "Northing" : "Easting";
        }

        return direction == PositionDirectionType.North ? "North" : "East";
    }

