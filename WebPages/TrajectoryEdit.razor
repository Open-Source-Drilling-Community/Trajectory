        [
            $"Measured Depth [{Parent?.GetDepthUnitLabel("DepthDrilling")}]",
            $"Inclination [{Parent?.GetUnitLabel("PlaneAngleDrilling")}]",
            $"Azimuth [{Parent?.GetUnitLabel("PlaneAngleDrilling")}]",
            $"Vertical Depth [{Parent?.GetDepthUnitLabel("DepthDrilling")}]",
            $"{NorthCoordinateLabel} [{Parent?.GetUnitLabel("PositionDrilling")}]",
            $"{EastCoordinateLabel} [{Parent?.GetUnitLabel("PositionDrilling")}]",
            $"Vertical Section [{Parent?.GetUnitLabel("DepthDrilling")}]",
            $"Curvature [{Parent?.GetUnitLabel("CurvatureDrilling")}]",
            $"BUR [{Parent?.GetUnitLabel("CurvatureDrilling")}]",
            $"TR [{Parent?.GetUnitLabel("CurvatureDrilling")}]"
        ];

        string content = BuildTabSeparatedContent(
            headers,
            calculatedStations.Select(station => new[]
            {
                ConvertDepthForExport(station.MD),
                ConvertQuantityForExport(station.Inclination, "PlaneAngleDrilling"),
                ConvertQuantityForExport(station.Azimuth, "PlaneAngleDrilling"),
                ConvertDepthForExport(station.TVD),
                ConvertPositionForExport(station.RiemannianNorth, PositionDirectionType.North),
                ConvertPositionForExport(station.RiemannianEast, PositionDirectionType.East),
                ConvertQuantityForExport(station.VerticalSection, "DepthDrilling"),
                ConvertQuantityForExport(station.Curvature, "CurvatureDrilling"),
                ConvertQuantityForExport(station.BUR, "CurvatureDrilling"),
                ConvertQuantityForExport(station.TUR, "CurvatureDrilling")
            }));

        await DownloadExportAsync("calculated-trajectory", content);
    }

    private async Task DownloadExportAsync(string exportName, string content)
    {
        try
        {
            string trajectoryName = string.IsNullOrWhiteSpace(currentTrajectory.Name) ? "trajectory" : currentTrajectory.Name;
            string fileName = $"{SanitizeFileName(trajectoryName)}-{exportName}.tsv";
            string base64Content = Convert.ToBase64String(Encoding.UTF8.GetBytes(content));

            await JSRuntime.InvokeVoidAsync("trajectoryDownloads.saveTextFileFromBase64", fileName, base64Content, "text/tab-separated-values;charset=utf-8");
            Snackbar.Add($"Exported {exportName}", Severity.Success);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error exporting {ExportName}", exportName);
            Snackbar.Add("Error exporting file: " + ex.Message, Severity.Warning);
        }
    }

    private string BuildTabSeparatedContent(IEnumerable<string> headers, IEnumerable<IEnumerable<string>> rows)
    {
        StringBuilder builder = new();
        builder.AppendLine(string.Join('\t', headers.Select(SanitizeExportField)));

        foreach (IEnumerable<string> row in rows)
        {
            builder.AppendLine(string.Join('\t', row.Select(SanitizeExportField)));
        }

        return builder.ToString();
    }

    private string ConvertDepthForExport(double? value) =>
        Parent == null || value is not { } depth
            ? string.Empty
            : NormalizeExportNumber(Parent.FromWGS84DepthSI(depth, "DepthDrilling", false));

    private string ConvertPositionForExport(double? value, PositionDirectionType direction)
    {
        if (Parent == null || value is not { } position || direction == PositionDirectionType.Independent)
        {
            return string.Empty;
        }

        double converted = Parent.FromWGS84PositionSI(position, "PositionDrilling", direction);
        return double.IsNaN(converted)
            ? string.Empty
            : NormalizeExportNumber(converted.ToString(CultureInfo.CurrentCulture));
    }

    private string ConvertQuantityForExport(double? value, string quantityName) =>
        Parent == null || value is not { } quantityValue
            ? string.Empty
            : NormalizeExportNumber(Parent.FromSI(quantityValue, quantityName, false));

    private static string NormalizeExportNumber(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        string trimmed = value.Trim()
            .Replace("\u00A0", string.Empty, StringComparison.Ordinal)
            .Replace(" ", string.Empty, StringComparison.Ordinal);

        if (double.TryParse(trimmed, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.CurrentCulture, out double parsed) ||
            double.TryParse(trimmed, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out parsed) ||
            double.TryParse(trimmed, NumberStyles.Float | NumberStyles.AllowThousands, new CultureInfo("nb-NO"), out parsed))
        {
            return parsed.ToString("G17", CultureInfo.InvariantCulture);
        }

        return trimmed.Replace(',', '.');
    }

    private static string SanitizeExportField(string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            return string.Empty;
        }

        string sanitized = value
            .Replace("\r", " ", StringComparison.Ordinal)
            .Replace("\n", " ", StringComparison.Ordinal)
            .Replace("\t", " ", StringComparison.Ordinal)
            .Trim();

        sanitized = sanitized
            .Replace("°", "deg", StringComparison.Ordinal)
            .Replace("µ", "u", StringComparison.Ordinal)
            .Replace("μ", "u", StringComparison.Ordinal);

        StringBuilder ascii = new(sanitized.Length);
        foreach (char c in sanitized)
        {
            ascii.Append(c <= sbyte.MaxValue ? c : '?');
        }

        return ascii.ToString();
    }

    private static string SanitizeFileName(string fileName)
    {
        char[] invalidChars = Path.GetInvalidFileNameChars();
        StringBuilder builder = new(fileName.Length);

        foreach (char c in fileName)
        {
            builder.Append(invalidChars.Contains(c) ? '-' : c);
        }

        return builder.ToString().Trim();
    }

    private void AddSurveyStation()
    {
        double? lastMD = 0.0;
        if (currentTrajectory.SurveyStationList.Count > 0)
            lastMD = currentTrajectory.SurveyStationList.Last().MD;
        currentTrajectory.SurveyStationList.Add(new SurveyStation() { MD = lastMD + 10 * currentTrajectory.MDStep, Inclination = 0, Azimuth = 0 });
    }
    private void DeleteSurveyStation(SurveyStation station)
    {
        currentTrajectory.SurveyStationList.Remove(station);
    }
    private void DeleteSurveyStations()
    {
        foreach (SurveyStation point in selectedSurveyStations)
            DeleteSurveyStation(point);
    }
    private bool IsValidTrajectory(Trajectory traj)
    {
        bool success = false;
        if (traj.MDStep > 0.0 && traj.SurveyStationList is { Count: > 2 } ssList)
        {
            success = true;
            foreach (var ss in ssList)
                success &= ss.MD is { } && ss.Inclination is { } && ss.Azimuth is { };
        }
        return success;
    }
    private async Task InitializeTrajectoryAsync(Trajectory traj)
    {
        try
        {
            traj.WellBoreID = Guid.Empty;
            if (traj.MDStep == 0.0)
                traj.MDStep = 10.0;
            traj.SurveyStationList.Clear();
            traj.SurveyStationList.Add(new SurveyStation() { MD = 0, Inclination = 0, Azimuth = 0, RiemannianNorth = 0, RiemannianEast = 0, TVD = 0 });
            traj.SurveyStationList.Add(new SurveyStation() { MD = 10 * traj.MDStep, Inclination = 0, Azimuth = 0 });
            traj.SurveyStationList.Add(new SurveyStation() { MD = 20 * traj.MDStep, Inclination = 0, Azimuth = 0 });
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Exception raised at initialization of trajectory");
            Snackbar.Add("Exception raised at initialization of trajectory", Severity.Error);
        }
    }

