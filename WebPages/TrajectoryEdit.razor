@inject ILogger<TrajectoryEdit> logger
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject ITrajectoryAPIUtils Api
@using System.Net.Http.Json
@using System.Globalization
@using System.Reflection
@using System.Text
@using System.Text.RegularExpressions

<MudText Class="mt-4 mb-4" Typo="Typo.h6">Edit Trajectory</MudText>
<MudContainer Class="d-flex flex-row mt-4 mb-4">
    <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Secondary" OnClick="DuplicateTrajectory">Duplicate</MudButton>
    <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveTrajectory">Save</MudButton>
    <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="SendMessage">Cancel</MudButton>
</MudContainer>

@if (currentTrajectory is { } traj)
{
    @* General information *@
    <MudGrid>
        <MudItem xs="3">
            <MudTextField @bind-Value="traj.Name" Label="Name" Required="true" For="@(() => traj.Name)" ShrinkLabel />
        </MudItem>
        <MudItem xs="3">
            <MudTextField @bind-Value="traj.Description" Label="Description" For="@(() => traj.Description)" ShrinkLabel />
        </MudItem>
        <MudItem xs="3">
            <MudTextField Value="@FormatDate(traj.CreationDate)" Label="Created" ReadOnly="true" ShrinkLabel />
        </MudItem>
        <MudItem xs="3">
            <MudTextField Value="@FormatDate(traj.LastModificationDate)" Label="Last Updated" ReadOnly="true" ShrinkLabel />
        </MudItem>
        <MudItem xs="2">
            <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId" ValueChanged="OnFieldChanged" ShrinkLabel Clearable="true">
                @if (AvailableFields.Count > 0)
                {
                    @foreach (Field field in AvailableFields)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">
                            @field.Name
                        </MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="2">
            <MudSelect Label="Cluster" T="Guid?" Value="@selectedClusterId" ValueChanged="OnClusterChanged" ShrinkLabel Clearable="true">
                @if (AvailableClusters.Count > 0)
                {
                    @foreach (Cluster cluster in AvailableClusters)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">
                            @cluster.Name
                        </MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="2">
            <MudSelect Label="Well" T="Guid?" Value="@selectedWellId" ValueChanged="OnWellChanged" ShrinkLabel Clearable="true">
                @if (AvailableWells.Count > 0)
                {
                    @foreach (Well well in AvailableWells)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">
                            @well.Name
                        </MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="3">
            <MudSelect Label="WellBore" T="Guid?" Value="@selectedWellBoreId" ValueChanged="OnWellBoreChanged" ShrinkLabel Clearable="true">
                @if (AvailableWellBores.Count > 0)
                {
                    @foreach (WellBore wb in AvailableWellBores)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)wb.MetaInfo.ID)">
                            @wb.Name
                        </MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="3">
            <MudTextField Value="@AssociatedRigName" Label="Rig" ReadOnly="true" ShrinkLabel />
        </MudItem>
        <MudItem xs="3">
            <MudSelect T="TrajectoryType" Label="Type" Value="@traj.TrajectoryType" ValueChanged="OnTrajectoryTypeChanged" ShrinkLabel>
                @foreach (TrajectoryType trajectoryType in TrajectoryTypes)
                {
                    <MudSelectItem T="TrajectoryType" Value="@trajectoryType">@trajectoryType</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="3" Class="d-flex align-center">
            <MudTooltip Text="@DefinitiveTooltipText">
                <div>
                    <MudCheckBox T="bool" @bind-Value="traj.IsDefinitive" Label="Definitive" Color="Color.Primary" Disabled="@IsDefinitiveChoiceDisabled" />
                </div>
            </MudTooltip>
        </MudItem>
    </MudGrid>
    <MudExpansionPanels Class="mt-4 mb-4" Style="overflow-y: auto; max-height: none;">
        @* Survey run sections *@
        <MudExpansionPanel Text="Survey run sections" @bind-IsExpanded="isSurveyExpanded">
            <MudToolBar>
                <MudText Typo="Typo.h6">Survey run sections</MudText>
                <MudSpacer />
                <MudButton OnClick="@AddSurveyRunSection" Color="@Color.Success" Class="add-item-btn"
                           Disabled="@(!AvailableSurveyRuns.Any())">Add</MudButton>
                <MudButton OnClick="@DeleteSurveyRunSections" Color="@Color.Error" Class="add-item-btn"
                           Disabled="@(!selectedSurveyRunSections.Any())">Delete</MudButton>
            </MudToolBar>
            @if (!AvailableSurveyRuns.Any())
            {
                <MudText>No Survey Runs are available for the selected WellBore.</MudText>
            }
            <MudTable Items="@TrajectorySurveyRunSections" MultiSelection="true" T="TrajectorySurveyRunSection"
                      @bind-SelectedItems="selectedSurveyRunSections"
                      Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true">
                <HeaderContent>
                    <MudTHeadRow IsCheckable="true">
                        <MudTh>Survey Run</MudTh>
                        <MudTh>Start Abscissa [@Parent?.GetUnitLabel("DepthDrilling")]</MudTh>
                        <MudTh />
                    </MudTHeadRow>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Survey Run">
                        <MudSelect T="Guid?" Value="@((Guid?)context.SurveyRunID)" ValueChanged="@(value => OnSurveyRunSectionSurveyRunChanged(context, value))" ShrinkLabel Dense="true">
                            @foreach (SurveyRunLight surveyRun in AvailableSurveyRuns)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)surveyRun.MetaInfo.ID)">@GetSurveyRunDisplayName(surveyRun)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd DataLabel="Start Abscissa">
                        <MudInputWithUnit QuantityName="DepthDrilling"
                                          SIValueNullable="@context.StartAbscissa"
                                          SIValueNullableChanged="@(value => OnSurveyRunSectionStartChanged(context, value))" />
                    </MudTd>
                    <MudTd>
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="(() => DeleteSurveyRunSection(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudExpansionPanel>
        @* Calculated trajectory *@
            <MudExpansionPanel Text="Calculated trajectory" ExpandedChanged="@OnCalculatedStationsPanelExpandedChanged">
            <MudToolBar>
                <MudText Typo="Typo.h6">Calculated trajectory</MudText>
                <MudSpacer />
                <MudButton OnClick="ExportCalculatedTrajectoryAsync" Color="@Color.Primary" Variant="Variant.Outlined" Disabled="@isLoadingCalculatedStations_">Export</MudButton>
            </MudToolBar>
            <MudGrid Class="mb-4">
                <MudItem xs="12" md="5">
                    <MudSelect T="TrajectoryCalculationType" Label="Trajectory calculation type" Value="@traj.CalculationType" ValueChanged="OnCalculationTypeChanged" ShrinkLabel>
                        @foreach (TrajectoryCalculationType method in TrajectoryCalculationTypes)
                        {
                            <MudSelectItem T="TrajectoryCalculationType" Value="@method">@GetCalculationMethodLabel(method)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            @if (CalculatedTieInPoint is { } tieInPoint)
            {
                <MudGrid Class="mb-4">
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle1">Tie in point</MudText>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudText>Measured Depth: @FormatDepthValue(tieInPoint.MD)</MudText>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudText>Inclination: @FormatAngleValue(tieInPoint.Inclination)</MudText>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudText>Azimuth: @FormatAngleValue(tieInPoint.Azimuth)</MudText>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudText>Vertical Depth: @FormatDepthValue(tieInPoint.TVD)</MudText>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudText>@NorthCoordinateLabel: @FormatPositionValue(tieInPoint.RiemannianNorth, PositionDirectionType.North)</MudText>
                    </MudItem>
                    <MudItem xs="6" md="2">
                        <MudText>@EastCoordinateLabel: @FormatPositionValue(tieInPoint.RiemannianEast, PositionDirectionType.East)</MudText>
                    </MudItem>
                </MudGrid>
            }
            @if (isLoadingCalculatedStations_)
            {
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.body2">@CalculatedStationLoadingText</MudText>
                    <MudProgressLinear Value="@CalculatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                </MudPaper>
            }
            else if (traj.SurveyStationList is { Count: > 0 } calculatedList)
            {
                <MudTable Items="@calculatedList" T="SurveyStation" Height="400px" FixedHeader="true"
                          Virtualize="true" OverscanCount="3" ItemSize="38"
                          Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true" ReadOnly="true">
                    <HeaderContent>
                        <MudTHeadRow>
                            <MudTh>Measured Depth [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                            <MudTh>Inclination [@Parent?.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                            <MudTh>Azimuth [@Parent?.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                            <MudTh>Vertical Depth [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                            <MudTh>@NorthCoordinateLabel [@Parent?.GetUnitLabel("PositionDrilling")]</MudTh>
                            <MudTh>@EastCoordinateLabel [@Parent?.GetUnitLabel("PositionDrilling")]</MudTh>
                            <MudTh>Vertical Section [@Parent?.GetUnitLabel("DepthDrilling")]</MudTh>
                            <MudTh>Curvature [@Parent?.GetUnitLabel("CurvatureDrilling")]</MudTh>
                            <MudTh>BUR [@Parent?.GetUnitLabel("CurvatureDrilling")]</MudTh>
                            <MudTh>TR [@Parent?.GetUnitLabel("CurvatureDrilling")]</MudTh>
                        </MudTHeadRow>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Measured Depth">
                            <MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.MD" />
                        </MudTd>
                        <MudTd DataLabel="Inclination">
                            <MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Inclination" />
                        </MudTd>
                        <MudTd DataLabel="Azimuth">
                            <MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Azimuth" />
                        </MudTd>
                        <MudTd DataLabel="Vertical Depth">
                            <MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.TVD" />
                        </MudTd>
                        <MudTd DataLabel="@NorthCoordinateLabel">
                            <MudSpanWithUnit QuantityName="PositionDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Position" PositionDirection="@PositionDirectionType.North" SIValue="@context.RiemannianNorth" />
                        </MudTd>
                        <MudTd DataLabel="@EastCoordinateLabel">
                            <MudSpanWithUnit QuantityName="PositionDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Position" PositionDirection="@PositionDirectionType.East" SIValue="@context.RiemannianEast" />
                        </MudTd>
                        <MudTd DataLabel="Vertical Section">
                            <MudSpanWithUnit QuantityName="DepthDrilling" SIValue="@context.VerticalSection" />
                        </MudTd>
                        <MudTd DataLabel="Curvature">
                            <MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.Curvature" />
                        </MudTd>
                        <MudTd DataLabel="BUR">
                            <MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.BUR" />
                        </MudTd>
                        <MudTd DataLabel="TR">
                            <MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.TUR" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudText>No calculated trajectory</MudText>
            }
        </MudExpansionPanel>
        <MudExpansionPanel Text="Uncertainty ellipses" ExpandedChanged="@OnCalculatedStationsPanelExpandedChanged">
            @if (isLoadingCalculatedStations_)
            {
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.body2">@CalculatedStationLoadingText</MudText>
                    <MudProgressLinear Value="@CalculatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                </MudPaper>
            }
            else if (traj.SurveyStationList is { Count: > 0 } calculatedList)
            {
                <SurveyStationEllipseTable SurveyStationList="@calculatedList"
                                           CalculationName="@($"{traj.Name} uncertainty ellipses")"
                                           EllipseResultsChanged="OnEllipseResultsChanged" />
            }
            else
            {
                <MudText>No calculated trajectory</MudText>
            }
        </MudExpansionPanel>
        @* Plot trajectory *@
        <MudExpansionPanel Text="Plot trajectory" ExpandedChanged="@OnPlotExpandedChanged"
                           Style="overflow: visible;">
            @if (isLoadingCalculatedStations_)
            {
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.body2">@CalculatedStationLoadingText</MudText>
                    <MudProgressLinear Value="@CalculatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                </MudPaper>
            }
            else if (traj.SurveyStationList is { Count: > 0 } ssList)
            {
                <MudToolBar>
                    <MudText Typo="Typo.h6">Plot</MudText>
                </MudToolBar>
                <MudGrid Justify="Justify.Center">
                    <MudItem xs="12">
                        <Scatter3DPlot NameList="@ThreeDNameList" ModeFlagList="@ThreeDModeFlagList" ColorList="@ThreeDColorList"
                                       ShowLegendList="@ThreeDShowLegendList"
                                       XValuesList="@ThreeDNorthValuesList" YValuesList="@ThreeDEastValuesList" ZValuesList="@ThreeDTvdValuesList"
                                       YAxisReversed="@true" ZAxisReversed="@true"
                                       PlotTitle="" XAxisTitle="@NorthCoordinateLabel" YAxisTitle="@EastCoordinateLabel" ZAxisTitle="TVD"
                                       XUnit="PositionDrilling" YUnit="PositionDrilling" ZUnit="DepthDrilling"
                                       XAxisUsesPositionReference="@true"
                                       YAxisUsesPositionReference="@true"
                                       ZAxisUsesDepthReference="@true"
                                       XAxisPositionDirection="@PositionDirectionType.North"
                                       YAxisPositionDirection="@PositionDirectionType.East">
                        </Scatter3DPlot>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <ScatterPlot NameList="@HorizontalNameList" ModeFlagList="@HorizontalModeFlagList" ColorList="@HorizontalColorList"
                                     ShowLegendList="@HorizontalShowLegendList"
                                     XValuesList="@HorizontalEastValuesList" YValuesList="@HorizontalNorthValuesList"
                                     PlotTitle="" XAxisTitle="@EastCoordinateLabel" YAxisTitle="@NorthCoordinateLabel"
                                     XUnit="PositionDrilling" YUnit="PositionDrilling"
                                     XAxisUsesPositionReference="@true"
                                     YAxisUsesPositionReference="@true"
                                     XAxisPositionDirection="@PositionDirectionType.East"
                                     YAxisPositionDirection="@PositionDirectionType.North"
                                     AspectRatio="1">
                        </ScatterPlot>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <ScatterPlot NameList="@VerticalNameList" ModeFlagList="@VerticalModeFlagList" ColorList="@VerticalColorList"
                                     ShowLegendList="@VerticalShowLegendList"
                                     XValuesList="@VerticalSectionValuesList" YValuesList="@VerticalTvdValuesList"
                                     PlotTitle="" XAxisTitle="Vertical Section" YAxisTitle="TVD"
                                     XUnit="DepthDrilling" YUnit="DepthDrilling"
                                     XAxisStartsAtZero="@true"
                                     YAxisUsesDepthReference="@true"
                                     YAxisReversed="@true"
                                     AspectRatio="1">
                        </ScatterPlot>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText>No calculated trajectory</MudText>
            }
        </MudExpansionPanel>
    </MudExpansionPanels>
}

@code {
    [CascadingParameter]
    private MudUnitAndReferenceChoiceTag? Parent { get; set; }
    [Parameter]
    public Guid? TrajectoryId { get; set; }
    [Parameter]
    public List<Rig>? RigList { get; set; }
    [Parameter]
    public List<WellBoreArchitectureLight>? WellBoreArchitectureList { get; set; }
    [Parameter]
    public List<WellBore>? WellBoreList { get; set; }
    [Parameter]
    public List<Well>? WellList { get; set; }
    [Parameter]
    public List<Cluster>? ClusterList { get; set; }
    [Parameter]
    public List<Field>? FieldList { get; set; }
    [Parameter]
    public List<TrajectoryLight>? TrajectoryList { get; set; }
    [Parameter]
    public EventCallback ValueChanged { get; set; }

    private Trajectory currentTrajectory = PseudoConstructors.ConstructTrajectory();
    private HashSet<SurveyStation> selectedSurveyStations = new();
    private HashSet<TrajectorySurveyRunSection> selectedSurveyRunSections = new();
    private bool isSurveyExpanded = false;
    private bool isInterpolExpanded = false;
    private bool isPlotExpanded = false;
    private Guid? selectedFieldId;
    private Guid? selectedClusterId;
    private Guid? selectedWellId;
    private Guid? selectedWellBoreId;
    private static readonly TrajectoryType[] TrajectoryTypes = Enum.GetValues<TrajectoryType>();
    private static readonly TrajectoryCalculationType[] TrajectoryCalculationTypes = Enum.GetValues<TrajectoryCalculationType>();
    private static readonly string[] CalculationMethods =
    [
        "Minimum Curvature Method",
        "Constant Build and Turn Rates",
        "Constant Curvature and Toolface"
    ];
    private bool interpolateAtCasingAndLinerShoeDepths;
    private bool interpolateAtLinerHangingDepths;
    private bool interpolateAtCasingDiameterChangeDepths;
    private double? supplementaryInterpolationDepthInput;
    private List<double> supplementaryInterpolationDepths = [];
    private IBrowserFile? surveyImportFile;
    private string surveyImportFileName = "No file selected";
    private string selectedSurveyImportFormat = "Separated";
    private static readonly string[] SurveyImportFormats = ["Separated", "Fixed width"];
    private string selectedSurveyImportSeparator = "Semicolon (;)";
    private static readonly string[] SurveyImportSeparators = ["Semicolon (;)", "Tab", "Space"];
    private string selectedSurveyImportDecimalMarker = "Auto";
    private static readonly string[] SurveyImportDecimalMarkers = ["Auto", "Dot (.)", "Comma (,)"];
    private string selectedSurveyImportMDUnit = string.Empty;
    private string selectedSurveyImportInclinationUnit = string.Empty;
    private string selectedSurveyImportAzimuthUnit = string.Empty;
    private int surveyImportMDColumn = 1;
    private int surveyImportInclinationColumn = 2;
    private int surveyImportAzimuthColumn = 3;
    private int surveyImportMDStart = 1;
    private int surveyImportMDWidth = 12;
    private int surveyImportInclinationStart = 13;
    private int surveyImportInclinationWidth = 12;
    private int surveyImportAzimuthStart = 25;
    private int surveyImportAzimuthWidth = 12;
    private string selectedInterpolatedCalculationMethod = "Minimum Curvature Method";
    private List<WellBoreArchitecture>? wellBoreArchitectureHeavyList;
    private bool isLoadingWellBoreArchitectureData;
    private List<SurveyRunLight> surveyRunList = [];
    private bool isLoadingCalculatedStations_;
    private bool calculatedStationLoadComplete_;
    private int calculatedStationChunkCount_;
    private int calculatedStationChunksLoaded_;
    private int calculatedStationsLoaded_;

    // Plot variables
    string[] colorScale = { "black", "blue", "grey", "red", "orange", "green", "yellow", "pink", "brown", "purple" };
    List<string> nameList = new List<string>(); //name of each curve in the list to plot
    List<int> modeFlagList = new List<int>(); //modeFlag of each curve in the list to plot (1 = lines; 2 = markers)
    List<string> colorList = new List<string>(); //color of each curve in the list of curves to plot
    List<List<object>> northValuesList = new List<List<object>>(); //North values for the list of curves to plot
    List<List<object>> eastValuesList = new List<List<object>>(); //East values for the list of curves to plot
    List<List<object>> TVDValuesList = new List<List<object>>(); //TVD values for the list of curves to plot
    List<List<object>> verticalSectionValuesList = new List<List<object>>(); //Vertical section values for the list of curves to plot
    private readonly EllipsePlotData ellipsePlotData = new();
    private List<SurveyStationEllipseResult> ellipseResults = [];

    private List<string> HorizontalNameList => Combine(nameList, ellipsePlotData.HorizontalNameList);
    private List<int> HorizontalModeFlagList => Combine(modeFlagList, ellipsePlotData.HorizontalModeFlagList);
    private List<string> HorizontalColorList => Combine(colorList, ellipsePlotData.HorizontalColorList);
    private List<bool> HorizontalShowLegendList => CombineLegendFlags(nameList.Count, ellipsePlotData.HorizontalShowLegendList);
    private List<List<object>> HorizontalEastValuesList => Combine(eastValuesList, ellipsePlotData.HorizontalEastValuesList);
    private List<List<object>> HorizontalNorthValuesList => Combine(northValuesList, ellipsePlotData.HorizontalNorthValuesList);

    private List<string> VerticalNameList => Combine(nameList, ellipsePlotData.VerticalNameList);
    private List<int> VerticalModeFlagList => Combine(modeFlagList, ellipsePlotData.VerticalModeFlagList);
    private List<string> VerticalColorList => Combine(colorList, ellipsePlotData.VerticalColorList);
    private List<bool> VerticalShowLegendList => CombineLegendFlags(nameList.Count, ellipsePlotData.VerticalShowLegendList);
    private List<List<object>> VerticalSectionValuesList => Combine(verticalSectionValuesList, ellipsePlotData.VerticalSectionValuesList);
    private List<List<object>> VerticalTvdValuesList => Combine(TVDValuesList, ellipsePlotData.VerticalTvdValuesList);

    private List<string> ThreeDNameList => Combine(nameList, ellipsePlotData.PerpendicularNameList);
    private List<int> ThreeDModeFlagList => Combine(modeFlagList, ellipsePlotData.PerpendicularModeFlagList);
    private List<string> ThreeDColorList => Combine(colorList, ellipsePlotData.PerpendicularColorList);
    private List<bool> ThreeDShowLegendList => CombineLegendFlags(nameList.Count, ellipsePlotData.PerpendicularShowLegendList);
    private List<List<object>> ThreeDNorthValuesList => Combine(northValuesList, ellipsePlotData.PerpendicularNorthValuesList);
    private List<List<object>> ThreeDEastValuesList => Combine(eastValuesList, ellipsePlotData.PerpendicularEastValuesList);
    private List<List<object>> ThreeDTvdValuesList => Combine(TVDValuesList, ellipsePlotData.PerpendicularTvdValuesList);

    private static List<T> Combine<T>(IEnumerable<T> first, IEnumerable<T> second) => first.Concat(second).ToList();
    private static List<bool> CombineLegendFlags(int baseTraceCount, IEnumerable<bool> ellipseFlags) =>
        Enumerable.Repeat(true, baseTraceCount).Concat(ellipseFlags).ToList();
    private double CalculatedStationLoadingProgressPercent =>
        calculatedStationChunkCount_ <= 0 ? 0.0 : 100.0 * calculatedStationChunksLoaded_ / calculatedStationChunkCount_;
    private string CalculatedStationLoadingText =>
        calculatedStationChunkCount_ <= 0
            ? "Loading calculated trajectory chunks..."
            : $"Loading calculated trajectory chunks {calculatedStationChunksLoaded_}/{calculatedStationChunkCount_} ({calculatedStationsLoaded_:N0} stations)";

    // Lifecycle
    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    /// <summary>
    /// Loads (or reloads) the trajectory independently of the Blazor lifecycle hook.
    /// Always call this for refreshes — never call OnInitializedAsync() directly.
    /// </summary>
    private async Task LoadDataAsync()
    {
        try
        {
            supplementaryInterpolationDepthInput = null;
            supplementaryInterpolationDepths.Clear();
            interpolateAtCasingAndLinerShoeDepths = false;
            interpolateAtLinerHangingDepths = false;
            interpolateAtCasingDiameterChangeDepths = false;

            if (WellBoreList == null || WellBoreList.Count == 0)
            {
                logger.LogError("No wellbore available on loading/initialization of trajectory");
                return;
            }
            if (TrajectoryId != null)
            {
                currentTrajectory = await Api.ClientTrajectory.GetTrajectoryByIdAsync(TrajectoryId.Value);
                currentTrajectory.SurveyStationList ??= [];
                ResetCalculatedStationLoadingState();
            }
            else
            {
                await InitializeTrajectoryAsync(currentTrajectory);
                ResetCalculatedStationLoadingState();
            }
            currentTrajectory.SurveyRunSectionList ??= new List<TrajectorySurveyRunSection>();
            currentTrajectory.SurveyStationList ??= new List<SurveyStation>();
            surveyRunList = ((IEnumerable<SurveyRunLight>)await Api.ClientTrajectory.GetAllSurveyRunLightAsync())
                .Where(surveyRun => surveyRun?.MetaInfo != null)
                .OrderBy(surveyRun => surveyRun.Name)
                .ToList();
            SyncSelectorsFromWellBore(currentTrajectory.WellBoreID);
            EnsureSurveyImportUnitsSelected();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while loading the selected Trajectory");
            return;
        }
        //Plot is updated at each reload of the Single Page Application to make sure the chart is not disposed
        UpdatePlots();
        await InvokeAsync(() => { StateHasChanged(); });
    }

    //Send message to parent component
    private async Task SendMessage()
    {
        await ValueChanged.InvokeAsync();
    }
    //Add/Edit panel controls
    private async Task SaveTrajectory()
    {
        try
        {
            if (currentTrajectory is { } && IsValidTrajectory(currentTrajectory))
            {
                ApplySelectedContext();
                NormalizeSurveyRunSections();
                if (TrajectoryId != null)
                {
                    currentTrajectory.LastModificationDate = DateTimeOffset.UtcNow;
                    await Api.ClientTrajectory.PutTrajectoryByIdAsync(TrajectoryId.Value, currentTrajectory);
                    currentTrajectory = await Api.ClientTrajectory.GetTrajectoryByIdAsync(TrajectoryId.Value);
                    currentTrajectory.SurveyStationList ??= [];
                    ResetCalculatedStationLoadingState();
                    Snackbar.Add("Trajectory updated successfully", Severity.Success);
                    await SendMessage();
                }
                else
                {
                    // voluntarily mutating current trajectory which has not been posted yet
                    currentTrajectory.MetaInfo.ID = Guid.NewGuid();
                    currentTrajectory.CreationDate = DateTimeOffset.UtcNow;
                    currentTrajectory.LastModificationDate = DateTimeOffset.UtcNow;
                    await Api.ClientTrajectory.PostTrajectoryAsync(currentTrajectory);
                    currentTrajectory = await Api.ClientTrajectory.GetTrajectoryByIdAsync(currentTrajectory.MetaInfo.ID);
                    currentTrajectory.SurveyStationList ??= [];
                    ResetCalculatedStationLoadingState();
                    Snackbar.Add("Trajectory created successfully", Severity.Success);
                    await SendMessage();
                }
            }
            else
            {
                Snackbar.Add("Trajectory badly configured (select a WellBore and define an ordered list of Survey Run sections)", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error saving Trajectory");
            Snackbar.Add("Error saving Trajectory: " + ex.Message, Severity.Warning);
        }
    }

    private Task OnCalculatedStationsPanelExpandedChanged(bool expanded)
    {
        if (expanded)
        {
            StartCalculatedStationLoading();
        }

        return Task.CompletedTask;
    }

    private void StartCalculatedStationLoading()
    {
        if (calculatedStationLoadComplete_ || isLoadingCalculatedStations_)
        {
            return;
        }

        _ = LoadTrajectoryCalculatedStationsAsync(currentTrajectory);
    }

    private void ResetCalculatedStationLoadingState()
    {
        calculatedStationLoadComplete_ = false;
        isLoadingCalculatedStations_ = false;
        calculatedStationChunkCount_ = 0;
        calculatedStationChunksLoaded_ = 0;
        calculatedStationsLoaded_ = 0;
    }

    private async Task LoadTrajectoryCalculatedStationsAsync(Trajectory? trajectory)
    {
        if (trajectory?.MetaInfo?.ID is not Guid trajectoryId || trajectoryId == Guid.Empty)
        {
            return;
        }

        isLoadingCalculatedStations_ = true;
        calculatedStationLoadComplete_ = false;
        calculatedStationChunkCount_ = 0;
        calculatedStationChunksLoaded_ = 0;
        calculatedStationsLoaded_ = 0;
        trajectory.SurveyStationList = [];
        await InvokeAsync(StateHasChanged);

        try
        {
            int chunkCount = await Api.ClientTrajectory.GetTrajectorySurveyStationChunkCountAsync(trajectoryId);
            calculatedStationChunkCount_ = chunkCount;
            await InvokeAsync(StateHasChanged);
            if (chunkCount <= 0)
            {
                trajectory.SurveyStationList ??= [];
                calculatedStationLoadComplete_ = true;
                return;
            }

            List<SurveyStation> stations = [];
            for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
            {
                SurveyStationChunk chunk = await Api.ClientTrajectory.GetTrajectorySurveyStationChunkAsync(trajectoryId, chunkIndex);
                if (chunk.SurveyStationList is { Count: > 0 } chunkStations)
                {
                    stations.AddRange(chunkStations);
                }

                calculatedStationChunksLoaded_ = chunkIndex + 1;
                calculatedStationsLoaded_ = stations.Count;
                if (chunkIndex == 0 || calculatedStationChunksLoaded_ == chunkCount || calculatedStationChunksLoaded_ % 5 == 0)
                {
                    await InvokeAsync(StateHasChanged);
                }
            }

            trajectory.SurveyStationList = stations;
            calculatedStationLoadComplete_ = true;
            UpdatePlots();
        }
        finally
        {
            isLoadingCalculatedStations_ = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task DuplicateTrajectory()
    {
        try
        {
            if (currentTrajectory is { } && IsValidTrajectory(currentTrajectory))
            {
                ApplySelectedContext();
                NormalizeSurveyRunSections();
                Trajectory newTraj = DeepCopyTrajectory(currentTrajectory);
                var nowDate = DateTimeOffset.UtcNow;
                newTraj.CreationDate = nowDate;
                newTraj.LastModificationDate = nowDate;
                newTraj.MetaInfo.ID = Guid.NewGuid();
                newTraj.Name += "-copy";
                await Api.ClientTrajectory.PostTrajectoryAsync(newTraj);
                Snackbar.Add("Trajectory duplicated successfully", Severity.Success);
                await SendMessage();
            }
            else
            {
                Snackbar.Add("Trajectory badly configured (select a WellBore and define an ordered list of Survey Run sections)", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error duplicating Trajectory");
            Snackbar.Add("Error duplicating Trajectory: " + ex.Message, Severity.Warning);
        }
    }

