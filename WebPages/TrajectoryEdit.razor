            Name = source.Name,
            Description = source.Description,
            CreationDate = source.CreationDate,
            LastModificationDate = source.LastModificationDate,
            FieldID = source.FieldID,
            ClusterID = source.ClusterID,
            WellID = source.WellID,
            WellBoreID = source.WellBoreID,
            TrajectoryType = source.TrajectoryType,
            IsDefinitive = false,
            CalculationType = source.CalculationType,
            MDStep = source.MDStep,
            SurveyRunSectionList = source.SurveyRunSectionList?
                .Select(section => new TrajectorySurveyRunSection
                {
                    SurveyRunID = section.SurveyRunID,
                    StartAbscissa = section.StartAbscissa
