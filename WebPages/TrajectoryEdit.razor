    private async Task ImportSurveyStationsAsync()
    {
        if (surveyImportFile == null)
        {
            Snackbar.Add("Select a survey file before importing", Severity.Warning);
            return;
        }

        try
        {
            using System.IO.Stream stream = surveyImportFile.OpenReadStream(10 * 1024 * 1024);
            using System.IO.StreamReader reader = new(stream);
            string content = await reader.ReadToEndAsync();
            string[] lines = content.Split(["\r\n", "\n", "\r"], StringSplitOptions.None);

            List<SurveyStation> importedStations = [];
            int skippedLines = 0;
            double? previousMD = null;

            foreach (string line in lines)
            {
                if (!TryParseSurveyStationLine(line, out SurveyStation? station))
                {
                    skippedLines++;
                    continue;
                }

                if (station?.MD is not { } md)
                {
                    skippedLines++;
                    continue;
                }

                if (previousMD is { } lastMD && md <= lastMD)
                {
                    skippedLines++;
                    continue;
                }

                importedStations.Add(station);
                previousMD = md;
            }

            if (importedStations.Count < 3)
            {
                Snackbar.Add("Survey import failed: fewer than 3 valid survey stations were found", Severity.Warning);
                return;
            }

            currentTrajectory.SurveyStationList = importedStations;
            selectedSurveyStations.Clear();
            UpdatePlots();
            Snackbar.Add($"Imported {importedStations.Count} survey stations. Skipped {skippedLines} lines.", Severity.Success);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error importing survey stations");
            Snackbar.Add("Error importing survey stations: " + ex.Message, Severity.Warning);
        }
    }

    private bool TryParseSurveyStationLine(string line, out SurveyStation? station)
    {
        station = null;
        if (string.IsNullOrWhiteSpace(line))
        {
            return false;
        }

        string? mdToken;
        string? inclinationToken;
        string? azimuthToken;

        if (IsFixedWidthImportFormat)
        {
            mdToken = ReadFixedWidthToken(line, surveyImportMDStart, surveyImportMDWidth);
            inclinationToken = ReadFixedWidthToken(line, surveyImportInclinationStart, surveyImportInclinationWidth);
            azimuthToken = ReadFixedWidthToken(line, surveyImportAzimuthStart, surveyImportAzimuthWidth);
        }
        else
        {
            List<string> columns = SplitDelimitedColumns(line);
            mdToken = ReadColumnToken(columns, surveyImportMDColumn);
            inclinationToken = ReadColumnToken(columns, surveyImportInclinationColumn);
            azimuthToken = ReadColumnToken(columns, surveyImportAzimuthColumn);
        }

        if (!TryParseImportedNumber(mdToken, out double md) ||
            !TryParseImportedNumber(inclinationToken, out double inclination) ||
            !TryParseImportedNumber(azimuthToken, out double azimuth))
        {
            return false;
        }

        station = new SurveyStation
        {
            MD = ConvertDepthToSI(md, selectedSurveyImportMDUnit),
            Inclination = ConvertAngleToSI(inclination, selectedSurveyImportInclinationUnit),
            Azimuth = ConvertAngleToSI(azimuth, selectedSurveyImportAzimuthUnit)
        };
        return true;
    }

    private List<string> SplitDelimitedColumns(string line)
    {
        return selectedSurveyImportSeparator switch
        {
            "Semicolon (;)" => line.Split(';').Select(value => value.Trim()).ToList(),
            "Tab" => line.Split('\t').Select(value => value.Trim()).ToList(),
            "Space" => Regex.Split(line.Trim(), @"\s+").Where(value => !string.IsNullOrWhiteSpace(value)).ToList(),
            _ => line.Split(';').Select(value => value.Trim()).ToList()
        };
    }

    private static string? ReadColumnToken(List<string> columns, int columnIndex)
    {
        if (columnIndex < 1 || columnIndex > columns.Count)
        {
            return null;
        }

        return columns[columnIndex - 1];
    }

    private static string? ReadFixedWidthToken(string line, int start, int width)
    {
        if (start < 1 || width < 1)
        {
            return null;
        }

        int zeroBasedStart = start - 1;
        if (zeroBasedStart >= line.Length)
        {
            return null;
        }

        int safeWidth = Math.Min(width, line.Length - zeroBasedStart);
        return line.Substring(zeroBasedStart, safeWidth).Trim();
    }

    private bool TryParseImportedNumber(string? token, out double value)
    {
        value = 0;
        if (string.IsNullOrWhiteSpace(token))
        {
            return false;
        }

        string normalized = token.Trim();

        if (selectedSurveyImportDecimalMarker == "Dot (.)")
        {
            normalized = normalized.Replace(",", string.Empty);
        }
        else if (selectedSurveyImportDecimalMarker == "Comma (,)")
        {
            normalized = normalized.Replace(".", string.Empty).Replace(',', '.');
        }
        else
        {
            normalized = NormalizeAutoDecimalNumber(normalized);
        }

        return double.TryParse(normalized, NumberStyles.Float | NumberStyles.AllowLeadingSign, CultureInfo.InvariantCulture, out value);
    }

    private static string NormalizeAutoDecimalNumber(string token)
    {
        int lastComma = token.LastIndexOf(',');
        int lastDot = token.LastIndexOf('.');

        if (lastComma >= 0 && lastDot >= 0)
        {
            if (lastComma > lastDot)
            {
                return token.Replace(".", string.Empty).Replace(',', '.');
            }

            return token.Replace(",", string.Empty);
        }

        if (lastComma >= 0)
        {
            return token.Replace(',', '.');
        }

        return token;
    }

    private List<string> GetAvailableSurveyImportUnits(List<OSDC.UnitConversion.Conversion.UnitChoice> unitChoices)
    {
        HashSet<string> unitLabels = new(StringComparer.OrdinalIgnoreCase);
        foreach (var c in unitChoices)
        {
            if (c != null && !string.IsNullOrEmpty(c.UnitName))
            {
                unitLabels.Add(c.UnitName);
            }
        }
        return unitLabels
            .Where(label => !string.IsNullOrWhiteSpace(label))
            .OrderBy(label => label, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private double ConvertDepthToSI(double value, string unit)
    {
        // 1) convert the value from external unit to SI
        OSDC.UnitConversion.Conversion.UnitChoice? unitChoice = null;
        foreach (var c in OSDC.UnitConversion.Conversion.DrillingEngineering.DepthDrillingQuantity.UnitChoiceDescriptions)
        {
            if (c != null && c.UnitName == unit)
            {
                unitChoice = c;
                break;
            }
        }
        if (unitChoice != null)
        {
            value = OSDC.UnitConversion.Conversion.DrillingEngineering.DepthDrillingQuantity.Instance.ToSI(value, unitChoice.ID);
        }
        if (Parent != null)
        {
            // 2) convert the value from SI to webapp unit without using references
            value = Parent.FromSI(value, "DepthDrilling");
            // 3) convert the value from webapp unit to SI using references
            value = Parent.ToWGS84DepthSI(value, "DepthDrilling");
        }
        return value;
    }

    private static double ConvertAngleToSI(double value, string unit)
    {
        OSDC.UnitConversion.Conversion.UnitChoice? unitChoice = null;
        foreach (var c in OSDC.UnitConversion.Conversion.DrillingEngineering.PlaneAngleDrillingQuantity.UnitChoiceDescriptions)
        {
            if (c != null && c.UnitName == unit)
            {
                unitChoice = c;
                break;
            }
        }
        if (unitChoice != null)
        {
            value = OSDC.UnitConversion.Conversion.DrillingEngineering.PlaneAngleDrillingQuantity.Instance.ToSI(value, unitChoice.ID);
        }
        return value;
    }

