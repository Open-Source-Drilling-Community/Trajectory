    private void ClearDefinitiveFlagIfAnotherTrajectoryAlreadyUsesIt()
    {
        if (currentTrajectory.IsDefinitive && HasOtherDefinitiveTrajectory(currentTrajectory.TrajectoryType))
        {
            currentTrajectory.IsDefinitive = false;
        }
    }

    private bool HasOtherDefinitiveTrajectory(TrajectoryType trajectoryType)
    {
        Guid wellBoreId = selectedWellBoreId ?? currentTrajectory.WellBoreID;
        if (wellBoreId == Guid.Empty || TrajectoryList == null)
        {
            return false;
        }

        Guid currentTrajectoryId = currentTrajectory.MetaInfo?.ID ?? Guid.Empty;
        return TrajectoryList.Any(trajectory =>
            trajectory?.MetaInfo?.ID is Guid trajectoryId &&
            trajectoryId != currentTrajectoryId &&
            trajectory.WellBoreID == wellBoreId &&
            trajectory.TrajectoryType == trajectoryType &&
            trajectory.IsDefinitive);
    }

    private string? GetOtherDefinitiveTrajectoryName(TrajectoryType trajectoryType)
    {
        Guid wellBoreId = selectedWellBoreId ?? currentTrajectory.WellBoreID;
        if (wellBoreId == Guid.Empty || TrajectoryList == null)
        {
            return null;
        }

        Guid currentTrajectoryId = currentTrajectory.MetaInfo?.ID ?? Guid.Empty;
        return TrajectoryList.FirstOrDefault(trajectory =>
            trajectory?.MetaInfo?.ID is Guid trajectoryId &&
            trajectoryId != currentTrajectoryId &&
            trajectory.WellBoreID == wellBoreId &&
            trajectory.TrajectoryType == trajectoryType &&
            trajectory.IsDefinitive)?.Name;
    }

    private void ApplySelectedContext()
    {
        currentTrajectory.FieldID = selectedFieldId;
        currentTrajectory.ClusterID = selectedClusterId;
        currentTrajectory.WellID = selectedWellId;
        currentTrajectory.WellBoreID = selectedWellBoreId ?? Guid.Empty;
