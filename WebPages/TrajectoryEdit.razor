    private void NormalizeSurveyRunSections()
    {
        currentTrajectory.SurveyRunSectionList = currentTrajectory.SurveyRunSectionList?
            .Where(section => section.SurveyRunID != Guid.Empty)
            .OrderBy(section => section.StartAbscissa)
            .ToList() ?? new List<TrajectorySurveyRunSection>();
    }

    private void RemoveSurveyRunSectionsFromOtherWellBores()
    {
        if (selectedWellBoreId == null || currentTrajectory.SurveyRunSectionList == null)
        {
            return;
        }

        HashSet<Guid> availableSurveyRunIds = AvailableSurveyRuns
            .Where(surveyRun => surveyRun?.MetaInfo != null)
            .Select(surveyRun => surveyRun.MetaInfo.ID)
            .ToHashSet();

        int countBefore = currentTrajectory.SurveyRunSectionList.Count;
        currentTrajectory.SurveyRunSectionList = currentTrajectory.SurveyRunSectionList
            .Where(section => availableSurveyRunIds.Contains(section.SurveyRunID))
            .ToList();

        if (currentTrajectory.SurveyRunSectionList.Count != countBefore)
        {
            selectedSurveyRunSections.Clear();
            ClearCalculatedTrajectoryData();
        }
    }

    private bool IsValidTrajectory(Trajectory traj)
    {
        if (traj.MDStep <= 0.0 || selectedWellBoreId == null || traj.SurveyRunSectionList is not { Count: > 0 } sectionList)
        {
            return false;
        }
        if (traj.IsDefinitive && HasOtherDefinitiveTrajectory(traj.TrajectoryType))
        {
            return false;
        }

        HashSet<Guid> availableSurveyRunIds = AvailableSurveyRuns
            .Where(surveyRun => surveyRun?.MetaInfo != null)
            .Select(surveyRun => surveyRun.MetaInfo.ID)
            .ToHashSet();

        double? previousStart = null;
        foreach (TrajectorySurveyRunSection section in sectionList.OrderBy(section => section.StartAbscissa))
        {
            if (section.SurveyRunID == Guid.Empty || !availableSurveyRunIds.Contains(section.SurveyRunID))
            {
                return false;
            }
            if (previousStart is { } previous && section.StartAbscissa <= previous)
            {
                return false;
            }
            previousStart = section.StartAbscissa;
        }

        return true;
    }
    private async Task InitializeTrajectoryAsync(Trajectory traj)
    {
        try
        {
            traj.WellBoreID = Guid.Empty;
            traj.TrajectoryType = TrajectoryType.Actual;
            traj.IsDefinitive = false;
            if (traj.MDStep == 0.0)
                traj.MDStep = 10.0;
            traj.SurveyRunSectionList = new List<TrajectorySurveyRunSection>();
            traj.SurveyStationList = new List<SurveyStation>();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Exception raised at initialization of trajectory");
            Snackbar.Add("Exception raised at initialization of trajectory", Severity.Error);
        }
    }

