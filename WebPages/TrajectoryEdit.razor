    private Task OnFieldChanged(Guid? fieldId)
    {
        selectedFieldId = fieldId;

        if (selectedClusterId != null && !AvailableClusters.Any(cluster => cluster.MetaInfo.ID == selectedClusterId))
        {
            selectedClusterId = null;
        }

        if (selectedWellId != null && !AvailableWells.Any(well => well.MetaInfo.ID == selectedWellId))
        {
            selectedWellId = null;
        }

        if (selectedWellId == null)
        {
            selectedWellBoreId = null;
        }
        else if (selectedWellBoreId != null && !AvailableWellBores.Any(wb => wb.MetaInfo.ID == selectedWellBoreId))
        {
            selectedWellBoreId = null;
        }

        ApplySelectedContext();
        return Task.CompletedTask;
    }

    private Task OnClusterChanged(Guid? clusterId)
    {
        selectedClusterId = clusterId;

        if (selectedWellId is Guid wellId)
        {
            Well? selectedWell = FindWellById(wellId);
            if (selectedWell == null || (!selectedWell.IsSingleWell && selectedWell.ClusterID != selectedClusterId))
            {
                selectedWellId = null;
                selectedWellBoreId = null;
            }
        }

        ApplySelectedContext();
        return Task.CompletedTask;
    }

    private Task OnWellChanged(Guid? wellId)
    {
        selectedWellId = wellId;

        if (selectedWellId is Guid selectedId)
        {
            Well? selectedWell = FindWellById(selectedId);
            if (selectedWell != null)
            {
                selectedClusterId = selectedWell.IsSingleWell ? null : selectedWell.ClusterID;
                selectedFieldId ??= FindFieldIdForWell(selectedWell);
            }
        }
        else
        {
            selectedWellBoreId = null;
        }

        if (selectedWellBoreId != null && !AvailableWellBores.Any(wb => wb.MetaInfo.ID == selectedWellBoreId))
        {
            selectedWellBoreId = AvailableWellBores.FirstOrDefault()?.MetaInfo.ID;
        }

        ApplySelectedContext();
        return Task.CompletedTask;
    }

    private Task OnWellBoreChanged(Guid? wellBoreId)
    {
        selectedWellBoreId = wellBoreId;
        ApplySelectedContext();
        RemoveSurveyRunSectionsFromOtherWellBores();
        ClearDefinitiveFlagIfAnotherTrajectoryAlreadyUsesIt();

        if (wellBoreId is Guid selectedId)
