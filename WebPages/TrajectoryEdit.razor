    {
        if (supplementaryInterpolationDepthInput is not { } depth || depth < 0)
        {
            Snackbar.Add("Supplementary interpolation depth must be a positive value", Severity.Warning);
            return;
        }

        if (!supplementaryInterpolationDepths.Any(existingDepth => Math.Abs(existingDepth - depth) < 1e-6))
