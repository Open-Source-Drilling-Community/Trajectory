    private void SyncSelectorsFromWellBore(Guid wellBoreId)
    {
        selectedWellBoreId = null;
        selectedWellId = null;
        selectedClusterId = null;
        selectedFieldId = null;

        if (wellBoreId == Guid.Empty)
        {
            currentTrajectory.FieldID = null;
            currentTrajectory.ClusterID = null;
            currentTrajectory.WellID = null;
            currentTrajectory.WellBoreID = Guid.Empty;
            return;
        }

        WellBore? wellBore = FindWellBoreById(wellBoreId);
        Well? well = wellBore?.WellID is Guid selectedWellIdValue ? FindWellById(selectedWellIdValue) : null;
        Cluster? cluster = well?.ClusterID is Guid selectedClusterIdValue ? FindClusterById(selectedClusterIdValue) : null;

        selectedWellBoreId = wellBore?.MetaInfo.ID;
        selectedWellId = well?.MetaInfo.ID;
        selectedClusterId = well is { IsSingleWell: true } ? null : cluster?.MetaInfo.ID;
        selectedFieldId = cluster?.FieldID ?? FindFieldIdForWell(well);

        ApplySelectedContext();
    }

    private bool MatchesSelectedField(Well well)
    {
        if (selectedFieldId == null)
        {
            return true;
        }

        Guid? fieldId = FindFieldIdForWell(well);
        return fieldId == selectedFieldId;
    }

    private Guid? FindFieldIdForWell(Well? well)
    {
        if (well?.ClusterID is Guid clusterId)
        {
            return FindClusterById(clusterId)?.FieldID;
        }

        return null;
    }

