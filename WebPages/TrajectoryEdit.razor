        method switch
        {
            TrajectoryCalculationType.MinimumCurvatureMethod => "Minimum Curvature Method",
            TrajectoryCalculationType.ConstantBuildAndTurnMethod => "Constant Build and Turn Rates",
            TrajectoryCalculationType.ConstantCurvatureAndToolfaceMethod => "Constant Curvature and Toolface",
            _ => method.ToString()
        };

    private static double? InterpolateValue(double? start, double? end, double ratio)
    {
        if (start is not { } startValue || end is not { } endValue)
        {
            return null;
        }

        return startValue + (endValue - startValue) * ratio;
    }

    private static double? GetVerticalSection(SurveyStation? point)
    {
        if (point?.RiemannianNorth is { } north && point.RiemannianEast is { } east)
        {
            return Math.Sqrt(north * north + east * east);
        }

        return null;
    }

