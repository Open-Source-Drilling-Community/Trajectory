    private static SurveyPoint? InterpolateDisplayPoint(List<SurveyPoint> points, double targetDepth)
    {
        SurveyPoint? previous = points
            .Where(point => point.MD is { } depth && depth <= targetDepth)
            .OrderByDescending(point => point.MD)
            .FirstOrDefault();
        SurveyPoint? next = points
            .Where(point => point.MD is { } depth && depth >= targetDepth)
            .OrderBy(point => point.MD)
            .FirstOrDefault();

        if (previous?.MD is not { } previousDepth || next?.MD is not { } nextDepth)
        {
            return null;
        }

        if (Math.Abs(previousDepth - targetDepth) < 1e-6)
        {
            return CloneSurveyPoint(previous);
        }

        if (Math.Abs(nextDepth - targetDepth) < 1e-6)
        {
            return CloneSurveyPoint(next);
        }

        if (Math.Abs(nextDepth - previousDepth) < 1e-9)
        {
            return null;
        }

        double ratio = (targetDepth - previousDepth) / (nextDepth - previousDepth);
        return new SurveyPoint
        {
            MD = targetDepth,
            Inclination = InterpolateValue(previous.Inclination, next.Inclination, ratio),
            Azimuth = InterpolateValue(previous.Azimuth, next.Azimuth, ratio),
            TVD = InterpolateValue(previous.TVD, next.TVD, ratio),
            RiemannianNorth = InterpolateValue(previous.RiemannianNorth, next.RiemannianNorth, ratio),
            RiemannianEast = InterpolateValue(previous.RiemannianEast, next.RiemannianEast, ratio),
            Curvature = InterpolateValue(previous.Curvature, next.Curvature, ratio),
            BUR = InterpolateValue(previous.BUR, next.BUR, ratio),
            TUR = InterpolateValue(previous.TUR, next.TUR, ratio)
        };
    }

    private static SurveyPoint CloneSurveyPoint(SurveyPoint point) =>
        new()
        {
            MD = point.MD,
            Inclination = point.Inclination,
            Azimuth = point.Azimuth,
            TVD = point.TVD,
            RiemannianNorth = point.RiemannianNorth,
            RiemannianEast = point.RiemannianEast,
            Curvature = point.Curvature,
            BUR = point.BUR,
            TUR = point.TUR
        };

