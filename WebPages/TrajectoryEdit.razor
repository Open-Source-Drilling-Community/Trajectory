    // Deep copy constructor
    private async Task EnsureWellBoreArchitectureDataLoadedAsync()
    {
        if (wellBoreArchitectureHeavyList != null || isLoadingWellBoreArchitectureData)
        {
            return;
        }

        try
        {
            isLoadingWellBoreArchitectureData = true;
            wellBoreArchitectureHeavyList = (List<WellBoreArchitecture>)await Api.ClientWellBoreArchitecture.GetAllWellBoreArchitectureAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while loading WellBoreArchitecture data");
        }
        finally
        {
            isLoadingWellBoreArchitectureData = false;
        }
    }

    private static Trajectory DeepCopyTrajectory(Trajectory source)
    {
        return new Trajectory
        {
            MetaInfo = new MetaInfo { ID = source.MetaInfo.ID },
            Name = source.Name,
            Description = source.Description,
            CreationDate = source.CreationDate,
            LastModificationDate = source.LastModificationDate,
            FieldID = source.FieldID,
            ClusterID = source.ClusterID,
            WellID = source.WellID,
            WellBoreID = source.WellBoreID,
            CalculationType = source.CalculationType,
            MDStep = source.MDStep,
            SurveyStationList = source.SurveyStationList
                .Select(ss => new SurveyStation
                {
                    MD = ss.MD,
                    Inclination = ss.Inclination,
                    Azimuth = ss.Azimuth,
                    RiemannianNorth = ss.RiemannianNorth,
                    RiemannianEast = ss.RiemannianEast,
                    TVD = ss.TVD
                })
                .ToList()
        };
    }

