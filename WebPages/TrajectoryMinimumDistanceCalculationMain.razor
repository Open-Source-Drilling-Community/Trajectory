            currentCalculation_.MaximumChordArcDistance = value;
        }
    }

    private Task OnResultsPanelExpandedChanged(bool expanded)
    {
        if (expanded)
        {
            StartResultLoading();
        }

        return Task.CompletedTask;
    }

    private void StartResultLoading()
    {
        if (currentCalculation_?.MetaInfo?.ID is not Guid id || id == Guid.Empty || resultLoadComplete_ || isLoadingResults_ || IsCalculationActive(currentCalculation_))
        {
            return;
        }

        _ = LoadResultsAsync(id);
    }

    private async Task LoadResultsAsync(Guid id)
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        isLoadingResults_ = true;
        resultLoadComplete_ = false;
        resultChunkCount_ = 0;
        resultChunksLoaded_ = 0;
        resultsLoaded_ = 0;
        currentCalculation_.ResultList = [];
        await InvokeAsync(StateHasChanged);

        try
        {
            int chunkCount = await Api.ClientTrajectory.GetTrajectoryMinimumDistanceCalculationResultChunkCountAsync(id);
            resultChunkCount_ = chunkCount;
            await InvokeAsync(StateHasChanged);
            List<TrajectoryMinimumDistanceResult> results = [];
            for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
            {
                TrajectoryMinimumDistanceResultChunk chunk = await Api.ClientTrajectory.GetTrajectoryMinimumDistanceCalculationResultChunkAsync(id, chunkIndex);
                if (chunk.ResultList is { Count: > 0 })
                {
                    results.AddRange(chunk.ResultList);
                }

                resultChunksLoaded_ = chunkIndex + 1;
                resultsLoaded_ = results.Count;
                if (chunkIndex == 0 || resultChunksLoaded_ == chunkCount || resultChunksLoaded_ % 5 == 0)
                {
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(1);
                }
            }

            currentCalculation_.ResultList = results;
            SelectAllResultTrajectories();
            resultLoadComplete_ = true;
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem loading trajectory minimum distance result chunks");
            Snackbar.Add("Failed to load result chunks.", Severity.Error);
        }
        finally
        {
            isLoadingResults_ = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ResetResultLoadingState()
    {
        isLoadingResults_ = false;
        resultLoadComplete_ = false;
        resultChunkCount_ = 0;
        resultChunksLoaded_ = 0;
        resultsLoaded_ = 0;
        displayedResultTrajectoryIds_.Clear();
    }

    private bool IsResultTrajectoryDisplayed(Guid trajectoryId) => displayedResultTrajectoryIds_.Contains(trajectoryId);

    private void SetResultTrajectoryDisplayed(Guid trajectoryId, bool selected)
    {
        if (selected)
        {
            displayedResultTrajectoryIds_.Add(trajectoryId);
        }
        else
        {
            displayedResultTrajectoryIds_.Remove(trajectoryId);
        }
    }

    private void SelectAllResultTrajectories()
    {
        displayedResultTrajectoryIds_.Clear();
        foreach (Guid trajectoryId in ResultComparisonTrajectoryIds)
        {
            displayedResultTrajectoryIds_.Add(trajectoryId);
        }
    }

    private void ClearResultTrajectoryFilter() => displayedResultTrajectoryIds_.Clear();

    private bool IsComparisonSelected(Guid id) => currentCalculation_?.ComparisonTrajectoryIDList?.Contains(id) == true;

    private bool IsComparisonCandidateStaged(Guid id) => stagedComparisonTrajectoryIds_.Contains(id);

    private void SetComparisonCandidateStaged(Guid id, bool selected)
    {
        if (selected)
        {
            stagedComparisonTrajectoryIds_.Add(id);
        }
        else
        {
            stagedComparisonTrajectoryIds_.Remove(id);
        }
    }

    private void AddStagedComparisonTrajectories()
    {
        AddComparisonTrajectories(stagedComparisonTrajectoryIds_);
        stagedComparisonTrajectoryIds_.Clear();
    }

    private void AddFilteredComparisonTrajectories()
    {
        AddComparisonTrajectories(AvailableComparisonCandidates.Select(trajectory => trajectory.MetaInfo.ID));
        stagedComparisonTrajectoryIds_.Clear();
    }

    private void AddComparisonTrajectories(IEnumerable<Guid> ids)
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        List<Guid> values = currentCalculation_.ComparisonTrajectoryIDList?.ToList() ?? [];
        foreach (Guid id in ids.Where(id => id != Guid.Empty && id != selectedReferenceTrajectoryId_))
        {
            if (!values.Contains(id))
            {
                values.Add(id);
            }
        }

        currentCalculation_.ComparisonTrajectoryIDList = values;
    }

    private void AddReferenceInterval()
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        currentCalculation_.ReferenceIntervalList ??= [];
        double? start = currentCalculation_.ReferenceIntervalList
            .Where(interval => interval.EndMD.HasValue)
            .Select(interval => interval.EndMD)
            .Max();
        currentCalculation_.ReferenceIntervalList.Add(new MinimumDistanceReferenceInterval
        {
            ID = Guid.NewGuid(),
            Name = $"Interval {currentCalculation_.ReferenceIntervalList.Count + 1}",
            StartMD = start,
            EndMD = start.HasValue ? start.Value + 100.0 : null
        });
    }

    private void RemoveReferenceInterval(MinimumDistanceReferenceInterval interval)
    {
        currentCalculation_?.ReferenceIntervalList?.Remove(interval);
    }

    private void RemoveComparisonTrajectory(Guid id)
    {
        if (currentCalculation_?.ComparisonTrajectoryIDList == null)
        {
            return;
        }

        currentCalculation_.ComparisonTrajectoryIDList = currentCalculation_.ComparisonTrajectoryIDList.Where(value => value != id).ToList();
        stagedComparisonTrajectoryIds_.Remove(id);
    }

    private void ClearComparisonTrajectories()
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        currentCalculation_.ComparisonTrajectoryIDList = [];
        stagedComparisonTrajectoryIds_.Clear();
    }

    private bool MatchesComparisonSearch(TrajectoryLight trajectory)
    {
        if (string.IsNullOrWhiteSpace(comparisonSearchString_))
        {
            return true;
        }

        return $"{trajectory.Name} {trajectory.Description}".Contains(comparisonSearchString_, StringComparison.OrdinalIgnoreCase);
    }

    private Func<TrajectoryMinimumDistanceCalculationLight, bool> Filter => x =>
        string.IsNullOrWhiteSpace(searchString_) ||
        $"{x.Name} {x.Description} {GetTrajectoryName(x.ReferenceTrajectoryID)}".Contains(searchString_, StringComparison.OrdinalIgnoreCase);

    private void SelectedItemsChanged(HashSet<TrajectoryMinimumDistanceCalculationLight> items) => selectedCalculationLightList_ = items.ToList();
    private async Task RowClicked(DataGridRowClickEventArgs<TrajectoryMinimumDistanceCalculationLight> args) => await EditCalculation(args.Item.MetaInfo.ID);
    private string GetTrajectoryName(Guid id) => trajectoryLightList_.FirstOrDefault(t => t.MetaInfo?.ID == id)?.Name ?? "NA";
    private double? SelectedDistance(TrajectoryMinimumDistanceResult result) =>
        selectedDistanceMode_ == CenterDistanceMode ? result.CenterToCenterDistance : result.ClearanceDistance;

    private static bool IsCalculationActive(TrajectoryMinimumDistanceCalculationLight calculation) =>
        calculation.CalculationState == CalculationState.Running ||
        calculation.CalculationState == CalculationState.Queued;

    private static bool IsCalculationActive(TrajectoryMinimumDistanceCalculation calculation) =>
        calculation.CalculationState == CalculationState.Running ||
        calculation.CalculationState == CalculationState.Queued;

    private static TrajectoryMinimumDistanceCalculation CreateCalculation() => new()
    {
        MetaInfo = PseudoConstructors.ConstructMetaInfo(),
        Name = "Default Name",
        Description = string.Empty,
        CreationDate = DateTimeOffset.UtcNow,
        LastModificationDate = DateTimeOffset.UtcNow,
        ComparisonTrajectoryIDList = [],
        AccountForBoreholeRadius = true,
        OctreeMaximumDepth = 8,
        OctreeMaximumSegmentCountPerLeaf = 32,
