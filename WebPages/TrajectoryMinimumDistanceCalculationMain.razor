@page "/TrajectoryMinimumDistanceCalculation"
@inject ILogger<TrajectoryMinimumDistanceCalculationMain> logger
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ITrajectoryAPIUtils Api

<MudUnitAndReferenceChoiceTag HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="@DataUtils.UpdateDepthReferenceName"
                              GroundMudLineDepthReferenceSource="@DataUtils.GroundMudLineDepthReferenceSource"
                              SeaWaterLevelDepthReferenceSource="@DataUtils.SeaWaterLevelDepthReferenceSource"
                              RotaryTableDepthReferenceSource="@DataUtils.RotaryTableDepthReferenceSource"
                              PositionReferenceName="@DataUtils.UnitAndReferenceParameters.PositionReferenceName"
                              PositionReferenceNameChanged="@DataUtils.UpdatePositionReferenceName"
                              WellHeadPositionReferenceSource="@DataUtils.WellHeadPositionReferenceSource"
                              CartographicGridPositionReferenceSource="@DataUtils.CartographicGridPositionReferenceSource"
                              LeaseLinePositionReferenceSource="@DataUtils.LeaseLinePositionReferenceSource"
                              ClusterPositionReferenceSource="@DataUtils.ClusterPositionReferenceSource">
    @if (!isEditing_)
    {
        <MudDataGrid T="TrajectoryMinimumDistanceCalculationLight" @key="gridKey_"
                     MultiSelection="true" Items="@calculationLightList_" SelectedItemsChanged="@SelectedItemsChanged"
                     Hover="true" RowClick="@RowClicked"
                     SortMode="SortMode.Multiple" QuickFilter="@Filter" Filterable="false"
                     ReadOnly="true" ColumnResizeMode="ResizeMode.Column" Elevation="0">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Trajectory Minimum Distance</MudText>
                <MudButton OnClick="@AddCalculation" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
                <MudButton OnClick="@DeleteSelectedCalculations" Color="@Color.Error" Class="add-item-btn"
                           Disabled="@(selectedCalculationLightList_.Count == 0)">Delete</MudButton>
                <MudSpacer />
                <MudTextField @bind-Value="searchString_" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
            </ToolBarContent>
            <Columns>
                <SelectColumn T="TrajectoryMinimumDistanceCalculationLight" />
                <PropertyColumn Property="x => x.Name" Title="Case" CellStyle="width: 25%;" Sortable="true" />
                <PropertyColumn Property="x => x.Description" Title="Description" CellStyle="width: 25%;" Sortable="true" />
                <PropertyColumn Property="x => GetTrajectoryName(x.ReferenceTrajectoryID)" Title="Reference Trajectory" Sortable="true" />
                <PropertyColumn Property="x => x.ResultCount" Title="Results" Sortable="true" />
                <TemplateColumn Title="Calculation" Sortable="true">
                    <CellTemplate>
                        @CalculationStatusContent(context.Item)
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn CellClass="d-flex justify-end">
                    <CellTemplate>
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete"
                                       OnClick="(() => DeleteCalculation(context.Item.MetaInfo.ID))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="TrajectoryMinimumDistanceCalculationLight" />
            </PagerContent>
        </MudDataGrid>
    }
    else if (currentCalculation_ != null)
    {
        <MudText Class="mt-4 mb-4" Typo="Typo.h6">Edit Minimum Distance Calculation</MudText>
        <MudContainer Class="d-flex flex-row mt-4 mb-4">
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveCalculation">Save</MudButton>
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="CloseEditor">Cancel</MudButton>
        </MudContainer>

        <MudGrid>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="currentCalculation_.Name" Label="Name" Required="true" ShrinkLabel /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="currentCalculation_.Description" Label="Description" ShrinkLabel /></MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Reference Trajectory" T="Guid?" Value="@selectedReferenceTrajectoryId_" ValueChanged="OnReferenceTrajectoryChanged" ShrinkLabel Clearable="true">
                    @foreach (TrajectoryLight trajectory in trajectoryLightList_)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)trajectory.MetaInfo.ID)">@trajectory.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudInputWithUnit QuantityLabel="Chord Distance" QuantityName="DepthDrilling"
                                  SIValueNullable="@currentCalculation_.MaximumChordArcDistance"
                                  SIValueNullableChanged="@OnMaximumChordDistanceChanged" />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudCheckBox T="bool" @bind-Value="currentCalculation_.AccountForBoreholeRadius" Label="Use borehole radius" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField T="int" @bind-Value="currentCalculation_.OctreeMaximumDepth" Label="Octree Depth" Min="1" Max="12" ShrinkLabel />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudNumericField T="int" @bind-Value="currentCalculation_.OctreeMaximumSegmentCountPerLeaf" Label="Segments per Leaf" Min="4" Max="256" ShrinkLabel />
            </MudItem>
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudCheckBox T="bool" Value="@AdaptiveRefinement.Enabled" ValueChanged="@OnAdaptiveRefinementEnabledChanged" Label="Adaptive polar refinement" />
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Displayed Distance" T="string" @bind-Value="selectedDistanceMode_" ShrinkLabel>
                    <MudSelectItem T="string" Value="@CenterDistanceMode">Center to center</MudSelectItem>
                    <MudSelectItem T="string" Value="@ClearanceDistanceMode">Clearance</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudExpansionPanels Elevation="0">
                    <MudExpansionPanel Text="Advanced adaptive refinement settings">
                        <MudGrid>
                            <MudItem xs="12" md="3">
                                <MudInputWithUnit QuantityLabel="Polar Deviation" QuantityName="PositionDrilling"
                                                  SIValueNullable="@AdaptiveRefinement.PolarDeviationTolerance"
                                                  SIValueNullableChanged="@OnAdaptivePolarDeviationToleranceChanged" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudInputWithUnit QuantityLabel="Angular Deviation" QuantityName="PlaneAngleDrilling"
                                                  SIValueNullable="@AdaptiveRefinement.PolarAngularTolerance"
                                                  SIValueNullableChanged="@OnAdaptivePolarAngularToleranceChanged" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudInputWithUnit QuantityLabel="Minimum MD Step" QuantityName="DepthDrilling"
                                                  SIValueNullable="@AdaptiveRefinement.MinimumMDStep"
                                                  SIValueNullableChanged="@OnAdaptiveMinimumMDStepChanged" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField T="int" Value="@AdaptiveRefinement.MaximumDepth" ValueChanged="@OnAdaptiveMaximumDepthChanged" Label="Maximum Refinement Depth" Min="1" Max="12" ShrinkLabel />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField T="int" Value="@AdaptiveRefinement.MaximumExtraSamplesPerComparison" ValueChanged="@OnAdaptiveMaximumExtraSamplesChanged" Label="Max Extra Samples" Min="0" Max="100000" ShrinkLabel />
                            </MudItem>
                        </MudGrid>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4 mt-4" Outlined="true">
            <MudText Typo="Typo.subtitle1">Comparison Trajectories</MudText>
            <MudGrid Class="mt-1">
                <MudItem xs="12" md="5">
                    <MudTextField @bind-Value="comparisonSearchString_" Label="Filter available trajectories" ShrinkLabel Immediate="true"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                    <MudToolBar Dense="true" Class="px-0">
                        <MudText Typo="Typo.caption">@AvailableComparisonCandidates.Count trajectory candidates</MudText>
                        <MudSpacer />
                        <MudButton OnClick="AddStagedComparisonTrajectories" Color="Color.Primary" Variant="Variant.Outlined"
                                   Disabled="@(!stagedComparisonTrajectoryIds_.Any())">Add Selected</MudButton>
                        <MudButton OnClick="AddFilteredComparisonTrajectories" Color="Color.Primary" Variant="Variant.Text"
                                   Disabled="@(!AvailableComparisonCandidates.Any())">Add Filtered</MudButton>
                    </MudToolBar>
                    <MudTable Items="@AvailableComparisonCandidates" T="TrajectoryLight" Dense="true" Hover="true"
                              Height="320px" FixedHeader="true" Elevation="0">
                        <HeaderContent>
                            <MudTh></MudTh>
                            <MudTh>Name</MudTh>
                            <MudTh>Description</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Select">
                                <MudCheckBox T="bool" Value="@IsComparisonCandidateStaged(context.MetaInfo.ID)"
                                             ValueChanged="@((bool selected) => SetComparisonCandidateStaged(context.MetaInfo.ID, selected))" />
                            </MudTd>
                            <MudTd DataLabel="Name">@context.Name</MudTd>
                            <MudTd DataLabel="Description">@context.Description</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
                <MudItem xs="12" md="7">
                    <MudToolBar Dense="true" Class="px-0">
                        <MudText Typo="Typo.caption">@SelectedComparisonTrajectories.Count selected comparison trajectories</MudText>
                        <MudSpacer />
                        <MudButton OnClick="ClearComparisonTrajectories" Color="Color.Error" Variant="Variant.Text"
                                   Disabled="@(!SelectedComparisonTrajectories.Any())">Clear</MudButton>
                    </MudToolBar>
                    <MudTable Items="@SelectedComparisonTrajectories" T="TrajectoryLight" Dense="true" Hover="true"
                              Height="370px" FixedHeader="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Description</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Name">@context.Name</MudTd>
                            <MudTd DataLabel="Description">@context.Description</MudTd>
                            <MudTd DataLabel="Remove">
                                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete"
                                               OnClick="@(() => RemoveComparisonTrajectory(context.MetaInfo.ID))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Class="pa-4 mt-4" Outlined="true">
            <MudToolBar Dense="true" Class="px-0">
                <MudText Typo="Typo.subtitle1">Reference MD Intervals</MudText>
                <MudSpacer />
                <MudButton OnClick="AddReferenceInterval" Color="Color.Success" Variant="Variant.Outlined">Add interval</MudButton>
            </MudToolBar>
            <MudTable Items="@ReferenceIntervals" T="MinimumDistanceReferenceInterval" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Start MD [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                    <MudTh>End MD [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudTextField @bind-Value="context.Name" ShrinkLabel />
                    </MudTd>
                    <MudTd DataLabel="Start MD">
                        <MudInputWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                          SIValueNullable="@context.StartMD"
                                          SIValueNullableChanged="@((double? value) => context.StartMD = value)" />
                    </MudTd>
                    <MudTd DataLabel="End MD">
                        <MudInputWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                          SIValueNullable="@context.EndMD"
                                          SIValueNullableChanged="@((double? value) => context.EndMD = value)" />
                    </MudTd>
                    <MudTd DataLabel="Remove">
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete"
                                       OnClick="@(() => RemoveReferenceInterval(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudExpansionPanels Class="mt-4" Style="overflow-y: auto; max-height: none;">
            <MudExpansionPanel Text="Results" ExpandedChanged="@OnResultsPanelExpandedChanged">
                @if (IsCalculationActive(currentCalculation_))
                {
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.body2">@currentCalculation_.CalculationMessage</MudText>
                        <MudProgressLinear Value="@(100.0 * currentCalculation_.CalculationProgress)" Color="Color.Info" Class="mt-2" />
                    </MudPaper>
                }
                else if (isLoadingResults_)
                {
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.body2">@ResultLoadingText</MudText>
                        <MudProgressLinear Value="@ResultLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                    </MudPaper>
                }
                else if (currentCalculation_.ResultList is { Count: > 0 } results)
                {
                    <MudText Typo="Typo.body2" Class="mb-2">
                        Global minimum clearance: <MudSpanWithUnit QuantityName="PositionDrilling" SIValue="@currentCalculation_.GlobalMinimumClearanceDistance" />
                        at MD <MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@currentCalculation_.GlobalMinimumReferenceMD" />
                    </MudText>
                    @if (currentCalculation_.IntervalResultList is { Count: > 0 } && ValidReferenceIntervals.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1">Interval Summary (@SelectedDistanceLabel)</MudText>
                        <MudTable Items="@ValidReferenceIntervals" T="MinimumDistanceReferenceInterval" Dense="true" Hover="true" Elevation="1" Bordered="true" Class="mb-3">
                            <HeaderContent>
                                <MudTh>Interval</MudTh>
                                @foreach (Guid trajectoryId in ResultComparisonTrajectoryIds)
                                {
                                    <MudTh>@GetTrajectoryName(trajectoryId)</MudTh>
                                }
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Interval">@GetIntervalLabel(context)</MudTd>
                                @foreach (Guid trajectoryId in ResultComparisonTrajectoryIds)
                                {
                                    <MudTd>@FormatIntervalResult(GetIntervalResult(context.ID, trajectoryId))</MudTd>
                                }
                            </RowTemplate>
                        </MudTable>
                    }
                    <MudPaper Class="pa-3 mb-3" Outlined="true">
                        <MudToolBar Dense="true" Class="px-0">
                            <MudText Typo="Typo.caption">@FilteredResultList.Count/@results.Count result rows displayed</MudText>
                            <MudSpacer />
                            <MudButton OnClick="SelectAllResultTrajectories" Color="Color.Primary" Variant="Variant.Text">All</MudButton>
                            <MudButton OnClick="ClearResultTrajectoryFilter" Color="Color.Primary" Variant="Variant.Text">None</MudButton>
                        </MudToolBar>
                        <MudGrid>
                            @foreach (Guid trajectoryId in ResultComparisonTrajectoryIds)
                            {
                                <MudItem xs="12" sm="6" md="4" lg="3">
                                    <MudCheckBox T="bool" Value="@IsResultTrajectoryDisplayed(trajectoryId)"
                                                 ValueChanged="@((bool selected) => SetResultTrajectoryDisplayed(trajectoryId, selected))"
                                                 Label="@GetTrajectoryName(trajectoryId)" />
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>
                    <MudTable Items="@FilteredResultList" T="TrajectoryMinimumDistanceResult" Height="360px" FixedHeader="true"
                              Virtualize="true" OverscanCount="3" ItemSize="38"
                              Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true" ReadOnly="true">
                        <HeaderContent>
                            <MudTHeadRow>
                                <MudTh>Reference MD [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                                <MudTh>Comparison</MudTh>
                                <MudTh>Comparison MD [@Parent?.GetDepthUnitLabel("DepthDrilling")]</MudTh>
                                <MudTh>Center Distance [@Parent?.GetUnitLabel("PositionDrilling")]</MudTh>
                                <MudTh>Clearance [@Parent?.GetUnitLabel("PositionDrilling")]</MudTh>
                                <MudTh>Toolface [@Parent?.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                            </MudTHeadRow>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.ReferenceMD" /></MudTd>
                            <MudTd>@GetTrajectoryName(context.ComparisonTrajectoryID ?? Guid.Empty)</MudTd>
                            <MudTd><MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.ComparisonMD" /></MudTd>
                            <MudTd><MudSpanWithUnit QuantityName="PositionDrilling" SIValue="@context.CenterToCenterDistance" /></MudTd>
                            <MudTd><MudSpanWithUnit QuantityName="PositionDrilling" SIValue="@context.ClearanceDistance" /></MudTd>
                            <MudTd><MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Toolface" /></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText>No results loaded</MudText>
                }
            </MudExpansionPanel>
            <MudExpansionPanel Text="Plots" ExpandedChanged="@OnResultsPanelExpandedChanged">
                @if (isLoadingResults_)
                {
                    <MudPaper Class="pa-4" Outlined="true">
                        <MudText Typo="Typo.body2">@ResultLoadingText</MudText>
                        <MudProgressLinear Value="@ResultLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                    </MudPaper>
                }
                else if (currentCalculation_.ResultList is { Count: > 0 })
                {
                    <MudGrid Justify="Justify.Center">
                        <MudItem xs="12" md="6">
                            <ScatterPlot NameList="@DistanceNameList" ModeFlagList="@DistanceModeFlagList" ColorList="@DistanceColorList"
                                         XValuesList="@DistanceValuesList" YValuesList="@ReferenceMdValuesList"
                                         PlotTitle="" XAxisTitle="@SelectedDistanceLabel" YAxisTitle="Reference MD"
                                         XUnit="PositionDrilling" YUnit="DepthDrilling"
                                         YAxisReversed="@true"
                                         YAxisUsesDepthReference="@true">
                            </ScatterPlot>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <ToolfacePolarPlot NameList="@DistanceNameList"
                                               ColorList="@DistanceColorList"
                                               RadiusValuesList="@DistanceValuesList"
                                               ToolfaceValuesList="@ToolfaceValuesList"
                                               RadiusUnit="PositionDrilling" />
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <MudText>No results loaded</MudText>
                }
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
</MudUnitAndReferenceChoiceTag>

@code {
    [CascadingParameter] private MudUnitAndReferenceChoiceTag? Parent { get; set; }

    private const string CenterDistanceMode = "Center";
    private const string ClearanceDistanceMode = "Clearance";
    private static readonly string[] PlotColorPalette = ["#1769aa", "#c23b22", "#4f7d20", "#7b3f98", "#bf7f00", "#00838f", "#8d5a3b", "#455a64"];
    private List<TrajectoryMinimumDistanceCalculationLight> calculationLightList_ = [];
    private List<TrajectoryMinimumDistanceCalculationLight> selectedCalculationLightList_ = [];
    private List<TrajectoryLight> trajectoryLightList_ = [];
    private List<WellBore>? wellBoreList_;
    private List<Well>? wellList_;
    private List<Cluster>? clusterList_;
    private List<Rig>? rigList_;
    private TrajectoryMinimumDistanceCalculation? currentCalculation_;
    private Guid? currentCalculationId_;
    private Guid? selectedReferenceTrajectoryId_;
    private string selectedDistanceMode_ = ClearanceDistanceMode;
    private string? searchString_;
    private string? comparisonSearchString_;
    private readonly HashSet<Guid> stagedComparisonTrajectoryIds_ = [];
    private readonly HashSet<Guid> displayedResultTrajectoryIds_ = [];
    private bool isEditing_;
    private bool isLoadingResults_;
    private bool resultLoadComplete_;
    private int resultChunkCount_;
    private int resultChunksLoaded_;
    private int resultsLoaded_;
    private int gridKey_;
    private CancellationTokenSource? pollingCancellation_;

    private List<TrajectoryLight> AvailableComparisonCandidates =>
        trajectoryLightList_
            .Where(trajectory => trajectory.MetaInfo?.ID is Guid id &&
                                 id != selectedReferenceTrajectoryId_ &&
                                 IsComparisonSelected(id) == false &&
                                 MatchesComparisonSearch(trajectory))
            .OrderBy(trajectory => trajectory.Name)
            .ToList();
    private List<TrajectoryLight> SelectedComparisonTrajectories =>
        currentCalculation_?.ComparisonTrajectoryIDList?
            .Select(id => trajectoryLightList_.FirstOrDefault(trajectory => trajectory.MetaInfo?.ID == id))
            .Where(trajectory => trajectory != null)
            .Cast<TrajectoryLight>()
            .OrderBy(trajectory => trajectory.Name)
            .ToList() ?? [];

    private List<IGrouping<Guid, TrajectoryMinimumDistanceResult>> ResultGroups =>
        currentCalculation_?.ResultList?
            .Where(result => result.ComparisonTrajectoryID.HasValue)
            .GroupBy(result => result.ComparisonTrajectoryID!.Value)
            .OrderBy(group => GetTrajectoryName(group.Key))
            .ToList() ?? [];
    private List<string> DistanceNameList => ResultGroups.Select(group => GetTrajectoryName(group.Key)).ToList();
    private List<int> DistanceModeFlagList => ResultGroups.Select(_ => 3).ToList();
    private List<string> DistanceColorList => ResultGroups.Select((_, index) => PlotColorPalette[index % PlotColorPalette.Length]).ToList();
    private List<List<object>> ReferenceMdValuesList => ResultGroups
        .Select(group => group.OrderBy(result => result.ReferenceMD).Select(result => (object)(result.ReferenceMD ?? double.NaN)).ToList())
        .ToList();
    private List<List<object>> DistanceValuesList => ResultGroups
        .Select(group => group.OrderBy(result => result.ReferenceMD).Select(result => (object)(SelectedDistance(result) ?? double.NaN)).ToList())
        .ToList();
    private List<List<object>> ToolfaceValuesList => ResultGroups
        .Select(group => group.OrderBy(result => result.ReferenceMD).Select(result => (object)(result.Toolface ?? double.NaN)).ToList())
        .ToList();
    private List<Guid> ResultComparisonTrajectoryIds =>
        currentCalculation_?.ResultList?
            .Where(result => result.ComparisonTrajectoryID.HasValue)
            .Select(result => result.ComparisonTrajectoryID!.Value)
            .Distinct()
            .OrderBy(GetTrajectoryName)
            .ToList() ?? [];
    private List<TrajectoryMinimumDistanceResult> FilteredResultList =>
        currentCalculation_?.ResultList?
            .Where(result => result.ComparisonTrajectoryID is Guid id && displayedResultTrajectoryIds_.Contains(id))
            .ToList() ?? [];
    private ICollection<MinimumDistanceReferenceInterval> ReferenceIntervals =>
        currentCalculation_?.ReferenceIntervalList ?? [];
    private MinimumDistanceAdaptiveRefinementSettings AdaptiveRefinement
    {
        get
        {
            if (currentCalculation_ == null)
            {
                return new MinimumDistanceAdaptiveRefinementSettings();
            }

            currentCalculation_.AdaptiveRefinementSettings ??= new MinimumDistanceAdaptiveRefinementSettings();
            return currentCalculation_.AdaptiveRefinementSettings;
        }
    }
    private List<MinimumDistanceReferenceInterval> ValidReferenceIntervals =>
        ReferenceIntervals
            .Where(IsValidReferenceInterval)
            .OrderBy(interval => interval.StartMD)
            .ToList();
    private string SelectedDistanceLabel => selectedDistanceMode_ == CenterDistanceMode ? "Center Distance" : "Clearance";
    private double ResultLoadingProgressPercent => resultChunkCount_ <= 0 ? 0.0 : 100.0 * resultChunksLoaded_ / resultChunkCount_;
    private string ResultLoadingText => resultChunkCount_ <= 0
        ? "Loading result chunks..."
        : $"Loading result chunks {resultChunksLoaded_}/{resultChunkCount_} ({resultsLoaded_:N0} rows)";

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        try
        {
            var calculationTask = Api.ClientTrajectory.GetAllTrajectoryMinimumDistanceCalculationLightAsync();
            var trajectoryTask = Api.ClientTrajectory.GetAllTrajectoryLightAsync();
            var wellBoreTask = Api.ClientWellBore.GetAllWellBoreAsync();
            var wellTask = Api.ClientWell.GetAllWellAsync();
            var clusterTask = Api.ClientCluster.GetAllClusterAsync();
            var rigTask = Api.ClientRig.GetAllRigAsync();

            await Task.WhenAll(calculationTask, trajectoryTask, wellBoreTask, wellTask, clusterTask, rigTask);

            calculationLightList_ = ((ICollection<TrajectoryMinimumDistanceCalculationLight>)await calculationTask).OrderBy(x => x.Name).ToList();
            trajectoryLightList_ = ((ICollection<TrajectoryLight>)await trajectoryTask).OrderBy(x => x.Name).ToList();
            wellBoreList_ = ((ICollection<WellBore>)await wellBoreTask).OrderBy(x => x.Name).ToList();
            wellList_ = ((ICollection<Well>)await wellTask).OrderBy(x => x.Name).ToList();
            clusterList_ = ((ICollection<Cluster>)await clusterTask).OrderBy(x => x.Name).ToList();
            rigList_ = ((ICollection<Rig>)await rigTask).OrderBy(x => x.Name).ToList();
            StartCalculationPollingIfNeeded();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem loading trajectory minimum distance calculations");
            Snackbar.Add("Failed to load minimum distance calculations.", Severity.Error);
        }

        gridKey_++;
        await InvokeAsync(StateHasChanged);
    }

    private RenderFragment CalculationStatusContent(TrajectoryMinimumDistanceCalculationLight calculation) => @<div style="min-width: 150px;">
        @if (IsCalculationActive(calculation))
        {
            <MudText Typo="Typo.caption">@calculation.CalculationState</MudText>
            <MudProgressLinear Value="@(100.0 * calculation.CalculationProgress)" Color="Color.Info" Size="Size.Small" />
        }
        else if (calculation.CalculationState == CalculationState.Failed)
        {
            <MudText Typo="Typo.caption" Color="Color.Error">@calculation.CalculationState</MudText>
        }
        else
        {
            <MudText Typo="Typo.caption">@calculation.CalculationState</MudText>
        }
    </div>;

    private void StartCalculationPollingIfNeeded()
    {
        if (calculationLightList_.Any(IsCalculationActive) || currentCalculation_ != null && IsCalculationActive(currentCalculation_))
        {
            if (pollingCancellation_ == null)
            {
                pollingCancellation_ = new CancellationTokenSource();
                _ = PollCalculationProgressAsync(pollingCancellation_.Token);
            }
        }
    }

    private async Task PollCalculationProgressAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
                calculationLightList_ = ((ICollection<TrajectoryMinimumDistanceCalculationLight>)await Api.ClientTrajectory.GetAllTrajectoryMinimumDistanceCalculationLightAsync()).OrderBy(x => x.Name).ToList();
                if (currentCalculation_?.MetaInfo?.ID is Guid id)
                {
                    currentCalculation_ = await Api.ClientTrajectory.GetTrajectoryMinimumDistanceCalculationByIdAsync(id);
                    currentCalculation_.ResultList ??= [];
                    if (currentCalculation_.CalculationState == CalculationState.Completed)
                    {
                        ResetResultLoadingState();
                    }
                }

                gridKey_++;
                await InvokeAsync(StateHasChanged);
                if (!calculationLightList_.Any(IsCalculationActive) && (currentCalculation_ == null || !IsCalculationActive(currentCalculation_)))
                {
                    break;
                }
            }
        }
        catch (TaskCanceledException)
        {
        }
        finally
        {
            pollingCancellation_?.Dispose();
            pollingCancellation_ = null;
        }
    }

    private async Task AddCalculation()
    {
        currentCalculationId_ = null;
        currentCalculation_ = CreateCalculation();
        currentCalculation_.ReferenceIntervalList ??= [];
        selectedReferenceTrajectoryId_ = null;
        ResetResultLoadingState();
        isEditing_ = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task EditCalculation(Guid id)
    {
        currentCalculationId_ = id;
        currentCalculation_ = await Api.ClientTrajectory.GetTrajectoryMinimumDistanceCalculationByIdAsync(id);
        currentCalculation_.ResultList ??= [];
        currentCalculation_.ReferenceIntervalList ??= [];
        selectedReferenceTrajectoryId_ = currentCalculation_.ReferenceTrajectoryID == Guid.Empty ? null : currentCalculation_.ReferenceTrajectoryID;
        ResetResultLoadingState();
        ApplyTrajectoryReferenceValues();
        isEditing_ = true;
        StartCalculationPollingIfNeeded();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveCalculation()
    {
        if (currentCalculation_ == null)
        {
            return;
        }

        if (selectedReferenceTrajectoryId_ is not Guid referenceId || referenceId == Guid.Empty)
        {
            Snackbar.Add("Choose a reference trajectory.", Severity.Warning);
            return;
        }

        if (currentCalculation_.ComparisonTrajectoryIDList is not { Count: > 0 })
        {
            Snackbar.Add("Choose at least one comparison trajectory.", Severity.Warning);
            return;
        }

        try
        {
            currentCalculation_.MetaInfo ??= PseudoConstructors.ConstructMetaInfo();
            currentCalculation_.ReferenceTrajectoryID = referenceId;
            currentCalculation_.LastModificationDate = DateTimeOffset.UtcNow;
            currentCalculation_.ResultList = null;
            currentCalculation_.IntervalResultList = null;
            if (currentCalculationId_ is Guid id)
            {
                await Api.ClientTrajectory.PutTrajectoryMinimumDistanceCalculationByIdAsync(id, currentCalculation_);
                currentCalculation_ = await Api.ClientTrajectory.GetTrajectoryMinimumDistanceCalculationByIdAsync(id);
                Snackbar.Add("Minimum distance calculation updated", Severity.Success);
            }
            else
            {
                currentCalculation_.MetaInfo.ID = currentCalculation_.MetaInfo.ID == Guid.Empty ? Guid.NewGuid() : currentCalculation_.MetaInfo.ID;
                currentCalculation_.CreationDate ??= DateTimeOffset.UtcNow;
                await Api.ClientTrajectory.PostTrajectoryMinimumDistanceCalculationAsync(currentCalculation_);
                currentCalculationId_ = currentCalculation_.MetaInfo.ID;
                currentCalculation_ = await Api.ClientTrajectory.GetTrajectoryMinimumDistanceCalculationByIdAsync(currentCalculationId_.Value);
                Snackbar.Add("Minimum distance calculation created", Severity.Success);
            }

            currentCalculation_.ResultList ??= [];
            ResetResultLoadingState();
            StartCalculationPollingIfNeeded();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error saving trajectory minimum distance calculation");
            Snackbar.Add("Error saving minimum distance calculation: " + ex.Message, Severity.Warning);
        }
    }

    private async Task CloseEditor()
    {
        isEditing_ = false;
        currentCalculation_ = null;
        currentCalculationId_ = null;
        await LoadDataAsync();
    }

    private Task OnReferenceTrajectoryChanged(Guid? id)
    {
        selectedReferenceTrajectoryId_ = id;
        if (currentCalculation_ != null)
        {
            currentCalculation_.ReferenceTrajectoryID = id ?? Guid.Empty;
            currentCalculation_.ComparisonTrajectoryIDList = currentCalculation_.ComparisonTrajectoryIDList?.Where(x => x != id).ToList();
            stagedComparisonTrajectoryIds_.Remove(id ?? Guid.Empty);
        }

        ApplyTrajectoryReferenceValues();
        return Task.CompletedTask;
    }

