    };

    private void OnAdaptiveRefinementEnabledChanged(bool value) => AdaptiveRefinement.Enabled = value;
    private void OnAdaptivePolarDeviationToleranceChanged(double? value) => AdaptiveRefinement.PolarDeviationTolerance = value;
    private void OnAdaptivePolarAngularToleranceChanged(double? value) => AdaptiveRefinement.PolarAngularTolerance = value;
    private void OnAdaptiveMinimumMDStepChanged(double? value) => AdaptiveRefinement.MinimumMDStep = value;
    private void OnAdaptiveMaximumDepthChanged(int value) => AdaptiveRefinement.MaximumDepth = value;
    private void OnAdaptiveMaximumExtraSamplesChanged(int value) => AdaptiveRefinement.MaximumExtraSamplesPerComparison = value;

    private static bool IsValidReferenceInterval(MinimumDistanceReferenceInterval interval) =>
        interval.StartMD is double start &&
        interval.EndMD is double end &&
        !double.IsNaN(start) &&
        !double.IsNaN(end) &&
        !double.IsInfinity(start) &&
        !double.IsInfinity(end) &&
        end > start;

    private TrajectoryMinimumDistanceIntervalResult? GetIntervalResult(Guid intervalId, Guid trajectoryId) =>
        currentCalculation_?.IntervalResultList?
            .FirstOrDefault(result => result.IntervalID == intervalId && result.ComparisonTrajectoryID == trajectoryId);

    private string GetIntervalLabel(MinimumDistanceReferenceInterval interval)
    {
        string name = string.IsNullOrWhiteSpace(interval.Name) ? "Interval" : interval.Name!;
        return $"{name} [{FormatDepth(interval.StartMD)} - {FormatDepth(interval.EndMD)}]";
    }

    private string FormatIntervalResult(TrajectoryMinimumDistanceIntervalResult? result)
    {
        if (result == null || result.SampleCount == 0)
        {
            return "-";
        }

        double? average = selectedDistanceMode_ == CenterDistanceMode
            ? result.AverageCenterToCenterDistance
            : result.AverageClearanceDistance;
        double? standardDeviation = selectedDistanceMode_ == CenterDistanceMode
            ? result.StandardDeviationCenterToCenterDistance
            : result.StandardDeviationClearanceDistance;
        return $"{FormatPosition(average)} +/- {FormatPosition(standardDeviation)} ({result.SampleCount})";
    }

    private string FormatDepth(double? value)
    {
        if (value == null)
        {
            return "-";
        }

        double converted = Parent?.FromSI(value.Value, "DepthDrilling") ?? value.Value;
        return converted.ToString("0.###");
    }

    private string FormatPosition(double? value)
    {
        if (value == null)
        {
            return "-";
        }

        double converted = Parent?.FromSI(value.Value, "PositionDrilling") ?? value.Value;
        return converted.ToString("0.###");
    }

    private async Task<bool> ConfirmDeletion()
    {
        var dialog = await DialogService.ShowAsync<DialogDeleteTemplate>("DELETE", new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        return result != null && !result.Canceled;
    }

    private async Task DeleteCalculation(Guid id)
    {
        try
        {
            if (await ConfirmDeletion())
            {
                await Api.ClientTrajectory.DeleteTrajectoryMinimumDistanceCalculationByIdAsync(id);
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete trajectory minimum distance calculation");
            Snackbar.Add("Failed to delete minimum distance calculation.", Severity.Error);
        }
    }

    private async Task DeleteSelectedCalculations()
    {
        List<TrajectoryMinimumDistanceCalculationLight> toDelete = selectedCalculationLightList_.ToList();
        if (toDelete.Count == 0)
        {
            return;
        }

        try
        {
            if (await ConfirmDeletion())
            {
                foreach (TrajectoryMinimumDistanceCalculationLight item in toDelete)
                {
                    await Api.ClientTrajectory.DeleteTrajectoryMinimumDistanceCalculationByIdAsync(item.MetaInfo.ID);
                }

                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete trajectory minimum distance calculations");
            Snackbar.Add("Failed to delete one or more minimum distance calculations.", Severity.Error);
        }
    }

    private void ApplyTrajectoryReferenceValues()
    {
        DataUtils.ApplyTrajectoryReferenceValues(selectedReferenceTrajectoryId_, trajectoryLightList_, wellBoreList_, wellList_, clusterList_, rigList_);
    }
