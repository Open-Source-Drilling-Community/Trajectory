    private async Task LoadDataAsync()
    {
        try
        {
            isEditing_ = false;
            surveyRunIdBeingEdited_ = null;
            selectedSurveyRunList_ = [];

            var fieldTask = Api.ClientField.GetAllFieldAsync();
            var clusterTask = Api.ClientCluster.GetAllClusterAsync();
            var wellTask = Api.ClientWell.GetAllWellAsync();
            var wellBoreTask = Api.ClientWellBore.GetAllWellBoreAsync();
            var rigTask = Api.ClientRig.GetAllRigAsync();
            var surveyInstrumentTask = Api.ClientSurveyInstrument.GetAllSurveyInstrumentLightAsync();
            var surveyRunTask = Api.ClientTrajectory.GetAllSurveyRunLightAsync();
            var surveyRunHeavyTask = Api.ClientTrajectory.GetAllSurveyRunAsync();

            await Task.WhenAll(fieldTask, clusterTask, wellTask, wellBoreTask, rigTask, surveyInstrumentTask, surveyRunTask, surveyRunHeavyTask);

            fieldList_ = fieldTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            clusterList_ = clusterTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            wellList_ = wellTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            wellBoreList_ = wellBoreTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            rigList_ = rigTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            surveyInstrumentList_ = surveyInstrumentTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            allSurveyRunList_ = surveyRunTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            allSurveyRunHeavyList_ = surveyRunHeavyTask.Result.Where(item => item != null).OrderBy(item => item.Name).ToList();
            surveyRunList_ = ApplySurveyRunFilters();
            gridKey_++;
            StartCalculationPollingIfNeeded();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while loading Survey Run data");
            Snackbar.Add("Problem while loading Survey Run data: " + ex.Message, Severity.Error);
        }
    }

    private RenderFragment CalculationStatusContent(SurveyRunLight surveyRun) => @<div style="min-width: 140px;">
        @if (surveyRun.CalculationState == CalculationState.Running || surveyRun.CalculationState == CalculationState.Queued)
        {
            <MudText Typo="Typo.caption">@surveyRun.CalculationState</MudText>
            <MudProgressLinear Value="@(100.0 * surveyRun.CalculationProgress)" Color="Color.Info" Size="Size.Small" />
        }
        else if (surveyRun.CalculationState == CalculationState.Failed)
        {
            <MudText Typo="Typo.caption" Color="Color.Error">@surveyRun.CalculationState</MudText>
        }
        else
        {
            <MudText Typo="Typo.caption">@surveyRun.CalculationState</MudText>
        }
    </div>;

    private void StartCalculationPollingIfNeeded()
    {
        if (surveyRunList_?.Any(IsCalculationActive) != true || calculationPollingCancellation_ != null)
        {
            return;
        }

        calculationPollingCancellation_ = new CancellationTokenSource();
        _ = PollCalculationProgressAsync(calculationPollingCancellation_.Token);
    }

    private async Task PollCalculationProgressAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
                allSurveyRunList_ = ((IEnumerable<SurveyRunLight>)await Api.ClientTrajectory.GetAllSurveyRunLightAsync()).OrderBy(item => item.Name).ToList();
                surveyRunList_ = ApplySurveyRunFilters();
                gridKey_++;
                await InvokeAsync(StateHasChanged);
                if (surveyRunList_?.Any(IsCalculationActive) != true)
                {
                    break;
                }
            }
        }
        catch (TaskCanceledException)
        {
        }
        finally
        {
            calculationPollingCancellation_?.Dispose();
            calculationPollingCancellation_ = null;
        }
    }

    private static bool IsCalculationActive(SurveyRunLight surveyRun) =>
        surveyRun.CalculationState == CalculationState.Running ||
        surveyRun.CalculationState == CalculationState.Queued;

    private List<SurveyRunLight> ApplySurveyRunFilters()
    {
        IEnumerable<SurveyRunLight> query = allSurveyRunList_ ?? [];

        if (listSelectedFieldId_ is Guid fieldId)
        {
            query = query.Where(surveyRun => surveyRun.FieldID == fieldId);
        }
        if (listSelectedClusterId_ is Guid clusterId)
        {
            query = query.Where(surveyRun => surveyRun.ClusterID == clusterId);
        }
        if (listSelectedWellId_ is Guid wellId)
        {
            query = query.Where(surveyRun => surveyRun.WellID == wellId);
        }
        if (listSelectedWellBoreId_ is Guid wellBoreId)
        {
            query = query.Where(surveyRun => surveyRun.WellBoreID == wellBoreId);
        }

        return query.OrderBy(surveyRun => surveyRun.Name).ToList();
    }

