    private double? GetSelectedWellheadMd()
    {
        if (selectedWellBoreId_ is not Guid wellBoreId)
        {
            return null;
        }

        WellBore? wellBore = wellBoreList_?.FirstOrDefault(item => item?.MetaInfo?.ID == wellBoreId);
        Well? well = wellBore?.WellID is Guid wellId
            ? wellList_?.FirstOrDefault(item => item?.MetaInfo?.ID == wellId)
            : null;
        Cluster? cluster = well?.ClusterID is Guid clusterId
            ? clusterList_?.FirstOrDefault(item => item?.MetaInfo?.ID == clusterId)
            : null;

        return cluster?.ReferenceDepth?.GaussianValue?.Mean;
    }

    private void UpdateSelectedSurveyRunReferenceSource()
    {
        DataUtils.GroundMudLineDepthReferenceSource.GroundMudLineDepthReference = 0;
        DataUtils.SeaWaterLevelDepthReferenceSource.SeaWaterLevelDepthReference = 0;
        DataUtils.RotaryTableDepthReferenceSource.RotaryTableDepthReference = 0;
        DataUtils.WellHeadPositionReferenceSource.WellHeadNorthPositionReference = 0;
        DataUtils.WellHeadPositionReferenceSource.WellHeadEastPositionReference = 0;

        if (selectedWellBoreId_ is not Guid wellBoreId)
        {
            measurementReferenceRenderVersion_++;
            return;
        }

        WellBore? wellBore = wellBoreList_?.FirstOrDefault(item => item?.MetaInfo?.ID == wellBoreId);
        Well? well = wellBore?.WellID is Guid wellId
            ? wellList_?.FirstOrDefault(item => item?.MetaInfo?.ID == wellId)
            : null;
        Cluster? cluster = well?.ClusterID is Guid clusterId
            ? clusterList_?.FirstOrDefault(item => item?.MetaInfo?.ID == clusterId)
            : null;
        Rig? rig = FindRigForWellBore(wellBore, cluster);

        if (cluster?.GroundMudLineDepth?.GaussianValue?.Mean is { } groundMudLineDepth)
        {
            DataUtils.ApplyGroundMudLineDepthWGS84(groundMudLineDepth);
        }
        if (cluster?.TopWaterDepth?.GaussianValue?.Mean is { } topWaterDepth)
        {
            DataUtils.ApplyTopWaterDepthWGS84(topWaterDepth);
        }
        DataUtils.ApplyRotaryTableDepthnWGS84(rig?.DrillFloorElevation);

        UpdateWellheadPositionReference(well, cluster);
        measurementReferenceRenderVersion_++;
    }

    private Rig? FindRigForWellBore(WellBore? wellBore, Cluster? cluster)
    {
        Guid? rigId = wellBore?.RigID;
        if (rigId == null && cluster?.IsFixedPlatform == true && cluster.RigID != null)
        {
            rigId = cluster.RigID;
        }

        return rigId is Guid definedRigId
            ? rigList_?.FirstOrDefault(rig => rig?.MetaInfo?.ID == definedRigId)
            : null;
    }

    private static void UpdateWellheadPositionReference(Well? well, Cluster? cluster)
    {
        if (well?.SlotID is not Guid slotId || cluster?.Slots == null)
        {
            return;
        }

        Slot? slot = cluster.Slots.Values.FirstOrDefault(item => item?.ID == slotId);
        if (slot?.Latitude?.GaussianValue?.Mean is { } latitude &&
            slot.Longitude?.GaussianValue?.Mean is { } longitude)
        {
            OSDC.DotnetLibraries.Drilling.Surveying.SurveyPoint surveyPoint = new()
            {
                Latitude = latitude,
                Longitude = longitude
            };
            if (surveyPoint.RiemannianNorth != null && surveyPoint.RiemannianEast != null)
            {
                DataUtils.WellHeadPositionReferenceSource.WellHeadNorthPositionReference = -surveyPoint.RiemannianNorth;
                DataUtils.WellHeadPositionReferenceSource.WellHeadEastPositionReference = -surveyPoint.RiemannianEast;
            }
        }
    }

    private bool IsParentSurveyRunCandidate(SurveyRun candidate)
    {
        if (currentSurveyRun_ == null ||
            GetFirstSurveyStationMd(currentSurveyRun_) is not { } firstMd ||
            candidate.SurveyStationList is not { Count: > 0 } stations)
        {
            return false;
        }

        List<double> candidateMds = stations
            .Select(station => station.MD ?? station.Abscissa)
            .Where(md => md.HasValue)
            .Select(md => md!.Value)
            .OrderBy(md => md)
            .ToList();

        if (candidateMds.Count == 0)
        {
            return false;
        }

        const double maxTieInGap = 10.0;
        double firstParentMd = candidateMds.First();
        double lastParentMd = candidateMds.Last();
        return (firstParentMd <= firstMd && firstMd <= lastParentMd) ||
               (lastParentMd <= firstMd && firstMd - lastParentMd <= maxTieInGap);
    }

