    private async Task ImportSurveyStationsAsync()
    {
        if (currentSurveyRun_ == null || surveyImportFile_ == null)
        {
            Snackbar.Add("Select a survey file before importing", Severity.Warning);
            return;
        }

        try
        {
            UpdateSelectedSurveyRunReferenceSource();
            using System.IO.Stream stream = surveyImportFile_.OpenReadStream(128 * 1024 * 1024);
            using System.IO.StreamReader reader = new(stream);
            string content = await reader.ReadToEndAsync();
            string[] lines = content.Split(["\r\n", "\n", "\r"], StringSplitOptions.None);

            List<SurveyMeasurement> importedMeasurements = [];
            int skippedLines = 0;
            double? previousMD = null;

            foreach (string line in lines)
            {
                if (!TryParseSurveyStationLine(line, out SurveyStation? station))
                {
                    skippedLines++;
                    continue;
                }

                if (station?.MD == null || previousMD is { } previous && station.MD <= previous)
                {
                    skippedLines++;
                    continue;
                }

                importedMeasurements.Add(SurveyMeasurement.FromSurveyStation(station));
                previousMD = station.MD;
            }

            if (importedMeasurements.Count == 0)
            {
                Snackbar.Add("No survey measurements could be imported", Severity.Warning);
                return;
            }

            currentSurveyRun_.SurveyMeasurementList = importedMeasurements;
            ClearInvalidParentSurveyRunSelection();
            ClearCalculatedSurveyRunData();
            UpdatePlots();
            selectedSurveyStations_.Clear();
            Snackbar.Add($"Imported {importedMeasurements.Count} survey measurements. Skipped {skippedLines} lines.", Severity.Success);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error importing survey stations");
            Snackbar.Add("Error importing survey stations: " + ex.Message, Severity.Error);
        }
    }

    private bool TryParseSurveyStationLine(string line, out SurveyStation? station)
    {
        station = null;
        if (string.IsNullOrWhiteSpace(line))
        {
            return false;
        }

        string? mdToken;
        string? inclinationToken;
        string? azimuthToken;

        if (!IsDelimitedImportFormat)
        {
            mdToken = ReadFixedWidthToken(line, surveyImportMDStart_, surveyImportMDWidth_);
            inclinationToken = ReadFixedWidthToken(line, surveyImportInclinationStart_, surveyImportInclinationWidth_);
            azimuthToken = ReadFixedWidthToken(line, surveyImportAzimuthStart_, surveyImportAzimuthWidth_);
        }
        else
        {
            List<string> columns = SplitDelimitedColumns(line);
            mdToken = ReadColumnToken(columns, surveyImportMDColumn_);
            inclinationToken = ReadColumnToken(columns, surveyImportInclinationColumn_);
            azimuthToken = ReadColumnToken(columns, surveyImportAzimuthColumn_);
        }

        if (!TryParseImportedNumber(mdToken, out double md) ||
            !TryParseImportedNumber(inclinationToken, out double inclination) ||
            !TryParseImportedNumber(azimuthToken, out double azimuth))
        {
            return false;
        }

        station = new SurveyStation
        {
            MD = ConvertDepthToSI(md, selectedSurveyImportMDUnit_),
            Inclination = ConvertAngleToSI(inclination, selectedSurveyImportInclinationUnit_),
            Azimuth = ConvertAngleToSI(azimuth, selectedSurveyImportAzimuthUnit_)
        };
        return true;
    }

    private List<string> SplitDelimitedColumns(string line)
    {
        return selectedSurveyImportSeparator_ switch
        {
            "Semicolon (;)" => line.Split(';').Select(value => value.Trim()).ToList(),
            "Tab" => line.Split('\t').Select(value => value.Trim()).ToList(),
            "Space" => Regex.Split(line.Trim(), @"\s+").Where(value => !string.IsNullOrWhiteSpace(value)).ToList(),
            _ => line.Split(';').Select(value => value.Trim()).ToList()
        };
    }

    private static string? ReadColumnToken(List<string> columns, int columnIndex)
    {
        if (columnIndex < 1 || columnIndex > columns.Count)
        {
            return null;
        }

        return columns[columnIndex - 1];
    }

    private static string? ReadFixedWidthToken(string line, int start, int width)
    {
        if (start < 1 || width < 1)
        {
            return null;
        }

        int zeroBasedStart = start - 1;
        if (zeroBasedStart >= line.Length)
        {
            return null;
        }

        int safeWidth = Math.Min(width, line.Length - zeroBasedStart);
        return line.Substring(zeroBasedStart, safeWidth).Trim();
    }

    private bool TryParseImportedNumber(string? token, out double value)
    {
        value = 0;
        if (string.IsNullOrWhiteSpace(token))
        {
            return false;
        }

        string normalized = token.Trim();
        if (selectedSurveyImportDecimalMarker_ == "Dot (.)")
        {
            normalized = normalized.Replace(",", string.Empty);
        }
        else if (selectedSurveyImportDecimalMarker_ == "Comma (,)")
        {
            normalized = normalized.Replace(".", string.Empty).Replace(',', '.');
        }
        else
        {
            normalized = NormalizeAutoDecimalNumber(normalized);
        }

        return double.TryParse(normalized, NumberStyles.Float | NumberStyles.AllowLeadingSign, CultureInfo.InvariantCulture, out value);
    }

    private static string NormalizeAutoDecimalNumber(string token)
    {
        int lastComma = token.LastIndexOf(',');
        int lastDot = token.LastIndexOf('.');
        if (lastComma >= 0 && lastDot >= 0)
        {
            return lastComma > lastDot
                ? token.Replace(".", string.Empty).Replace(',', '.')
                : token.Replace(",", string.Empty);
        }
        if (lastComma >= 0)
        {
            return token.Replace(',', '.');
        }
        return token;
    }

    private static List<string> GetAvailableSurveyImportUnits(List<OSDC.UnitConversion.Conversion.UnitChoice> unitChoices)
    {
        HashSet<string> unitLabels = new(StringComparer.OrdinalIgnoreCase);
        foreach (var choice in unitChoices)
        {
            if (!string.IsNullOrWhiteSpace(choice?.UnitName))
            {
                unitLabels.Add(choice.UnitName);
            }
        }
        return unitLabels.OrderBy(unit => unit).ToList();
    }

    private double ConvertDepthToSI(double value, string unit)
    {
        OSDC.UnitConversion.Conversion.UnitChoice? unitChoice = DepthDrillingQuantity.UnitChoiceDescriptions
            .FirstOrDefault(choice => choice != null && choice.UnitName == unit);
        if (unitChoice != null)
        {
            value = DepthDrillingQuantity.Instance.ToSI(value, unitChoice.ID);
        }

        value -= GetSelectedDepthReferenceDelta();
        return value;
    }

    private static double GetSelectedDepthReferenceDelta()
    {
        return DataUtils.UnitAndReferenceParameters.DepthReferenceName switch
        {
            "Ground/Mud line" or "Mud-line/Ground Level" => DataUtils.GroundMudLineDepthReferenceSource.GroundMudLineDepthReference ?? 0.0,
            "Sea water level" or "Sea/Water Level" => DataUtils.SeaWaterLevelDepthReferenceSource.SeaWaterLevelDepthReference ?? 0.0,
            "Rotary table" => DataUtils.RotaryTableDepthReferenceSource.RotaryTableDepthReference ?? 0.0,
            _ => 0.0
        };
    }

    private static double ConvertAngleToSI(double value, string unit)
    {
        OSDC.UnitConversion.Conversion.UnitChoice? unitChoice = PlaneAngleDrillingQuantity.UnitChoiceDescriptions
            .FirstOrDefault(choice => choice != null && choice.UnitName == unit);
        return unitChoice == null ? value : PlaneAngleDrillingQuantity.Instance.ToSI(value, unitChoice.ID);
    }

    private void UpdatePlots()
    {
        if (currentSurveyRun_ == null)
        {
            nameList.Clear();
            modeFlagList.Clear();
            colorList.Clear();
            northValuesList.Clear();
            eastValuesList.Clear();
            tvdValuesList.Clear();
            verticalSectionValuesList.Clear();
            return;
        }

        Trajectory plotTrajectory = new()
        {
            Name = currentSurveyRun_.Name,
            SurveyStationList = currentSurveyRun_.SurveyStationList
        };

        DataUtils.UpdatePlots(
            nameList,
            modeFlagList,
            colorList,
            northValuesList,
            eastValuesList,
            tvdValuesList,
            verticalSectionValuesList,
            [plotTrajectory]
        );
        UpdateUncertaintyPlotData();
    }

    private async Task OnEllipseResultsChanged(ICollection<SurveyStationEllipseResult> results)
    {
        ellipseResults = results?.ToList() ?? [];
        ellipseCalculation = null;
        UpdateUncertaintyPlotData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnEllipseCalculationChanged(SurveyStationEllipseCalculation? calculation)
    {
        ellipseCalculation = calculation;
        UpdateUncertaintyPlotData();
        await InvokeAsync(StateHasChanged);
    }

    private void UpdateUncertaintyPlotData()
    {
        DataUtils.UpdateEllipsePlots(currentSurveyRun_?.SurveyStationList?.ToList(), ellipseResults, ellipsePlotData);
        DataUtils.AddExtremeTvdPathPlots(ellipseCalculation, ellipsePlotData);
    }

    private static string GetCalculationMethodLabel(TrajectoryCalculationType method) =>
        method switch
        {
            TrajectoryCalculationType.MinimumCurvatureMethod => "Minimum Curvature Method",
            TrajectoryCalculationType.ConstantBuildAndTurnMethod => "Constant Build and Turn Rates",
            TrajectoryCalculationType.ConstantCurvatureAndToolfaceMethod => "Constant Curvature and Toolface",
            _ => method.ToString()
        };

    private string NorthCoordinateLabel => GetCoordinateLabel(PositionDirectionType.North);

    private string EastCoordinateLabel => GetCoordinateLabel(PositionDirectionType.East);

    private string GetCoordinateLabel(PositionDirectionType direction)
    {
        string? positionReferenceName = UnitReference?.PositionReferenceName ?? DataUtils.UnitAndReferenceParameters.PositionReferenceName;
        if (string.Equals(positionReferenceName, "WGS84", StringComparison.OrdinalIgnoreCase))
        {
            return direction == PositionDirectionType.North ? "Riemann North" : "Riemann East";
        }

        if (string.Equals(positionReferenceName, "Cartographic", StringComparison.OrdinalIgnoreCase))
        {
            return direction == PositionDirectionType.North ? "Northing" : "Easting";
        }

        return direction == PositionDirectionType.North ? "North" : "East";
    }

    private string FormatDepthValue(double? value) =>
        UnitReference != null && value is not null
            ? UnitReference.FromWGS84DepthSI(value, "DepthDrilling", true)
            : string.Empty;

    private string FormatPositionValue(double? value, PositionDirectionType direction) =>
        UnitReference != null && value is not null
            ? UnitReference.FromWGS84PositionSI(value, "PositionDrilling", true, direction)
            : string.Empty;

    private string FormatAngleValue(double? value) =>
        UnitReference != null && value is not null
            ? UnitReference.FromSI(value, "PlaneAngleDrilling", true)
            : string.Empty;

    private string ConvertDepthForExport(double? value) =>
        UnitReference != null && value is not null
            ? UnitReference.FromWGS84DepthSI(value, "DepthDrilling", false)
            : FormatExportNumber(value);

    private string ConvertPositionForExport(double? value, PositionDirectionType direction) =>
        UnitReference != null && value is not null
            ? UnitReference.FromWGS84PositionSI(value, "PositionDrilling", false, direction)
            : FormatExportNumber(value);

    private string ConvertQuantityForExport(double? value, string quantityName) =>
        UnitReference != null && value is not null
            ? UnitReference.FromSI(value, quantityName, false)
            : FormatExportNumber(value);

    private async Task ExportSurveyStationsAsync()
    {
        if (currentSurveyRun_?.SurveyMeasurementList is not { Count: > 0 } surveyMeasurements)
        {
            Snackbar.Add("No survey measurements to export", Severity.Warning);
            return;
        }

        string[] headers =
        [
            "Measured Depth [m]",
            "Inclination [rad]",
            "Azimuth [rad]"
        ];
        string content = BuildTabSeparatedContent(
            headers,
            surveyMeasurements.Select(measurement => new[]
            {
                FormatExportNumber(measurement.MD),
                FormatExportNumber(measurement.Inclination),
                FormatExportNumber(measurement.Azimuth)
            }));

        try
        {
            string surveyRunName = string.IsNullOrWhiteSpace(currentSurveyRun_.Name) ? "survey-run" : currentSurveyRun_.Name;
            string fileName = $"{SanitizeFileName(surveyRunName)}-survey-measurements.tsv";
            string base64Content = Convert.ToBase64String(Encoding.UTF8.GetBytes(content));

            await JSRuntime.InvokeVoidAsync("trajectoryDownloads.saveTextFileFromBase64", fileName, base64Content, "text/tab-separated-values;charset=utf-8");
            Snackbar.Add("Exported survey measurements", Severity.Success);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error exporting survey stations");
            Snackbar.Add("Error exporting survey stations: " + ex.Message, Severity.Warning);
        }
    }

    private async Task ExportCalculatedSurveyRunAsync()
    {
        if (currentSurveyRun_?.SurveyStationList is not { Count: > 0 } calculatedStations)
        {
            Snackbar.Add("No calculated survey run to export", Severity.Warning);
            return;
        }

        string[] headers =
        [
            $"Measured Depth [{DepthUnitLabel}]",
            $"Inclination [{AngleUnitLabel}]",
            $"Azimuth [{AngleUnitLabel}]",
            $"Vertical Depth [{DepthUnitLabel}]",
            $"{NorthCoordinateLabel} [{PositionUnitLabel}]",
            $"{EastCoordinateLabel} [{PositionUnitLabel}]",
            $"Vertical Section [{LengthUnitLabel}]",
            $"Curvature [{CurvatureUnitLabel}]",
            $"BUR [{CurvatureUnitLabel}]",
            $"TR [{CurvatureUnitLabel}]"
        ];

        string content = BuildTabSeparatedContent(
            headers,
            calculatedStations.Select(station => new[]
            {
                ConvertDepthForExport(station.MD),
                ConvertQuantityForExport(station.Inclination, "PlaneAngleDrilling"),
                ConvertQuantityForExport(station.Azimuth, "PlaneAngleDrilling"),
                ConvertDepthForExport(station.TVD),
                ConvertPositionForExport(station.RiemannianNorth, PositionDirectionType.North),
                ConvertPositionForExport(station.RiemannianEast, PositionDirectionType.East),
                ConvertQuantityForExport(station.VerticalSection, "DepthDrilling"),
                ConvertQuantityForExport(station.Curvature, "CurvatureDrilling"),
                ConvertQuantityForExport(station.BUR, "CurvatureDrilling"),
                ConvertQuantityForExport(station.TUR, "CurvatureDrilling")
            }));

        try
        {
            string surveyRunName = string.IsNullOrWhiteSpace(currentSurveyRun_.Name) ? "survey-run" : currentSurveyRun_.Name;
            string fileName = $"{SanitizeFileName(surveyRunName)}-calculated-survey-run.tsv";
            string base64Content = Convert.ToBase64String(Encoding.UTF8.GetBytes(content));

            await JSRuntime.InvokeVoidAsync("trajectoryDownloads.saveTextFileFromBase64", fileName, base64Content, "text/tab-separated-values;charset=utf-8");
            Snackbar.Add("Exported calculated survey run", Severity.Success);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error exporting calculated survey run");
            Snackbar.Add("Error exporting calculated survey run: " + ex.Message, Severity.Warning);
        }
    }

    private static string BuildTabSeparatedContent(IEnumerable<string> headers, IEnumerable<IEnumerable<string>> rows)
    {
        StringBuilder builder = new();
        builder.AppendLine(string.Join('\t', headers.Select(SanitizeExportField)));

        foreach (IEnumerable<string> row in rows)
        {
            builder.AppendLine(string.Join('\t', row.Select(SanitizeExportField)));
        }

        return builder.ToString();
    }

    private static string FormatExportNumber(double? value) =>
        value?.ToString("G17", CultureInfo.InvariantCulture) ?? string.Empty;

    private static string SanitizeExportField(string? value) =>
        (value ?? string.Empty).Replace('\t', ' ').ReplaceLineEndings(" ");

    private static string SanitizeFileName(string value)
    {
        char[] invalidCharacters = Path.GetInvalidFileNameChars();
        string sanitized = new(value.Select(ch => invalidCharacters.Contains(ch) ? '-' : ch).ToArray());
        return string.IsNullOrWhiteSpace(sanitized) ? "survey-run" : sanitized;
    }

    private static string FormatDate(DateTimeOffset? value) =>
        value?.ToLocalTime().ToString("g", CultureInfo.CurrentCulture) ?? string.Empty;
}


