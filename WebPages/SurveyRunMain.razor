    private async Task EditSurveyRunAsync(Guid surveyRunId)
    {
        try
        {
            currentSurveyRun_ = await Api.ClientTrajectory.GetSurveyRunByIdAsync(surveyRunId);
            await LoadSurveyMeasurementsAsync(currentSurveyRun_);
            surveyRunIdBeingEdited_ = surveyRunId;
            selectedFieldId_ = currentSurveyRun_.FieldID;
            selectedClusterId_ = currentSurveyRun_.ClusterID;
            selectedWellId_ = currentSurveyRun_.WellID;
            selectedWellBoreId_ = currentSurveyRun_.WellBoreID == Guid.Empty ? null : currentSurveyRun_.WellBoreID;
            selectedSurveyInstrumentId_ = currentSurveyRun_.SurveyInstrumentID == Guid.Empty ? null : currentSurveyRun_.SurveyInstrumentID;
            selectedParentSurveyRunId_ = currentSurveyRun_.ParentSurveyRunID;
            selectedSurveyStations_.Clear();
            isEditing_ = true;
            await InvokeAsync(StateHasChanged);
            currentSurveyRun_.SurveyStationList ??= new List<SurveyStation>();
            ResetCalculatedStationLoadingState();
            EnsureSurveyImportUnitsSelected();
            UpdateSelectedSurveyRunReferenceSource();
            UpdatePlots();
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while loading Survey Run {SurveyRunId}", surveyRunId);
            Snackbar.Add("Problem while loading Survey Run: " + ex.Message, Severity.Error);
        }
    }

    private async Task LoadSurveyMeasurementsAsync(SurveyRun? surveyRun)
    {
        if (surveyRun?.MetaInfo?.ID is not Guid surveyRunId || surveyRunId == Guid.Empty)
        {
            return;
        }

        int chunkCount = await Api.ClientTrajectory.GetSurveyRunSurveyMeasurementChunkCountAsync(surveyRunId);
        if (chunkCount > 0)
        {
            List<SurveyMeasurement> measurements = [];
            for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
            {
                SurveyMeasurementChunk chunk = await Api.ClientTrajectory.GetSurveyRunSurveyMeasurementChunkAsync(surveyRunId, chunkIndex);
                if (chunk.SurveyMeasurementList is { Count: > 0 } chunkMeasurements)
                {
                    measurements.AddRange(chunkMeasurements);
                }
            }

            surveyRun.SurveyMeasurementList = measurements;
            return;
        }

        surveyRun.SurveyMeasurementList ??= surveyRun.SurveyStationList?
            .Select(SurveyMeasurement.FromSurveyStation)
            .ToList() ?? [];
    }

    private async Task LoadSurveyRunCalculatedStationsAsync(SurveyRun? surveyRun)
    {
        if (surveyRun?.MetaInfo?.ID is not Guid surveyRunId || surveyRunId == Guid.Empty)
        {
            return;
        }

        isLoadingCalculatedStations_ = true;
        calculatedStationLoadComplete_ = false;
        calculatedStationChunkCount_ = 0;
        calculatedStationChunksLoaded_ = 0;
        calculatedStationsLoaded_ = 0;
        surveyRun.SurveyStationList = [];
        await InvokeAsync(StateHasChanged);

        try
        {
            int chunkCount = await Api.ClientTrajectory.GetSurveyRunSurveyStationChunkCountAsync(surveyRunId);
            calculatedStationChunkCount_ = chunkCount;
            await InvokeAsync(StateHasChanged);
            if (chunkCount <= 0)
            {
                surveyRun.SurveyStationList ??= [];
                calculatedStationLoadComplete_ = true;
                return;
            }

            List<SurveyStation> stations = [];
            for (int chunkIndex = 0; chunkIndex < chunkCount; chunkIndex++)
            {
                SurveyStationChunk chunk = await Api.ClientTrajectory.GetSurveyRunSurveyStationChunkAsync(surveyRunId, chunkIndex);
                if (chunk.SurveyStationList is { Count: > 0 } chunkStations)
                {
                    stations.AddRange(chunkStations);
                }

                calculatedStationChunksLoaded_ = chunkIndex + 1;
                calculatedStationsLoaded_ = stations.Count;
                if (chunkIndex == 0 || calculatedStationChunksLoaded_ == chunkCount || calculatedStationChunksLoaded_ % 5 == 0)
                {
                    await InvokeAsync(StateHasChanged);
                }
            }

            surveyRun.SurveyStationList = stations;
            calculatedStationLoadComplete_ = true;
            UpdatePlots();
        }
        finally
        {
            isLoadingCalculatedStations_ = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveSurveyMeasurementChunksAsync(Guid surveyRunId, List<SurveyMeasurement> measurements)
    {
        await Api.ClientTrajectory.DeleteSurveyRunSurveyMeasurementChunksAsync(surveyRunId);
        int chunkIndex = 0;
        foreach (List<SurveyMeasurement> measurementChunk in measurements.Chunk(SurveyMeasurementChunkSize).Select(chunk => chunk.ToList()))
        {
            SurveyMeasurementChunk chunk = new()
            {
                SurveyRunID = surveyRunId,
                ChunkIndex = chunkIndex,
                MeasurementCount = measurementChunk.Count,
                StartMD = measurementChunk.FirstOrDefault()?.MD,
                EndMD = measurementChunk.LastOrDefault()?.MD,
                SurveyMeasurementList = measurementChunk
            };
            await Api.ClientTrajectory.PutSurveyRunSurveyMeasurementChunkAsync(surveyRunId, chunkIndex, chunk);
            chunkIndex++;
        }
    }

    private static SurveyRun CreateSurveyRunMetadataCopy(SurveyRun source)
    {
        return new SurveyRun
        {
            MetaInfo = source.MetaInfo,
            Name = source.Name,
            Description = source.Description,
            CreationDate = source.CreationDate,
            LastModificationDate = source.LastModificationDate,
            FieldID = source.FieldID,
            ClusterID = source.ClusterID,
            WellID = source.WellID,
            WellBoreID = source.WellBoreID,
            SurveyInstrumentID = source.SurveyInstrumentID,
            SurveyRunType = source.SurveyRunType,
            CalculationType = source.CalculationType,
            ParentSurveyRunID = source.ParentSurveyRunID,
            TieInPoint = source.TieInPoint,
            SurveyMeasurementList = null,
            SurveyStationList = null
        };
    }

    private async Task SaveSurveyRunAsync()
    {
        if (currentSurveyRun_ == null)
        {
            return;
        }
        if (string.IsNullOrWhiteSpace(currentSurveyRun_.Name))
        {
            Snackbar.Add("Survey Run name is required", Severity.Warning);
            return;
        }
        if (selectedWellBoreId_ is not Guid wellBoreId)
        {
            Snackbar.Add("Select a WellBore", Severity.Warning);
            return;
        }
        if (selectedSurveyInstrumentId_ is not Guid surveyInstrumentId)
        {
            Snackbar.Add("Select a Survey Instrument", Severity.Warning);
            return;
        }
        if (currentSurveyRun_.SurveyMeasurementList is not { Count: > 0 })
        {
            Snackbar.Add("Add at least one survey measurement", Severity.Warning);
            return;
        }
        if (IsParentSurveyRunRequired && selectedParentSurveyRunId_ is not Guid)
        {
            Snackbar.Add("Select a parent Survey Run", Severity.Warning);
            return;
        }

        try
        {
            currentSurveyRun_.FieldID = selectedFieldId_;
            currentSurveyRun_.ClusterID = selectedClusterId_;
            currentSurveyRun_.WellID = selectedWellId_;
            currentSurveyRun_.WellBoreID = wellBoreId;
            currentSurveyRun_.SurveyInstrumentID = surveyInstrumentId;
            currentSurveyRun_.ParentSurveyRunID = IsParentSurveyRunRequired ? selectedParentSurveyRunId_ : null;
            List<SurveyMeasurement> surveyMeasurements = currentSurveyRun_.SurveyMeasurementList
                .OrderBy(measurement => measurement.MD ?? double.MaxValue)
                .ToList();
            currentSurveyRun_.SurveyMeasurementList = surveyMeasurements;
            currentSurveyRun_.LastModificationDate = DateTimeOffset.UtcNow;
            SurveyRun metadata = CreateSurveyRunMetadataCopy(currentSurveyRun_);

            if (surveyRunIdBeingEdited_ is Guid surveyRunId)
            {
                await Api.ClientTrajectory.PutSurveyRunByIdAsync(surveyRunId, metadata);
                await SaveSurveyMeasurementChunksAsync(surveyRunId, surveyMeasurements);
                await Api.ClientTrajectory.CommitSurveyRunSurveyMeasurementChunksAsync(surveyRunId);
                await RefreshSurveyRunAfterCalculationAsync(surveyRunId, surveyMeasurements);
                Snackbar.Add("Survey Run updated successfully", Severity.Success);
            }
            else
            {
                currentSurveyRun_.CreationDate ??= DateTimeOffset.UtcNow;
                metadata.CreationDate = currentSurveyRun_.CreationDate;
                await Api.ClientTrajectory.PostSurveyRunAsync(metadata);
                surveyRunIdBeingEdited_ = currentSurveyRun_.MetaInfo?.ID;
                if (surveyRunIdBeingEdited_ is Guid createdSurveyRunId)
                {
                    await SaveSurveyMeasurementChunksAsync(createdSurveyRunId, surveyMeasurements);
                    await Api.ClientTrajectory.CommitSurveyRunSurveyMeasurementChunksAsync(createdSurveyRunId);
                    await RefreshSurveyRunAfterCalculationAsync(createdSurveyRunId, surveyMeasurements);
                }
                Snackbar.Add("Survey Run created successfully", Severity.Success);
            }

            currentSurveyRun_.SurveyStationList ??= new List<SurveyStation>();
            selectedParentSurveyRunId_ = currentSurveyRun_.ParentSurveyRunID;
            selectedSurveyStations_.Clear();
            allSurveyRunList_ = ((IEnumerable<SurveyRunLight>)await Api.ClientTrajectory.GetAllSurveyRunLightAsync()).OrderBy(item => item.Name).ToList();
            allSurveyRunHeavyList_ = ((IEnumerable<SurveyRun>)await Api.ClientTrajectory.GetAllSurveyRunAsync()).OrderBy(item => item.Name).ToList();
            surveyRunList_ = ApplySurveyRunFilters();
            UpdatePlots();
            isEditing_ = true;
        }
        catch (ApiException ex)
        {
            logger.LogError(ex, "Problem while saving Survey Run");
            Snackbar.Add("Problem while saving Survey Run: " + ex.Response, Severity.Error);
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while saving Survey Run");
            Snackbar.Add("Problem while saving Survey Run: " + ex.Message, Severity.Error);
        }
    }

    private async Task RefreshSurveyRunAfterCalculationAsync(Guid surveyRunId, List<SurveyMeasurement> surveyMeasurements)
    {
        currentSurveyRun_ = await Api.ClientTrajectory.GetSurveyRunByIdAsync(surveyRunId);
        currentSurveyRun_.SurveyMeasurementList = surveyMeasurements;
        await PollSurveyRunCalculationAsync(surveyRunId, surveyMeasurements);
        currentSurveyRun_ = await Api.ClientTrajectory.GetSurveyRunByIdAsync(surveyRunId);
        await LoadSurveyMeasurementsAsync(currentSurveyRun_);
        currentSurveyRun_.SurveyStationList ??= [];
        ResetCalculatedStationLoadingState();
        StartCalculatedStationLoading();
    }

