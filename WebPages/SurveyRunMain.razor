@page "/SurveyRun"
@inject ILogger<SurveyRunMain> logger
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject ITrajectoryAPIUtils Api
@using System.Globalization
@using System.Text.RegularExpressions
@using OSDC.UnitConversion.Conversion.DrillingEngineering

<MudUnitAndReferenceChoiceTag @ref="unitReferenceTag_"
                              HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@OnUnitSystemNameChanged"
                              DepthReferenceName="@DataUtils.UnitAndReferenceParameters.DepthReferenceName"
                              DepthReferenceNameChanged="@OnDepthReferenceNameChanged"
                              GroundMudLineDepthReferenceSource="@DataUtils.GroundMudLineDepthReferenceSource"
                              SeaWaterLevelDepthReferenceSource="@DataUtils.SeaWaterLevelDepthReferenceSource"
                              RotaryTableDepthReferenceSource="@DataUtils.RotaryTableDepthReferenceSource"
                              PositionReferenceName="@DataUtils.UnitAndReferenceParameters.PositionReferenceName"
                              PositionReferenceNameChanged="@OnPositionReferenceNameChanged"
                              WellHeadPositionReferenceSource="@DataUtils.WellHeadPositionReferenceSource"
                              CartographicGridPositionReferenceSource="@DataUtils.CartographicGridPositionReferenceSource"
                              LeaseLinePositionReferenceSource="@DataUtils.LeaseLinePositionReferenceSource"
                              ClusterPositionReferenceSource="@DataUtils.ClusterPositionReferenceSource">
    @if (isEditing_)
    {
        <MudText Class="mt-4 mb-4" Typo="Typo.h6">Edit Survey Run</MudText>
        <MudContainer Class="d-flex flex-row mt-4 mb-4">
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveSurveyRunAsync">Save</MudButton>
            <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="CloseEditorAsync">Cancel</MudButton>
        </MudContainer>
        @if (currentSurveyRun_ is { CalculationState: CalculationState.Running or CalculationState.Queued })
        {
            <MudProgressLinear Value="@(100.0 * currentSurveyRun_.CalculationProgress)" Color="Color.Info" Class="mb-3" />
        }

        @if (currentSurveyRun_ is { } surveyRun)
        {
            <MudGrid>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="surveyRun.Name" Label="Name" Required="true" ShrinkLabel />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="surveyRun.Description" Label="Description" ShrinkLabel />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField Value="@FormatDate(surveyRun.CreationDate)" Label="Created" ReadOnly="true" ShrinkLabel />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField Value="@FormatDate(surveyRun.LastModificationDate)" Label="Last modified" ReadOnly="true" ShrinkLabel />
                </MudItem>
            </MudGrid>

            <MudGrid Class="mt-2">
                <MudItem xs="12" md="3">
                    <MudSelect Label="Field" T="Guid?" Value="@selectedFieldId_" ValueChanged="OnEditorFieldChanged" ShrinkLabel Clearable="true">
                        @foreach (Field field in AvailableFields)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect Label="Cluster" T="Guid?" Value="@selectedClusterId_" ValueChanged="OnEditorClusterChanged" ShrinkLabel Clearable="true">
                        @foreach (Cluster cluster in AvailableClusters)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">@cluster.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect Label="Well" T="Guid?" Value="@selectedWellId_" ValueChanged="OnEditorWellChanged" ShrinkLabel Clearable="true">
                        @foreach (Well well in AvailableWells)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">@well.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect Label="WellBore" T="Guid?" Value="@selectedWellBoreId_" ValueChanged="OnEditorWellBoreChanged" ShrinkLabel Required="true">
                        @foreach (WellBore wellBore in AvailableWellBores)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)wellBore.MetaInfo.ID)">@wellBore.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect Label="Survey instrument" T="Guid?" Value="@selectedSurveyInstrumentId_" ValueChanged="OnEditorSurveyInstrumentChanged" ShrinkLabel Required="true">
                        @foreach (SurveyInstrumentLight instrument in AvailableSurveyInstruments)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)instrument.MetaInfo.ID)">@instrument.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect Label="Survey run type" T="SurveyRunType" Value="@surveyRun.SurveyRunType" ValueChanged="@(value => surveyRun.SurveyRunType = value)" ShrinkLabel Required="true">
                        @foreach (SurveyRunType surveyRunType in SurveyRunTypes)
                        {
                            <MudSelectItem T="SurveyRunType" Value="@surveyRunType">@surveyRunType</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect Label="Parent survey run" T="Guid?" Value="@selectedParentSurveyRunId_" ValueChanged="OnEditorParentSurveyRunChanged" ShrinkLabel Clearable="true" Disabled="@(!IsParentSurveyRunRequired)">
                        @foreach (SurveyRun parentSurveyRun in AvailableParentSurveyRuns)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)parentSurveyRun.MetaInfo.ID)">@parentSurveyRun.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect T="TrajectoryCalculationType" Label="Calculation method" Value="@surveyRun.CalculationType" ValueChanged="OnCalculationTypeChanged" ShrinkLabel>
                        @foreach (TrajectoryCalculationType method in TrajectoryCalculationTypes)
                        {
                            <MudSelectItem T="TrajectoryCalculationType" Value="@method">@GetCalculationMethodLabel(method)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <MudExpansionPanels Class="mt-4">
                <MudExpansionPanel Text="Import survey stations">
                    <MudGrid>
                        <MudItem xs="12" md="3">
                            <InputFile OnChange="OnSurveyImportFileChanged" />
                            <MudText Typo="Typo.caption">@surveyImportFileName_</MudText>
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudSelect T="string" Label="File format" @bind-Value="selectedSurveyImportFormat_" ShrinkLabel>
                                @foreach (string format in SurveyImportFormats_)
                                {
                                    <MudSelectItem T="string" Value="@format">@format</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        @if (IsDelimitedImportFormat)
                        {
                            <MudItem xs="12" md="3">
                                <MudSelect T="string" Label="Column separator" @bind-Value="selectedSurveyImportSeparator_" ShrinkLabel>
                                    @foreach (string separator in SurveyImportSeparators_)
                                    {
                                        <MudSelectItem T="string" Value="@separator">@separator</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                        }
                        <MudItem xs="12" md="3">
                            <MudSelect T="string" Label="Decimal marker" @bind-Value="selectedSurveyImportDecimalMarker_" ShrinkLabel>
                                @foreach (string marker in SurveyImportDecimalMarkers_)
                                {
                                    <MudSelectItem T="string" Value="@marker">@marker</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        @if (IsDelimitedImportFormat)
                        {
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="MD column" @bind-Value="surveyImportMDColumn_" Min="1" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Incl column" @bind-Value="surveyImportInclinationColumn_" Min="1" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Az column" @bind-Value="surveyImportAzimuthColumn_" Min="1" Immediate="true" />
                            </MudItem>
                        }
                        else
                        {
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="MD start" @bind-Value="surveyImportMDStart_" Min="1" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="MD width" @bind-Value="surveyImportMDWidth_" Min="1" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Incl start" @bind-Value="surveyImportInclinationStart_" Min="1" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Incl width" @bind-Value="surveyImportInclinationWidth_" Min="1" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Az start" @bind-Value="surveyImportAzimuthStart_" Min="1" Immediate="true" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Az width" @bind-Value="surveyImportAzimuthWidth_" Min="1" Immediate="true" />
                            </MudItem>
                        }
                        <MudItem xs="12" md="2">
                            <MudSelect T="string" Label="MD unit" @bind-Value="selectedSurveyImportMDUnit_" ShrinkLabel>
                                @foreach (string unit in AvailableSurveyImportDepthUnits)
                                {
                                    <MudSelectItem T="string" Value="@unit">@unit</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudSelect T="string" Label="Incl unit" @bind-Value="selectedSurveyImportInclinationUnit_" ShrinkLabel>
                                @foreach (string unit in AvailableSurveyImportAngleUnits)
                                {
                                    <MudSelectItem T="string" Value="@unit">@unit</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="2">
                            <MudSelect T="string" Label="Az unit" @bind-Value="selectedSurveyImportAzimuthUnit_" ShrinkLabel>
                                @foreach (string unit in AvailableSurveyImportAngleUnits)
                                {
                                    <MudSelectItem T="string" Value="@unit">@unit</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="3" Class="d-flex align-center">
                            <MudButton OnClick="ImportSurveyStationsAsync" Color="Color.Primary" Variant="Variant.Filled">Import</MudButton>
                        </MudItem>
                    </MudGrid>
                </MudExpansionPanel>
            </MudExpansionPanels>

            <MudToolBar Class="mt-4">
                <MudText Typo="Typo.h6">Survey measurements</MudText>
                <MudSpacer />
                <MudButton OnClick="ExportSurveyStationsAsync" Color="@Color.Primary" Variant="Variant.Outlined" Class="add-item-btn">Export</MudButton>
                <MudButton OnClick="@AddSurveyStation" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
                <MudButton OnClick="@DeleteSurveyStations" Color="@Color.Error" Class="add-item-btn"
                           Disabled="@(!selectedSurveyStations_.Any())">Delete</MudButton>
            </MudToolBar>
            <MudTable Items="@SurveyMeasurements" MultiSelection="true" T="SurveyMeasurement"
                      @key="MeasurementReferenceRenderKey"
                      @bind-SelectedItems="selectedSurveyStations_"
                      Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true">
                <HeaderContent>
                    <MudTh></MudTh>
                    <MudTh>Measured Depth [@DepthUnitLabel]</MudTh>
                    <MudTh>Inclination [@AngleUnitLabel]</MudTh>
                    <MudTh>Azimuth [@AngleUnitLabel]</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Measured Depth">
                        <MudInputWithUnit QuantityName="DepthDrilling"
                                          @key="MeasurementReferenceRenderKey"
                                          DrillingSignalReference="@DrillingSignalReferenceType.Depth"
                                          SIValueNullable="@context.MD"
                                          SIValueNullableChanged="@(val => OnSurveyStationMdChanged(context, val))" />
                    </MudTd>
                    <MudTd DataLabel="Inclination">
                        <MudInputWithUnit QuantityName="PlaneAngleDrilling"
                                          SIValueNullable="@context.Inclination"
                                          SIValueNullableChanged="@(val => OnSurveyStationInclinationChanged(context, val))" />
                    </MudTd>
                    <MudTd DataLabel="Azimuth">
                        <MudInputWithUnit QuantityName="PlaneAngleDrilling"
                                          SIValueNullable="@context.Azimuth"
                                          SIValueNullableChanged="@(val => OnSurveyStationAzimuthChanged(context, val))" />
                    </MudTd>
                    <MudTd>
                        <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="(() => DeleteSurveyStation(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudExpansionPanels Class="mt-4">
                <MudExpansionPanel Text="Calculated survey run" ExpandedChanged="@OnCalculatedStationsPanelExpandedChanged">
                    <MudToolBar>
                        <MudText Typo="Typo.h6">Calculated survey run</MudText>
                        <MudSpacer />
                        <MudButton OnClick="ExportCalculatedSurveyRunAsync" Color="@Color.Primary" Variant="Variant.Outlined" Disabled="@isLoadingCalculatedStations_">Export</MudButton>
                    </MudToolBar>
                    @if (surveyRun.TieInPoint is { } tieInPoint)
                    {
                        <MudGrid Class="mb-4">
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle1">Tie in point</MudText>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <MudText>Measured Depth: @FormatDepthValue(tieInPoint.MD)</MudText>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <MudText>Inclination: @FormatAngleValue(tieInPoint.Inclination)</MudText>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <MudText>Azimuth: @FormatAngleValue(tieInPoint.Azimuth)</MudText>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <MudText>Vertical Depth: @FormatDepthValue(tieInPoint.TVD)</MudText>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <MudText>@NorthCoordinateLabel: @FormatPositionValue(tieInPoint.RiemannianNorth, PositionDirectionType.North)</MudText>
                            </MudItem>
                            <MudItem xs="6" md="2">
                                <MudText>@EastCoordinateLabel: @FormatPositionValue(tieInPoint.RiemannianEast, PositionDirectionType.East)</MudText>
                            </MudItem>
                        </MudGrid>
                    }
                    @if (isLoadingCalculatedStations_)
                    {
                        <MudPaper Class="pa-4" Outlined="true">
                            <MudText Typo="Typo.body2">@CalculatedStationLoadingText</MudText>
                            <MudProgressLinear Value="@CalculatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                        </MudPaper>
                    }
                    else if (surveyRun.SurveyStationList is { Count: > 0 } calculatedList)
                    {
                        <MudTable Items="@calculatedList" T="SurveyStation" Height="400px" FixedHeader="true"
                                  @key="MeasurementReferenceRenderKey"
                                  Virtualize="true" OverscanCount="3" ItemSize="38"
                                  Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true" ReadOnly="true">
                            <HeaderContent>
                                <MudTHeadRow>
                                    <MudTh>Measured Depth [@DepthUnitLabel]</MudTh>
                                    <MudTh>Inclination [@AngleUnitLabel]</MudTh>
                                    <MudTh>Azimuth [@AngleUnitLabel]</MudTh>
                                    <MudTh>Vertical Depth [@DepthUnitLabel]</MudTh>
                                    <MudTh>@NorthCoordinateLabel [@PositionUnitLabel]</MudTh>
                                    <MudTh>@EastCoordinateLabel [@PositionUnitLabel]</MudTh>
                                    <MudTh>Vertical Section [@LengthUnitLabel]</MudTh>
                                    <MudTh>Curvature [@CurvatureUnitLabel]</MudTh>
                                    <MudTh>BUR [@CurvatureUnitLabel]</MudTh>
                                    <MudTh>TR [@CurvatureUnitLabel]</MudTh>
                                </MudTHeadRow>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Measured Depth">
                                    <MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.MD" />
                                </MudTd>
                                <MudTd DataLabel="Inclination">
                                    <MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Inclination" />
                                </MudTd>
                                <MudTd DataLabel="Azimuth">
                                    <MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Azimuth" />
                                </MudTd>
                                <MudTd DataLabel="Vertical Depth">
                                    <MudSpanWithUnit QuantityName="DepthDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Depth" SIValue="@context.TVD" />
                                </MudTd>
                                <MudTd DataLabel="@NorthCoordinateLabel">
                                    <MudSpanWithUnit QuantityName="PositionDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Position" PositionDirection="@PositionDirectionType.North" SIValue="@context.RiemannianNorth" />
                                </MudTd>
                                <MudTd DataLabel="@EastCoordinateLabel">
                                    <MudSpanWithUnit QuantityName="PositionDrilling" DrillingSignalReference="@DrillingSignalReferenceType.Position" PositionDirection="@PositionDirectionType.East" SIValue="@context.RiemannianEast" />
                                </MudTd>
                                <MudTd DataLabel="Vertical Section">
                                    <MudSpanWithUnit QuantityName="DepthDrilling" SIValue="@context.VerticalSection" />
                                </MudTd>
                                <MudTd DataLabel="Curvature">
                                    <MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.Curvature" />
                                </MudTd>
                                <MudTd DataLabel="BUR">
                                    <MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.BUR" />
                                </MudTd>
                                <MudTd DataLabel="TR">
                                    <MudSpanWithUnit QuantityName="CurvatureDrilling" SIValue="@context.TUR" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudExpansionPanel>
                <MudExpansionPanel Text="Uncertainty ellipses" ExpandedChanged="@OnCalculatedStationsPanelExpandedChanged">
                    @if (isLoadingCalculatedStations_)
                    {
                        <MudPaper Class="pa-4" Outlined="true">
                            <MudText Typo="Typo.body2">@CalculatedStationLoadingText</MudText>
                            <MudProgressLinear Value="@CalculatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                        </MudPaper>
                    }
                    else if (surveyRun.SurveyStationList is { Count: > 0 } calculatedList)
                    {
                        <SurveyStationEllipseTable SurveyStationList="@calculatedList"
                                                   SurveyInstrumentID="@surveyRun.SurveyInstrumentID"
                                                   CalculationName="@($"{surveyRun.Name} uncertainty ellipses")"
                                                   EllipseResultsChanged="OnEllipseResultsChanged"
                                                   CalculationChanged="OnEllipseCalculationChanged" />
                    }
                </MudExpansionPanel>
                <MudExpansionPanel Text="Plot survey run" Style="overflow: visible;" ExpandedChanged="@OnCalculatedStationsPanelExpandedChanged">
                    @if (isLoadingCalculatedStations_)
                    {
                        <MudPaper Class="pa-4" Outlined="true">
                            <MudText Typo="Typo.body2">@CalculatedStationLoadingText</MudText>
                            <MudProgressLinear Value="@CalculatedStationLoadingProgressPercent" Color="Color.Info" Class="mt-2" />
                        </MudPaper>
                    }
                    else if (surveyRun.SurveyStationList is { Count: > 0 })
                    {
                        <MudToolBar>
                            <MudText Typo="Typo.h6">Plot</MudText>
                        </MudToolBar>
                        <MudGrid Justify="Justify.Center">
                            <MudItem xs="12">
                                <Scatter3DPlot NameList="@ThreeDNameList" ModeFlagList="@ThreeDModeFlagList" ColorList="@ThreeDColorList"
                                               ShowLegendList="@ThreeDShowLegendList"
                                               XValuesList="@ThreeDNorthValuesList" YValuesList="@ThreeDEastValuesList" ZValuesList="@ThreeDTvdValuesList"
                                               YAxisReversed="@true" ZAxisReversed="@true"
                                               PlotTitle="" XAxisTitle="@NorthCoordinateLabel" YAxisTitle="@EastCoordinateLabel" ZAxisTitle="TVD"
                                               XUnit="PositionDrilling" YUnit="PositionDrilling" ZUnit="DepthDrilling"
                                               XAxisUsesPositionReference="@true"
                                               YAxisUsesPositionReference="@true"
                                               ZAxisUsesDepthReference="@true"
                                               XAxisPositionDirection="@PositionDirectionType.North"
                                               YAxisPositionDirection="@PositionDirectionType.East">
                                </Scatter3DPlot>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <ScatterPlot NameList="@HorizontalNameList" ModeFlagList="@HorizontalModeFlagList" ColorList="@HorizontalColorList"
                                             ShowLegendList="@HorizontalShowLegendList"
                                             XValuesList="@HorizontalEastValuesList" YValuesList="@HorizontalNorthValuesList"
                                             PlotTitle="" XAxisTitle="@EastCoordinateLabel" YAxisTitle="@NorthCoordinateLabel"
                                             XUnit="PositionDrilling" YUnit="PositionDrilling"
                                             XAxisUsesPositionReference="@true"
                                             YAxisUsesPositionReference="@true"
                                             XAxisPositionDirection="@PositionDirectionType.East"
                                             YAxisPositionDirection="@PositionDirectionType.North"
                                             AspectRatio="1">
                                </ScatterPlot>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <ScatterPlot NameList="@VerticalNameList" ModeFlagList="@VerticalModeFlagList" ColorList="@VerticalColorList"
                                             ShowLegendList="@VerticalShowLegendList"
                                             XValuesList="@VerticalSectionValuesList" YValuesList="@VerticalTvdValuesList"
                                             PlotTitle="" XAxisTitle="Vertical Section" YAxisTitle="TVD"
                                             XUnit="DepthDrilling" YUnit="DepthDrilling"
                                             XAxisStartsAtZero="@true"
                                             YAxisUsesDepthReference="@true"
                                             YAxisReversed="@true"
                                             AspectRatio="1">
                                </ScatterPlot>
                            </MudItem>
                        </MudGrid>
                    }
                    else
                    {
                        <MudText>No calculated survey run</MudText>
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    }
    else if (surveyRunList_ == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <MudGrid Class="mb-4">
            <MudItem xs="12" md="3">
                <MudSelect Label="Field" T="Guid?" Value="@listSelectedFieldId_" ValueChanged="OnListFieldChanged" ShrinkLabel Clearable="true">
                    @foreach (Field field in AvailableFields)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)field.MetaInfo.ID)">@field.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Cluster" T="Guid?" Value="@listSelectedClusterId_" ValueChanged="OnListClusterChanged" ShrinkLabel Clearable="true">
                    @foreach (Cluster cluster in AvailableListClusters)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)cluster.MetaInfo.ID)">@cluster.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="Well" T="Guid?" Value="@listSelectedWellId_" ValueChanged="OnListWellChanged" ShrinkLabel Clearable="true">
                    @foreach (Well well in AvailableListWells)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)well.MetaInfo.ID)">@well.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3">
                <MudSelect Label="WellBore" T="Guid?" Value="@listSelectedWellBoreId_" ValueChanged="OnListWellBoreChanged" ShrinkLabel Clearable="true">
                    @foreach (WellBore wellBore in AvailableListWellBores)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)wellBore.MetaInfo.ID)">@wellBore.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <MudDataGrid T="SurveyRunLight" @key="gridKey_"
                     MultiSelection="true" Items="@surveyRunList_" SelectedItemsChanged="@SelectedItemsChanged"
                     Hover="true" RowClick="@RowClicked"
                     SortMode="SortMode.Multiple" QuickFilter="@SurveyRunFilter" Filterable="false"
                     ReadOnly="true" ColumnResizeMode="ResizeMode.Column" Elevation="0">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Survey Run</MudText>
                <MudButton OnClick="@AddSurveyRun" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
                <MudButton OnClick="@DeleteSelectedSurveyRunsAsync" Color="@Color.Error" Class="add-item-btn"
                           Disabled="@(selectedSurveyRunList_.Count == 0)">Delete</MudButton>
                <MudSpacer />
                <MudTextField @bind-Value="searchString_" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <Columns>
                <SelectColumn T="SurveyRunLight" />
                <PropertyColumn Property="x => x.Name" Title="Survey Run" CellStyle="width: 25%;" Sortable="true" Editable="false" />
                <PropertyColumn Property="x => x.Description" Title="Description" CellStyle="width: 30%;" Sortable="true" Editable="false" />
                <PropertyColumn Property="x => GetWellBoreNameFromID(x.WellBoreID)" Title="WellBore" Sortable="true" />
                <PropertyColumn Property="x => GetSurveyInstrumentNameFromID(x.SurveyInstrumentID)" Title="Survey Instrument" Sortable="true" />
                <PropertyColumn Property="x => x.SurveyRunType" Title="Type" Sortable="true" />
                <TemplateColumn Title="Calculation" Sortable="true">
                    <CellTemplate>
                        @CalculationStatusContent(context.Item)
