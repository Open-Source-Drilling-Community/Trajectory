    private async Task PollSurveyRunCalculationAsync(Guid surveyRunId, List<SurveyMeasurement> surveyMeasurements)
    {
        for (int attempt = 0; attempt < 120; attempt++)
        {
            List<SurveyRunLight> lights = ((IEnumerable<SurveyRunLight>)await Api.ClientTrajectory.GetAllSurveyRunLightAsync()).ToList();
            SurveyRunLight? light = lights.FirstOrDefault(item => item.MetaInfo?.ID == surveyRunId);
            if (light == null)
            {
                return;
            }

            if (currentSurveyRun_ != null)
            {
                currentSurveyRun_.CalculationState = light.CalculationState;
                currentSurveyRun_.CalculationProgress = light.CalculationProgress;
                currentSurveyRun_.CalculationMessage = light.CalculationMessage;
                currentSurveyRun_.SurveyMeasurementList = surveyMeasurements;
            }
            await InvokeAsync(StateHasChanged);

            if (light.CalculationState != CalculationState.Running &&
                light.CalculationState != CalculationState.Queued)
            {
                return;
            }

            await Task.Delay(TimeSpan.FromSeconds(1));
        }
    }

