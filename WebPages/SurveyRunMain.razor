            },
            SurveyStationList = []
        };

        surveyRunIdBeingEdited_ = null;
        selectedFieldId_ = currentSurveyRun_.FieldID;
        selectedClusterId_ = currentSurveyRun_.ClusterID;
        selectedWellId_ = currentSurveyRun_.WellID;
        selectedWellBoreId_ = currentSurveyRun_.WellBoreID == Guid.Empty ? null : currentSurveyRun_.WellBoreID;
        selectedSurveyInstrumentId_ = null;
        selectedParentSurveyRunId_ = null;
        selectedSurveyStations_.Clear();
        ResetCalculatedStationLoadingState();
        EnsureSurveyImportUnitsSelected();
        UpdateSelectedSurveyRunReferenceSource();
        UpdatePlots();
        isEditing_ = true;
