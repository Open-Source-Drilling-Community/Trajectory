@inject ILogger<TrajectoryEdit> logger
@inject ISnackbar Snackbar

<MudText Class="mt-4 mb-4" Typo="Typo.h6">Edit Trajectory</MudText>
<MudContainer Class="d-flex flex-row mt-4 mb-4">
    <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Secondary" OnClick="DuplicateTrajectory">Duplicate</MudButton>
    <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Success" OnClick="SaveTrajectory">Save</MudButton>
    <MudButton Class="me-1" Variant="Variant.Filled" Color="Color.Error" OnClick="SendMessage">Cancel</MudButton>
</MudContainer>

@if (currentTrajectory is { } traj)
{
    @* General information *@
    <MudGrid>
        <MudItem xs="3">
            <MudTextField @bind-Value="traj.Name" Label="Name" Required="true" For="@(() => traj.Name)" ShrinkLabel />
        </MudItem>
        <MudItem xs="4">
            <MudTextField @bind-Value="traj.Description" Label="Description" For="@(() => traj.Description)" ShrinkLabel />
        </MudItem>
        <MudItem xs="3">
            <MudSelect Label="WellBore" T="Guid" Value="@traj.WellBoreID" ValueChanged="@((val) => UpdateWellBoreSelection(val))" ShrinkLabel>
                @if (WellBoreList is { Count: > 0 } wbList)
                {
                    @foreach (WellBore wb in wbList)
                    {
                        <MudSelectItem Value="@wb.MetaInfo.ID">
                            @wb.Name
                        </MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="2">
            <MudInputWithUnitAdornment QuantityLabel="Depth" QuantityName="DepthDrilling"
                                       SIValue="@traj.MDStep"
                                       SIValueChanged="@(val => traj.MDStep = val)" />
        </MudItem>
    </MudGrid>
    <MudExpansionPanels Class="mt-4 mb-4" Style="overflow-y: auto; max-height: none;">
        @* Survey stations *@
        <MudExpansionPanel Text="Survey stations" @bind-IsExpanded="isSurveyExpanded">
            @if (traj.SurveyStationList is { } ssList)
            {
                <MudToolBar>
                    <MudText Typo="Typo.h6">Survey stations</MudText>
                    <MudSpacer />
                    <MudButton OnClick="@AddSurveyStation" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
                    <MudButton OnClick="@DeleteSurveyStations" Color="@Color.Error" Class="add-item-btn">Delete</MudButton>
                </MudToolBar>
                <MudTable Items="@ssList" MultiSelection="true" T="SurveyStation"
                          @bind-SelectedItems="selectedSurveyStations"
                          Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true">
                    <HeaderContent>
                        <MudTHeadRow IsCheckable="true">
                            <MudTh>Measured Depth [@Parent.GetUnitLabel("DepthDrilling")]</MudTh>
                            <MudTh>Inclination [@Parent.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                            <MudTh>Azimuth [@Parent.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                            <MudTh /><MudTh /><MudTh />
                        </MudTHeadRow>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Measured Depth">
                            <MudInputWithUnit QuantityName="DepthDrilling"
                                              SIValueNullable="@context.MD"
                                              SIValueNullableChanged="@(val => context.MD = val)" />
                        </MudTd>
                        <MudTd DataLabel="Inclination">
                            <MudInputWithUnit QuantityName="PlaneAngleDrilling"
                                              SIValueNullable="@context.Inclination"
                                              SIValueNullableChanged="@(val => context.Inclination = val)" />
                        </MudTd>
                        <MudTd DataLabel="Azimuth">
                            <MudInputWithUnit QuantityName="PlaneAngleDrilling"
                                              SIValueNullable="@context.Azimuth"
                                              SIValueNullableChanged="@(val => context.Azimuth = val)" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudText>No survey stations</MudText>
            }
        </MudExpansionPanel>
        @* Interpolated trajectory *@
        <MudExpansionPanel Text="Interpolated trajectory" IsExpandedChanged="@OnInterpolExpandedChanged">
            @if (traj.InterpolatedTrajectory is { } spList)
            {
                <MudToolBar>
                    <MudText Typo="Typo.h6">Interpolated trajectory</MudText>
                </MudToolBar>
                <MudTable Items="@spList" T="SurveyPoint" Height="400px" FixedHeader="true"
                          Elevation="1" CustomHeader="true" Hover="true" Dense="true" Bordered="true">
                    <HeaderContent>
                        <MudTHeadRow>
                            <MudTh>Measured Depth [@Parent.GetUnitLabel("DepthDrilling")]</MudTh>
                            <MudTh>Inclination [@Parent.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                            <MudTh>Azimuth [@Parent.GetUnitLabel("PlaneAngleDrilling")]</MudTh>
                            <MudTh>Riemannian North [@Parent.GetUnitLabel("PositionDrilling")]</MudTh>
                            <MudTh>Riemannian East [@Parent.GetUnitLabel("PositionDrilling")]</MudTh>
                            <MudTh>TVD [@Parent.GetUnitLabel("DepthDrilling")]</MudTh>
                        </MudTHeadRow>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Measured Depth">
                            <MudSpanWithUnit QuantityName="DepthDrilling" SIValue="@context.MD" />
                        </MudTd>
                        <MudTd DataLabel="Inclination">
                            <MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Inclination" />
                        </MudTd>
                        <MudTd DataLabel="Azimuth">
                            <MudSpanWithUnit QuantityName="PlaneAngleDrilling" SIValue="@context.Azimuth" />
                        </MudTd>
                        <MudTd DataLabel="Riemannian North">
                            <MudSpanWithUnit QuantityName="PositionDrilling" SIValue="@context.RiemannianNorth" />
                        </MudTd>
                        <MudTd DataLabel="Riemannian East">
                            <MudSpanWithUnit QuantityName="PositionDrilling" SIValue="@context.RiemannianEast" />
                        </MudTd>
                        <MudTd DataLabel="TVD">
                            <MudSpanWithUnit QuantityName="DepthDrilling" SIValue="@context.TVD" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudText>No interpolated trajectory</MudText>
            }
        </MudExpansionPanel>
        @* Plot trajectory *@
        <MudExpansionPanel Text="Plot trajectory" IsExpandedChanged="@OnPlotExpandedChanged"
                           Style="overflow: visible;">
            @if (traj.SurveyStationList is { } ssList && traj.InterpolatedTrajectory is { } spList)
            {
                <MudToolBar>
                    <MudText Typo="Typo.h6">Plot</MudText>
                </MudToolBar>
                @* Major flaw in the visualization here: 
                        Scatter plot 3D representation assumes coordinates are expressed in an Euclidean space, which is not the case with Riemannian coordinates.
                        Ideally, XYZ coordinates should represent Euclidean coordinates in an Earth fixed system (Earth-centered, or arbitrary reference point-centered)
                    *@
                <MudGrid Justify="Justify.Center">
                    <MudItem xs="12">
                        <Scatter3DPlot NameList="@nameList" ModeFlagList="@modeFlagList" ColorList="@colorList"
                                       XValuesList="@northValuesList" YValuesList="@eastValuesList" ZValuesList="@TVDValuesList"
                                       YAxisReversed="@true" ZAxisReversed="@true"
                                       PlotTitle="" XAxisTitle="North" YAxisTitle="East" ZAxisTitle="TVD"
                                       XUnit="PositionDrilling" YUnit="PositionDrilling" ZUnit="DepthDrilling">
                        </Scatter3DPlot>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText>Either no survey stations or interpolated trajectory</MudText>
            }
        </MudExpansionPanel>
    </MudExpansionPanels>
}

@code {
    [CascadingParameter]
    private MudUnitAndReferenceChoiceTag? Parent { get; set; }
    [Parameter]
    public Guid? TrajectoryId { get; set; }
    [Parameter]
    public List<WellBore>? WellBoreList { get; set; }
    [Parameter]
    public EventCallback ValueChanged { get; set; }

    private Trajectory currentTrajectory = PseudoConstructors.ConstructTrajectory();
    private HashSet<SurveyStation> selectedSurveyStations = new();
    private bool isSurveyExpanded = false;
    private bool isInterpolExpanded = false;
    private bool isPlotExpanded = false;

    // Plot variables
    string[] colorScale = { "black", "blue", "grey", "red", "orange", "green", "yellow", "pink", "brown", "purple" };
    List<string> nameList = new List<string>(); //name of each curve in the list to plot
    List<int> modeFlagList = new List<int>(); //modeFlag of each curve in the list to plot (1 = lines; 2 = markers)
    List<string> colorList = new List<string>(); //color of each curve in the list of curves to plot
    List<List<object>> northValuesList = new List<List<object>>(); //North values for the list of curves to plot
    List<List<object>> eastValuesList = new List<List<object>>(); //East values for the list of curves to plot
    List<List<object>> TVDValuesList = new List<List<object>>(); //TVD values for the list of curves to plot

    // Lifecycle
    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    /// <summary>
    /// Loads (or reloads) the trajectory independently of the Blazor lifecycle hook.
    /// Always call this for refreshes — never call OnInitializedAsync() directly.
    /// </summary>
    private async Task LoadDataAsync()
    {
        try
        {
            if (WellBoreList == null || WellBoreList.Count == 0)
            {
                logger.LogError("No wellbore available on loading/initialization of trajectory");
                return;
            }
            if (TrajectoryId != null)
            {
                currentTrajectory = await APIUtils.ClientTrajectory.GetTrajectoryByIdAsync(TrajectoryId.Value);
            }
            else
            {
                await InitializeTrajectoryAsync(currentTrajectory);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem while loading the selected Trajectory");
            return;
        }
        //Plot is updated at each reload of the Single Page Application to make sure the chart is not disposed
        UpdatePlots();
        await InvokeAsync(() => { StateHasChanged(); });
    }

    //Send message to parent component
    private async Task SendMessage()
    {
        await ValueChanged.InvokeAsync();
    }
    //Add/Edit panel controls
    private async Task SaveTrajectory()
    {
        try
        {
            if (currentTrajectory is { } && IsValidTrajectory(currentTrajectory))
            {
                if (TrajectoryId != null)
                {
                    currentTrajectory.LastModificationDate = DateTimeOffset.UtcNow;
                    await APIUtils.ClientTrajectory.PutTrajectoryByIdAsync(TrajectoryId.Value, currentTrajectory);
                    Snackbar.Add("Trajectory updated successfully", Severity.Success);
                    await SendMessage();
                }
                else
                {
                    // voluntarily mutating current trajectory which has not been posted yet
                    currentTrajectory.MetaInfo.ID = Guid.NewGuid();
                    currentTrajectory.CreationDate = DateTimeOffset.UtcNow;
                    currentTrajectory.LastModificationDate = DateTimeOffset.UtcNow;
                    await APIUtils.ClientTrajectory.PostTrajectoryAsync(currentTrajectory);
                    Snackbar.Add("Trajectory created successfully", Severity.Success);
                    await SendMessage();
                }
            }
            else
            {
                Snackbar.Add("Trajectory badly configured (at least 3 survey stations with valid coordinates)", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error saving Trajectory");
            Snackbar.Add("Error saving Trajectory: " + ex.Message, Severity.Warning);
        }
    }
    private async Task DuplicateTrajectory()
    {
        try
        {
            if (currentTrajectory is { } && IsValidTrajectory(currentTrajectory))
            {
                Trajectory newTraj = DeepCopyTrajectory(currentTrajectory);
                var nowDate = DateTimeOffset.UtcNow;
                newTraj.CreationDate = nowDate;
                newTraj.LastModificationDate = nowDate;
                newTraj.MetaInfo.ID = Guid.NewGuid();
                newTraj.Name += "-copy";
                await APIUtils.ClientTrajectory.PostTrajectoryAsync(newTraj);
                Snackbar.Add("Trajectory duplicated successfully", Severity.Success);
                await SendMessage();
            }
            else
            {
                Snackbar.Add("Trajectory badly configured (at least 3 survey stations with valid coordinates)", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Error duplicating Trajectory");
            Snackbar.Add("Error duplicating Trajectory: " + ex.Message, Severity.Warning);
        }
    }

    // Expansion panel event handlers
    /// <summary>
    /// Tracks interpolated-trajectory panel state.
    /// No StateHasChanged needed here — MudTable renders fine without a JS interop init.
    /// </summary>
    private void OnInterpolExpandedChanged(bool expanded)
    {
        isInterpolExpanded = expanded;
    }

    /// <summary>
    /// Tracks plot panel state AND triggers a re-render so that
    /// Plotly's OnAfterRenderAsync runs and mounts the chart canvas on first open.
    /// </summary>
    private async Task OnPlotExpandedChanged(bool expanded)
    {
        isPlotExpanded = expanded;
        if (expanded)
        {
            // Give MudBlazor's expand animation one tick to finish, then let
            // Plotly measure the container and draw into it.
            await Task.Delay(50);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void UpdateWellBoreSelection(Guid wellBoreId)
    {
        currentTrajectory.WellBoreID = wellBoreId;
    }
    private void AddSurveyStation()
    {
        double? lastMD = 0.0;
        if (currentTrajectory.SurveyStationList.Count > 0)
            lastMD = currentTrajectory.SurveyStationList.Last().MD;
        currentTrajectory.SurveyStationList.Add(new SurveyStation() { MD = lastMD + 10 * currentTrajectory.MDStep, Inclination = 0, Azimuth = 0 });
    }
    private void DeleteSurveyStation(SurveyStation station)
    {
        currentTrajectory.SurveyStationList.Remove(station);
    }
    private void DeleteSurveyStations()
    {
        foreach (SurveyStation point in selectedSurveyStations)
            DeleteSurveyStation(point);
    }
    private bool IsValidTrajectory(Trajectory traj)
    {
        bool success = false;
        if (traj.MDStep > 0.0 && traj.SurveyStationList is { Count: > 2 } ssList)
        {
            success = true;
            foreach (var ss in ssList)
                success &= ss.MD is { } && ss.Inclination is { } && ss.Azimuth is { };
        }
        return success;
    }
    private async Task InitializeTrajectoryAsync(Trajectory traj)
    {
        try
        {
            WellBore wellBore = WellBoreList![0];
            traj.WellBoreID = wellBore.MetaInfo.ID;
            // retrieve the cluster and slot hosting the wellbore from the microservice architecture
            (GaussianGeodeticPoint3D? referencePoint, string msg) = await APIUtils.GetReferencePointAsync(wellBore);
            if (referencePoint?.LatitudeWGS84 is { } refLat &&
                referencePoint?.LongitudeWGS84 is { } refLon &&
                referencePoint?.TvdWGS84 is { } refTVD)
            {
                logger.LogInformation(msg);
                if (traj.MDStep == 0.0)
                    traj.MDStep = 10.0;
                traj.SurveyStationList.Clear();
                // TODO: fix bug with using global geodetic coordinates of the slot hosting the trajectory, called reference point (the interpolate function fails badly)
                // TODO: X=RiemannianNorth should be refined to discriminate between Riemannian coordinates and Euclidean ones.
                // TODO: in addition to globa coordinates for X, Riemannian ones, local Eulidean coordinates would be convenient to have
                // traj.SurveyStationList.Add(new SurveyStation() { MD = 0, Inclination = 0, Azimuth = 0, Latitude = refLat, Longitude = refLon, TVD = refTVD });
                // TODO: the case below with zero Riemannian coordinates falls back to values compatible with local range, although this is not satisfactory at all because
                //  - 1) computations are done in Riemannian space but are visualized in an Euclidean Scatter3DPlot
                //  - 2) the zero in Riemannian space should be on the the Equator parallel and Greenwich meridian, whereas they are apparently purely local in this case. Handling of computations in Surveying is wrong, to be debugged.
                traj.SurveyStationList.Add(new SurveyStation() { MD = 0, Inclination = 0, Azimuth = 0, RiemannianNorth = 0, RiemannianEast = 0, TVD = 0 });
                traj.SurveyStationList.Add(new SurveyStation() { MD = 10 * traj.MDStep, Inclination = 0, Azimuth = 0 });
                traj.SurveyStationList.Add(new SurveyStation() { MD = 20 * traj.MDStep, Inclination = 0, Azimuth = 0 });
            }
            else
            {
                logger.LogError(msg);
                Snackbar.Add("Error while retrieving the reference point of the slot hosting the initial wellbore of the trajectory: " + msg, Severity.Warning);
                return;
            }

        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Exception raised at initialization of trajectory");
            Snackbar.Add("Exception raised at initialization of trajectory", Severity.Error);
        }
    }

    //Update unit system
    private void ManageUnits() { }

    private void UpdatePlots()
    {
        DataUtils.UpdatePlots(
            nameList,
            modeFlagList,
            colorList,
            northValuesList,
            eastValuesList,
            TVDValuesList,
            [currentTrajectory]
        );
    }

    // Deep copy constructor
    private static Trajectory DeepCopyTrajectory(Trajectory source)
    {
        return new Trajectory
        {
            MetaInfo = new MetaInfo { ID = source.MetaInfo.ID },
            Name = source.Name,
            Description = source.Description,
            CreationDate = source.CreationDate,
            LastModificationDate = source.LastModificationDate,
            WellBoreID = source.WellBoreID,
            MDStep = source.MDStep,
            SurveyStationList = source.SurveyStationList
                .Select(ss => new SurveyStation
                {
                    MD = ss.MD,
                    Inclination = ss.Inclination,
                    Azimuth = ss.Azimuth,
                    RiemannianNorth = ss.RiemannianNorth,
                    RiemannianEast = ss.RiemannianEast,
                    TVD = ss.TVD
                })
                .ToList(),
            InterpolatedTrajectory = source.InterpolatedTrajectory?
                .Select(sp => new SurveyPoint
                {
                    MD = sp.MD,
                    Inclination = sp.Inclination,
                    Azimuth = sp.Azimuth,
                    RiemannianNorth = sp.RiemannianNorth,
                    RiemannianEast = sp.RiemannianEast,
                    TVD = sp.TVD
                })
                .ToList()
        };
    }

}
